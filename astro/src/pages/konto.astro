---
import Base from '@/layouts/Base.astro';

export const prerender = false;

// If already authenticated (DS cookie present), go straight to profile
const sessionToken = Astro.cookies.get('DS')?.value;
if (sessionToken) {
  const redirect = Astro.url.searchParams.get('redirect') ?? '/konto/profil';
  return Astro.redirect(redirect);
}

const DESCOPE_PROJECT_ID = import.meta.env.DESCOPE_PROJECT_ID ?? '';
---

<Base locale="da" title="Min konto | AB 1889">
  <main class="min-h-screen flex items-center justify-center px-4 py-24" style="background:#060806">
    <div class="w-full max-w-md">

      {/* AB Monogram placeholder — swap for licensed SVG before launch */}
      <div class="flex justify-center mb-10">
        <div
          class="w-16 h-16 rounded-full flex items-center justify-center text-white font-black text-xl"
          style="background:#006A52"
          aria-label="AB 1889"
        >
          AB
        </div>
      </div>

      <h1
        class="text-center text-2xl font-black uppercase mb-2"
        style="color:#D6A02A;letter-spacing:0.14em"
      >
        Min konto
      </h1>
      <p class="text-center text-sm mb-8" style="color:#8AA898">
        Akademisk Boldklub 1889
      </p>

      {DESCOPE_PROJECT_ID ? (
        <div id="descope-container"></div>
      ) : (
        <div
          class="border p-6 text-center text-sm"
          style="border-color:#152214;color:#8AA898"
        >
          {/* TODO(descope): configure DESCOPE_PROJECT_ID to enable login */}
          Login kræver konfiguration. Kontakt AB 1889.
        </div>
      )}

    </div>
  </main>

  {DESCOPE_PROJECT_ID && (
    <script type="module" define:vars={{ DESCOPE_PROJECT_ID }}>
      import('https://unpkg.com/@descope/web-component@3/dist/index.js').then(() => {
        const el = document.createElement('descope-wc');
        el.setAttribute('project-id', DESCOPE_PROJECT_ID);
        el.setAttribute('flow-id', 'sign-up-or-in');
        el.setAttribute('theme', 'dark');
        el.setAttribute('locale', 'da-DK');

        el.addEventListener('success', (e) => {
          const params = new URLSearchParams(location.search);
          location.href = params.get('redirect') ?? '/konto/profil';
        });

        document.getElementById('descope-container')?.appendChild(el);
      });
    </script>
  )}
</Base>
