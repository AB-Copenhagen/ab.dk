---
import Base from '@/layouts/Base.astro';
import { fetchCollectionType, strapiMediaUrl } from '@/lib/strapi/client';

export const prerender = false;

const T = {
  ground:  '#060806',
  surface: '#0D1A10',
  border:  '#152214',
  green:   '#006A52',
  gold:    '#D6A02A',
  muted:   '#8AA898',
};

const { slug } = Astro.params;

let product: any = null;

try {
  const results = await fetchCollectionType<any[]>('products', {
    filters: { slug: { $eq: slug } },
    locale: 'da',
    populate: ['image', 'gallery'],
  });
  product = results?.[0] ?? null;
} catch { /* fall through to 404 */ }

if (!product) {
  return Astro.redirect('/products');
}

const { name, description, price, buyLink, category } = product;
const imageUrl = product.image?.url ? strapiMediaUrl(product.image.url) : null;
const gallery: any[] = product.gallery ?? [];
---

<Base locale="da" title={`${name} | AB 1889`}>

  {/* ── Back nav ───────────────────────────────────────────────────────── */}
  <div class="border-b" style={`border-color:${T.border}`}>
    <div class="max-w-7xl mx-auto px-5 md:px-12 pt-10 pb-6">
      <a
        href="/products"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase mb-8"
        style={`color:${T.muted};letter-spacing:0.15em`}
      >
        ← Alle produkter
      </a>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 md:px-12 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      {/* ── Image ─────────────────────────────────────────────────────────── */}
      <div class="space-y-3">
        <div class="aspect-square overflow-hidden border" style={`border-color:${T.border};background:${T.surface}`}>
          {imageUrl ? (
            <img
              src={imageUrl}
              alt={name}
              class="w-full h-full object-cover"
            />
          ) : (
            <div
              class="w-full h-full flex items-center justify-center font-black text-6xl"
              style={`color:rgba(0,106,82,0.15)`}
            >
              AB
            </div>
          )}
        </div>
        {gallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2">
            {gallery.slice(0, 4).map((img: any) => (
              <div class="aspect-square overflow-hidden border" style={`border-color:${T.border}`}>
                <img
                  src={strapiMediaUrl(img.url)}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      {/* ── Info ──────────────────────────────────────────────────────────── */}
      <div class="flex flex-col justify-start pt-2">
        {category && (
          <p class="text-[0.6rem] font-bold uppercase mb-3" style={`color:${T.gold};letter-spacing:0.2em`}>
            {category}
          </p>
        )}
        <h1
          class="font-black text-white mb-4"
          style="font-size:clamp(2rem,5vw,3.5rem);letter-spacing:-0.03em;line-height:0.95"
        >
          {name}
        </h1>

        {price && (
          <p class="text-3xl font-black tabular-nums mb-8" style={`color:${T.gold}`}>
            {price}
          </p>
        )}

        {description && (
          <div class="mb-8">
            <div class="h-px mb-6" style={`background:${T.border}`}></div>
            <p class="text-sm leading-relaxed" style={`color:${T.muted}`}>
              {description}
            </p>
          </div>
        )}

        {buyLink && (
          <a
            href={buyLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 font-black text-sm uppercase tracking-widest text-black transition-all"
            style={`background:${T.gold};letter-spacing:0.15em`}
          >
            Køb nu →
          </a>
        )}

        <div class="mt-8 h-0.5 w-12" style={`background:${T.green}`}></div>
      </div>

    </div>
  </div>
</Base>
