---
import Base from '@/layouts/Base.astro';
import ArticleContent from '@/components/islands/ArticleContent';
import { fetchCollectionType } from '@/lib/strapi/client';
import { strapiMediaUrl } from '@/lib/strapi/client';
export const prerender = false;

const { slug } = Astro.params;
const locale = 'da';

const T = { border: '#152214', surface: '#0D1A10', green: '#006A52', gold: '#D6A02A', muted: '#8AA898' };
const STRAPI_URL = import.meta.env.STRAPI_URL ?? 'http://localhost:1337';

const results = await fetchCollectionType<any[]>('articles', {
  locale,
  filters: { slug: { $eq: slug } },
}).catch(() => [] as any[]);

const article = results[0];

if (!article) {
  return Astro.redirect('/nyheder');
}

function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString('da-DK', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return ''; }
}
---

<Base locale="da" title={`${article.title} | Akademisk Boldklub`}>
  <article>
    <!-- Hero image -->
    {article.image?.url && (
      <div class="w-full overflow-hidden" style="max-height:520px">
        <img
          src={strapiMediaUrl(article.image.url)}
          alt={article.title}
          loading="eager"
          class="w-full object-cover object-top"
          style="max-height:520px"
        />
      </div>
    )}

    <div class="max-w-3xl mx-auto px-5 md:px-8 py-12 md:py-16">
      <!-- Back link -->
      <a href="/nyheder" class="inline-flex items-center gap-2 text-xs mb-8 transition-opacity hover:opacity-70" style={`color:${T.green};letter-spacing:0.08em`}>
        ← {locale === 'da' ? 'Alle nyheder' : 'All news'}
      </a>

      <!-- Categories -->
      {article.categories?.length > 0 && (
        <div class="flex gap-2 flex-wrap mb-4">
          {article.categories.map((cat: any) => (
            <span class="text-xs font-bold uppercase px-2 py-0.5" style={`color:${T.green};background:rgba(0,106,82,0.1);letter-spacing:0.1em`}>
              {cat.name}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-black text-white mb-4 leading-tight" style="font-size:clamp(1.8rem,4vw,2.8rem);letter-spacing:-0.03em">
        {article.title}
      </h1>

      {article.description && (
        <p class="text-base leading-relaxed mb-6" style={`color:${T.muted}`}>{article.description}</p>
      )}

      <div class="flex items-center gap-3 pb-8 mb-8 border-b" style={`border-color:${T.border}`}>
        <div class="h-3 w-0.5" style={`background:${T.green}`}></div>
        <time class="text-xs" style="color:rgba(138,168,152,0.6);font-variant-numeric:tabular-nums">
          {formatDate(article.publishedAt)}
        </time>
      </div>

      <!-- Article body -->
      {article.content && (
        <ArticleContent content={article.content} strapiUrl={STRAPI_URL} client:load />
      )}
    </div>
  </article>
</Base>

<style is:global>
  .prose { color: rgba(255,255,255,0.75); }
  .prose h1,.prose h2,.prose h3,.prose h4 { color: white; letter-spacing: -0.02em; }
  .prose a { color: #006A52; text-decoration: underline; text-underline-offset: 3px; }
  .prose strong { color: white; }
  .prose blockquote { border-left-color: #006A52; color: #8AA898; }
  .prose code { color: #D6A02A; background: rgba(214,160,42,0.08); padding: 0.1em 0.3em; border-radius: 2px; }
  .prose pre { background: #0D1A10; border: 1px solid #152214; }
  .prose ul > li::marker { color: #006A52; }
  .prose ol > li::marker { color: #8AA898; }
  .prose hr { border-color: #152214; }
</style>
