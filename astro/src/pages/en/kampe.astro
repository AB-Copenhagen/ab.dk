---
import Base from '@/layouts/Base.astro';
import FixturesWidget from '@/components/FixturesWidget.astro';
import StandingsWidget from '@/components/StandingsWidget.astro';
export const prerender = false;

const T = { border: '#152214', surface: '#0D1A10', gold: '#D6A02A', green: '#006A52', muted: '#8AA898' };
---

<Base locale="en" title="Fixtures | Akademisk Boldklub">
  <div class="border-b" style={`border-color:${T.border}`}>
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <div class="py-14 md:py-20">
        <p class="text-xs font-bold uppercase mb-3" style={`color:${T.gold};letter-spacing:0.2em`}>Season 2024/25</p>
        <h1 class="font-black text-white" style="font-size:clamp(3rem,8vw,5rem);letter-spacing:-0.03em;line-height:0.95">Fixtures</h1>
        <div class="mt-5 h-0.5 w-12" style={`background:${T.green}`}></div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14">
    <div class="grid lg:grid-cols-[1fr_320px] gap-8 items-start">
      <section>
        <h2 class="text-[0.6rem] font-bold uppercase mb-5" style={`color:${T.muted};letter-spacing:0.18em`}>
          Fixtures &amp; Results
        </h2>
        <div class="border" style={`background:${T.surface};border-color:${T.border}`}>
          <FixturesWidget locale="en" limit={30} />
        </div>
      </section>

      <section>
        <h2 class="text-[0.6rem] font-bold uppercase mb-5" style={`color:${T.muted};letter-spacing:0.18em`}>
          1st Division — Table
        </h2>
        <div class="border" style={`background:${T.surface};border-color:${T.border}`}>
          <StandingsWidget locale="en" />
        </div>
      </section>
    </div>
  </div>
</Base>
