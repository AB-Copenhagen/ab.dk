---
import Base from '@/layouts/Base.astro';
import ArticleSearch from '@/components/islands/ArticleSearch';
import { fetchCollectionType } from '@/lib/strapi/client';
import { strapiMediaUrl } from '@/lib/strapi/client';
import { truncate } from '@/lib/utils';
export const prerender = false;

const locale = 'en';
const T = {
  ground:  '#060806',
  surface: '#0D1A10',
  border:  '#152214',
  green:   '#006A52',
  gold:    '#C9941F',
  muted:   '#8AA898',
};

const allArticles = await fetchCollectionType<any[]>('articles', {
  locale,
  sort: ['publishedAt:desc'],
}).catch(() => [] as any[]);

const [featured, ...rest] = allArticles;

function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return ''; }
}
---

<Base locale="en" title="News | Akademisk Boldklub">
  <div class="border-b" style={`border-color:${T.border}`}>
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <div class="py-14 md:py-20">
        <p class="text-xs font-bold uppercase mb-3" style={`color:${T.gold};letter-spacing:0.2em`}>
          Akademisk Boldklub
        </p>
        <h1 class="font-black text-white" style="font-size:clamp(3rem,8vw,5rem);letter-spacing:-0.03em;line-height:0.95">
          News
        </h1>
        <div class="mt-5 h-0.5 w-12" style={`background:${T.green}`}></div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 md:px-12 pb-20" style={`background:${T.ground}`}>
    {featured && (
      <div class="pt-12 pb-4">
        <a
          href={`/en/blog/${featured.slug}`}
          class="group grid md:grid-cols-2 border overflow-hidden transition-colors hover:border-[#1F3A2C]"
          style={`border-color:${T.border}`}
        >
          <div class="relative overflow-hidden" style="min-height:320px">
            {featured.image?.url ? (
              <img
                src={strapiMediaUrl(featured.image.url)}
                alt={featured.title}
                loading="eager"
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                style="min-height:320px"
              />
            ) : (
              <div
                class="h-full w-full flex items-center justify-center font-black"
                style={`min-height:320px;background:linear-gradient(135deg,${T.surface} 0%,#091208 100%);font-size:4rem;color:rgba(0,106,82,0.18);letter-spacing:-0.04em`}
              >AB</div>
            )}
          </div>
          <div class="p-8 md:p-12 flex flex-col" style={`background:${T.surface}`}>
            {featured.categories?.[0] && (
              <p class="text-xs font-bold uppercase mb-3" style={`color:${T.green};letter-spacing:0.18em`}>
                {featured.categories[0].name}
              </p>
            )}
            <h2 class="font-black text-white mb-4 leading-tight" style="font-size:clamp(1.3rem,2.8vw,2rem);letter-spacing:-0.025em">
              {featured.title}
            </h2>
            {featured.description && (
              <p class="text-sm leading-relaxed mb-6" style={`color:${T.muted}`}>
                {truncate(featured.description, 200)}
              </p>
            )}
            <div class="mt-auto flex items-center justify-between">
              <p class="text-xs" style="color:rgba(138,168,152,0.5);font-variant-numeric:tabular-nums">
                {formatDate(featured.publishedAt)}
              </p>
              <span class="text-sm font-bold transition-transform group-hover:translate-x-1" style={`color:${T.green}`}>→</span>
            </div>
          </div>
        </a>
      </div>
    )}

    {rest.length > 0 && (
      <ArticleSearch
        articles={rest}
        locale="en"
        basePath="/en/blog/"
        client:load
      />
    )}

    {!featured && (
      <p class="text-center py-24 text-sm" style={`color:${T.muted}`}>
        No news yet.
      </p>
    )}
  </div>
</Base>
