---
import Base from '@/layouts/Base.astro';
import { fetchCollectionType, fetchSingleType, strapiMediaUrl } from '@/lib/strapi/client';

export const prerender = false;

const T = {
  ground:  '#060806',
  surface: '#0D1A10',
  border:  '#152214',
  green:   '#006A52',
  gold:    '#D6A02A',
  muted:   '#8AA898',
};

let pageData: any = null;
let products: any[] = [];

try {
  [pageData, products] = await Promise.all([
    fetchSingleType('product-page', { locale: 'da' }).catch(() => null),
    fetchCollectionType<any[]>('products', { locale: 'da' }).catch(() => []),
  ]);
} catch { /* render with empty state */ }

const featured = (products ?? []).filter((p: any) => p.featured);
const all = products ?? [];
---

<Base locale="da" title={(pageData?.seo?.title ?? 'Shop') + ' | AB 1889'}>

  {/* ── Hero ───────────────────────────────────────────────────────────── */}
  <div class="border-b" style={`border-color:${T.border}`}>
    <div class="max-w-7xl mx-auto px-5 md:px-12 pt-16 pb-10">
      <p class="text-[0.6rem] font-bold uppercase mb-2" style={`color:${T.gold};letter-spacing:0.2em`}>
        AB 1889
      </p>
      <h1
        class="font-black text-white"
        style="font-size:clamp(2.5rem,7vw,5rem);letter-spacing:-0.03em;line-height:0.92"
      >
        {pageData?.heading ?? 'Shop'}
      </h1>
      {pageData?.sub_heading && (
        <p class="mt-4 text-sm max-w-lg" style={`color:${T.muted}`}>
          {pageData.sub_heading}
        </p>
      )}
      <div class="mt-6 h-0.5 w-12" style={`background:${T.green}`}></div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 md:px-12 py-12 space-y-16">

    {/* ── Featured ───────────────────────────────────────────────────────── */}
    {featured.length > 0 && (
      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style={`color:${T.gold};letter-spacing:0.2em`}>
          Udvalgt
        </p>
        <h2
          class="font-black text-white mb-8"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          {pageData?.featured_heading ?? 'Udvalgte produkter'}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featured.map((product: any) => (
            <a
              href={`/products/${product.slug}`}
              class="group border overflow-hidden flex flex-col transition-colors"
              style={`border-color:${T.border};background:${T.surface}`}
            >
              {product.image?.url && (
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={strapiMediaUrl(product.image.url)}
                    alt={product.name ?? ''}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6 flex-1 flex flex-col justify-between">
                <div>
                  <p class="text-[0.6rem] font-bold uppercase mb-1" style={`color:${T.gold};letter-spacing:0.18em`}>
                    {product.category ?? 'Produkt'}
                  </p>
                  <h3 class="text-xl font-black text-white uppercase tracking-tight">
                    {product.name}
                  </h3>
                  {product.description && (
                    <p class="mt-2 text-sm line-clamp-2" style={`color:${T.muted}`}>
                      {product.description}
                    </p>
                  )}
                </div>
                {product.price && (
                  <p class="mt-4 text-lg font-black tabular-nums" style={`color:${T.gold}`}>
                    {product.price}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ── All products ───────────────────────────────────────────────────── */}
    {all.length > 0 && (
      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style={`color:${T.gold};letter-spacing:0.2em`}>
          Sortiment
        </p>
        <h2
          class="font-black text-white mb-8"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          {pageData?.popular_heading ?? 'Alle produkter'}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {all.map((product: any) => (
            <a
              href={`/products/${product.slug}`}
              class="group border overflow-hidden flex flex-col transition-colors hover:border-green-700"
              style={`border-color:${T.border};background:${T.surface}`}
            >
              <div class="aspect-square overflow-hidden" style={`background:${T.ground}`}>
                {product.image?.url ? (
                  <img
                    src={strapiMediaUrl(product.image.url)}
                    alt={product.name ?? ''}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="w-full h-full flex items-center justify-center font-black text-3xl"
                    style={`color:rgba(0,106,82,0.15)`}
                  >
                    AB
                  </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="text-sm font-black text-white uppercase tracking-tight truncate">
                  {product.name}
                </h3>
                {product.price && (
                  <p class="mt-1 text-sm font-bold tabular-nums" style={`color:${T.gold}`}>
                    {product.price}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ── Empty state ────────────────────────────────────────────────────── */}
    {all.length === 0 && (
      <div class="py-20 text-center" style={`color:${T.muted}`}>
        <p class="text-sm font-bold uppercase tracking-widest">Ingen produkter</p>
      </div>
    )}

  </div>
</Base>
