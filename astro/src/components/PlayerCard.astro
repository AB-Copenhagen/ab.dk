---
interface Props {
  player: {
    id?: number;
    name?: string;
    position?: string;
    role?: string;
    jerseyNumber?: number;
    number?: number;
    nationality?: string;
    stats?: { appearances?: number; goals?: number; assists?: number };
  };
  locale: 'da' | 'en';
}

const { player, locale } = Astro.props;
const number = player.jerseyNumber ?? player.number;
const position = player.position ?? player.role ?? '';
---

<div
  class="relative border transition-colors duration-200 hover:border-[#006A52] group"
  style="background:#0D1410;border-color:#1A2018"
>
  {number !== undefined && (
    <span class="absolute top-3 right-3 text-xs font-bold tabular-nums" style="color:#C9941F;opacity:0.5">
      {number}
    </span>
  )}

  <!-- Silhouette -->
  <div class="flex items-end justify-center" style="height:96px;background:linear-gradient(180deg,#081209 0%,#0D1410 100%)">
    <svg width="44" height="56" viewBox="0 0 44 56" fill="none" style="opacity:0.2">
      <circle cx="22" cy="11" r="7" fill="#7A9185" />
      <path d="M8 26C8 18 36 18 36 26L40 50H4L8 26Z" fill="#7A9185" />
    </svg>
  </div>

  <div class="px-3 pt-3 pb-4">
    <p class="text-sm font-bold text-white leading-tight truncate transition-colors group-hover:text-[#C9941F]" title={player.name}>
      {player.name ?? '—'}
    </p>

    {position && (
      <p class="text-[0.6rem] uppercase mt-1 truncate" style="color:#006A52;letter-spacing:0.12em">
        {position}
      </p>
    )}

    {player.nationality && (
      <p class="text-[0.6rem] mt-1 truncate" style="color:#7A9185">{player.nationality}</p>
    )}

    {player.stats && (
      <div class="flex gap-4 mt-3 pt-2 border-t" style="border-color:#1A2018">
        {player.stats.appearances !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase" style="color:#7A9185;letter-spacing:0.12em">
              {locale === 'da' ? 'Kam.' : 'App.'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.appearances}</p>
          </div>
        )}
        {player.stats.goals !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase" style="color:#7A9185;letter-spacing:0.12em">
              {locale === 'da' ? 'Mål' : 'Gls'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.goals}</p>
          </div>
        )}
        {player.stats.assists !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase" style="color:#7A9185;letter-spacing:0.12em">
              {locale === 'da' ? 'Ass.' : 'Ast.'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.assists}</p>
          </div>
        )}
      </div>
    )}
  </div>
</div>
