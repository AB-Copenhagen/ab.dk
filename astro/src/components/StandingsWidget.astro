---
import { fetchStandings } from '@/lib/si/client';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

let rows: any[] = [];
let error = '';

try {
  const data = await fetchStandings(locale);
  rows = data?.standings ?? data?.data ?? [];
} catch (err) {
  const msg = err instanceof Error ? err.message : '';
  error = msg.includes('AB_TOURNAMENT_ID')
    ? 'Stilling ikke tilgængelig — AB_TOURNAMENT_ID mangler'
    : locale === 'da'
    ? 'Stilling ikke tilgængelig'
    : 'Standings unavailable';
}

const headers = locale === 'da'
  ? ['#', 'Hold', 'K', 'V', 'U', 'T', 'Mål', 'Pt']
  : ['#', 'Club', 'P', 'W', 'D', 'L', 'GD', 'Pts'];
---

{error ? (
  <div class="text-xs py-4 text-center" style="color:#7A9185">{error}</div>
) : !rows.length ? (
  <div class="text-xs py-4 text-center" style="color:#7A9185">
    {locale === 'da' ? 'Ingen data' : 'No data'}
  </div>
) : (
  <div class="overflow-x-auto">
    <table class="w-full text-xs">
      <thead>
        <tr class="border-b border-[#1A2018]">
          {headers.map((h) => (
            <th class="py-2 px-2 text-left font-bold uppercase first:pl-4 last:pr-4" style="color:#7A9185;font-size:0.6rem;letter-spacing:0.12em">
              {h}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-[#1A2018]">
        {rows.map((row: any, i: number) => {
          const isAB = row.teamId === 9805 || row.team?.id === 9805;
          return (
            <tr
              class="transition-colors hover:bg-[#0D1410]"
              style={isAB ? 'background:rgba(0,106,82,0.12)' : ''}
            >
              <td class="py-2.5 pl-4 pr-2 tabular-nums" style={isAB ? 'color:#D6A02A' : 'color:#7A9185'}>
                {row.position ?? i + 1}
              </td>
              <td class="py-2.5 px-2 font-bold" style={isAB ? 'color:#D6A02A' : 'color:white'}>
                {row.teamName ?? row.team?.name ?? '—'}
                {isAB && <span class="ml-1.5 text-[0.55rem] uppercase" style="color:#006A52">▲</span>}
              </td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#7A9185">{row.played ?? '—'}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#7A9185">{row.wins ?? '—'}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#7A9185">{row.draws ?? '—'}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#7A9185">{row.losses ?? '—'}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#7A9185">{row.goalDifference ?? '—'}</td>
              <td class="py-2.5 pr-4 pl-2 font-bold tabular-nums" style={isAB ? 'color:#D6A02A' : 'color:white'}>
                {row.points ?? '—'}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
)}
