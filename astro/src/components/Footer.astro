---
interface Props {
  locale?: string;
  globalData?: any;
}

const { locale = 'da', globalData } = Astro.props;
const d = globalData;
const year = new Date().getFullYear();

const sections = [
  {
    title: locale === 'da' ? 'Klub' : 'Club',
    links: d?.internal_links as { text: string; URL: string }[] | undefined,
  },
  {
    title: 'Information',
    links: d?.policy_links as { text: string; URL: string }[] | undefined,
  },
  {
    title: locale === 'da' ? 'Følg os' : 'Follow us',
    links: d?.social_media_links as { text: string; URL: string }[] | undefined,
  },
];
---

<footer class="border-t" style="border-color:rgba(0,106,82,0.25); background:#080A08;">
  <div class="h-px w-full" style="background:#006A52;" />

  <div class="max-w-7xl mx-auto px-6 pt-16 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={locale === 'en' ? '/en' : '/'} class="font-black text-white text-2xl" style="letter-spacing:-0.04em;">AB</a>
        <p class="mt-5 text-xs leading-relaxed max-w-xs" style="color:rgba(255,255,255,0.4); line-height:1.8;">
          {d?.description ?? 'Akademisk Boldklub er en dansk fodboldklub grundlagt i 1889. Vi spiller i 1. division og har hjemmebane på Gladsaxe Stadion.'}
        </p>
      </div>

      <!-- Link columns -->
      <div class="md:col-span-3 grid grid-cols-2 sm:grid-cols-3 gap-10">
        {sections.map((section) => (
          <div>
            <p class="text-xs font-bold uppercase mb-4" style="color:rgba(255,255,255,0.25); letter-spacing:0.18em;">
              {section.title}
            </p>
            {section.links?.length ? (
              <ul class="flex flex-col gap-2.5">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.URL}
                      class="text-xs hover:text-white transition-colors"
                      style="color:rgba(255,255,255,0.45);"
                    >
                      {link.text}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-xs" style="color:rgba(255,255,255,0.2);">—</p>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t" style="border-color:rgba(255,255,255,0.06);">
      <p class="text-xs" style="color:rgba(255,255,255,0.25);">
        {d?.copyright ?? `© ${year} Akademisk Boldklub. Alle rettigheder forbeholdes.`}
      </p>
      <p class="text-xs" style="color:rgba(255,255,255,0.15); letter-spacing:0.06em;">AB · EST. 1889</p>
    </div>
  </div>
</footer>
