---
import { fetchABEvents } from '@/lib/si/client';

interface Props {
  locale: 'da' | 'en';
  limit?: number;
}

const { locale, limit = 20 } = Astro.props;

let events: any[] = [];
let error = '';

try {
  events = await fetchABEvents({ locale, limit });
} catch {
  error = locale === 'da' ? 'Kampprogram ikke tilgængeligt' : 'Fixtures unavailable';
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString(
    locale === 'da' ? 'da-DK' : 'en-GB',
    { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }
  );
}
---

{error ? (
  <div class="text-xs py-4 text-center" style="color:#7A9185">{error}</div>
) : !events.length ? (
  <div class="text-xs py-4 text-center" style="color:#7A9185">
    {locale === 'da' ? 'Ingen kampe fundet' : 'No fixtures found'}
  </div>
) : (
  <div class="divide-y divide-[#1A2018]">
    {events.slice(0, limit).map((event: any) => {
      const isABHome = event.homeId === 9805;
      const opponent = isABHome ? event.awayName : event.homeName;
      const isFinished = event.statusType === 'finished';
      const isLive = event.statusType === 'inprogress';
      return (
        <div class="flex items-center justify-between py-3 px-4 gap-4 hover:bg-[#0D1410] transition-colors">
          <div class="min-w-[130px]">
            <span class="text-xs" style="color:#7A9185">{formatDate(event.startDate)}</span>
          </div>

          <div class="flex-1 flex items-center gap-2 min-w-0">
            <span class="text-xs font-bold uppercase text-white truncate" style="letter-spacing:0.04em">
              {isABHome ? 'AB' : opponent}
            </span>
            {(isFinished || isLive) && event.score ? (
              <span
                class="text-sm font-bold tabular-nums px-2 py-0.5"
                style={isLive
                  ? 'color:#00FF1F;background:rgba(0,255,31,0.08)'
                  : 'color:#C9941F;background:rgba(201,148,31,0.08)'}
              >{event.score}</span>
            ) : (
              <span class="text-xs" style="color:#7A9185">vs</span>
            )}
            <span class="text-xs font-bold uppercase text-white truncate" style="letter-spacing:0.04em">
              {isABHome ? opponent : 'AB'}
            </span>
          </div>

          <div class="min-w-[40px] text-right">
            {isLive && (
              <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase" style="color:#00FF1F;letter-spacing:0.1em">
                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                LIVE
              </span>
            )}
            {isFinished && (
              <span class="text-xs uppercase" style="color:#7A9185;letter-spacing:0.1em">FT</span>
            )}
          </div>
        </div>
      );
    })}
  </div>
)}
