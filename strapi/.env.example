HOST=0.0.0.0
PORT=1337
APP_KEYS="tobemodified1,tobemodified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

CLIENT_URL=http://localhost:3000
PREVIEW_SECRET=preview_secret # optional, required with Next.js draft mode

# ── SportsInnovation API ──────────────────────────────
# Required if Strapi webhooks or custom plugins call the SI API directly.
# The Next.js layer also needs this in next/.env.local
SI_ACCESS_TOKEN=tobemodified

# ── DeepL auto-translation ────────────────────────────
DEEPL_API_KEY=tobemodified
# Set to false if on a paid DeepL plan (uses api.deepl.com instead of api-free.deepl.com)
DEEPL_API_FREE=true