HOST=0.0.0.0
PORT=1337
APP_KEYS="tobemodified1,tobemodified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

CLIENT_URL=http://localhost:3000
PREVIEW_SECRET=preview_secret # optional, required with Next.js draft mode

# ── SportsInnovation API ──────────────────────────────
# Required if Strapi webhooks or custom plugins call the SI API directly.
# The Next.js layer also needs this in next/.env.local
SI_ACCESS_TOKEN=tobemodified

# ── Mailgun email ─────────────────────────────────────
MAILGUN_API_KEY=tobemodified
MAILGUN_DOMAIN=mg.ab.dk
# EU accounts: https://api.eu.mailgun.net — omit for US
MAILGUN_HOST=https://api.eu.mailgun.net
MAILGUN_FROM=noreply@ab.dk
MAILGUN_REPLY_TO=kontakt@ab.dk

# ── DeepL auto-translation ────────────────────────────
DEEPL_API_KEY=tobemodified
# Set to false if on a paid DeepL plan (uses api.deepl.com instead of api-free.deepl.com)
DEEPL_API_FREE=true

# ── Wasabi object storage ─────────────────────────────
# Create bucket at https://console.wasabisys.com
# IAM: create a user with s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket
WASABI_ACCESS_KEY_ID=tobemodified
WASABI_SECRET_ACCESS_KEY=tobemodified
WASABI_BUCKET=ab-media
# Wasabi regions: us-east-1, eu-central-1, eu-west-1, ap-northeast-1, etc.
WASABI_REGION=eu-central-1
WASABI_ENDPOINT=https://s3.eu-central-1.wasabisys.com
# Presigned URL expiry in seconds (default 604800 = 7 days)
WASABI_SIGNED_URL_EXPIRES=604800