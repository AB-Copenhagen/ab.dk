---
import Base from '@/layouts/Base.astro';
import SquadCard from '@/components/SquadCard.astro';
import { fetchABPlayers, type SIPlayer } from '@/lib/si/client';
import { COACHING_STAFF, staffInitials } from '@/data/coaching-staff';
export const prerender = false;

const locale = 'da' as const;

const POSITION_GROUPS = {
  keeper: 'Målmænd',
  defender: 'Forsvarsspillere',
  midfielder: 'Midtbanespillere',
  forward: 'Angribere',
} as const;
type PositionKey = keyof typeof POSITION_GROUPS;
const GROUP_ORDER: PositionKey[] = [
  'keeper',
  'defender',
  'midfielder',
  'forward',
];


let players: SIPlayer[] = [];
try {
  players = await fetchABPlayers(locale);
} catch {
  /* SI unavailable */
}

players.sort((a, b) => {
  const ai = GROUP_ORDER.indexOf(a.position as PositionKey);
  const bi = GROUP_ORDER.indexOf(b.position as PositionKey);
  if (ai !== bi) return ai - bi;
  return (a.shirtNumber ?? 99) - (b.shirtNumber ?? 99);
});

const groups = new Map<PositionKey, SIPlayer[]>();
for (const p of players) {
  const key = p.position as PositionKey;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(p);
}
---

<Base
  locale="da"
  title="Holdet | Akademisk Boldklub">
  <div style="background:#fff">
    <!-- Squad banner (image with embedded title) -->
    <div class="w-full">
      <img
        src="/images/squad-banner.png"
        alt="AB 1889 Holdet"
        class="w-full h-auto block"
        loading="eager"
      />
    </div>

    <div class="max-w-[1680px] mx-auto px-5 md:px-10 py-10 lg:py-14">
      {
        players.length === 0 ? (
          <p
            class="text-center py-24 text-sm"
            style="color:#9CA3AF">
            Holdoplysninger er ikke tilgængelige i øjeblikket.
          </p>
        ) : (
          GROUP_ORDER.map((key) => {
            const group = groups.get(key);
            if (!group?.length) return null;
            return (
              <section class="mb-14">
                <h2
                  class="font-black mb-6"
                  style="font-size:clamp(1.5rem,3vw,2.5rem); letter-spacing:-0.03em; color:#111; text-transform:none;">
                  {POSITION_GROUPS[key]}
                </h2>
                <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-3 md:gap-x-7">
                  {group.map((player) => (
                    <SquadCard
                      player={player}
                      locale="da"
                    />
                  ))}
                </div>
              </section>
            );
          })
        )
      }
      <!-- Coaching Staff -->
      <section class="mb-14">
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.5rem); letter-spacing:-0.03em; color:#111; text-transform:none;">
          Trænerstab
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-3 md:gap-x-7">
          {COACHING_STAFF.map((staff) => {
            const parts = staff.name.trim().split(' ');
            const firstName = parts[0];
            const lastName = parts.slice(1).join(' ');
            const initials = staffInitials(staff.name);
            return (
              <a href={`/stab/${staff.slug}`} class="relative block group" style="aspect-ratio:593/503;">
                <div class="absolute inset-x-0 bottom-0 transition-all duration-300 group-hover:brightness-95" style="height:84.1%; background:#EBEBEB;"></div>
                <div class="absolute top-0 bottom-0 right-0 overflow-hidden rounded-r-xl" style="width:51%;">
                  <img src={staff.photo} alt={staff.name} loading="lazy"
                       class="absolute inset-0 w-full h-full object-cover object-top"
                       onerror="this.style.opacity='0'" />
                </div>
                <div class="absolute inset-x-0 bottom-0 flex flex-col justify-between p-4 md:p-5 z-10"
                     style="height:84.1%; width:53%;">
                  <div>
                    <p class="font-black leading-tight"
                       style="font-size:clamp(0.95rem,2.1vw,1.75rem); letter-spacing:-0.025em; text-wrap:balance; color:#006A52;">
                      {firstName}<br />{lastName}
                    </p>
                    <p class="text-xs mt-1 font-medium" style="color:rgba(0,106,82,0.6);">{staff.role.da}</p>
                  </div>
                  <p class="font-black leading-none select-none"
                     style="font-size:clamp(2.5rem,6.5vw,6.5rem); letter-spacing:-0.04em; color:rgba(0,106,82,0.18);">
                    {initials}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</Base>
