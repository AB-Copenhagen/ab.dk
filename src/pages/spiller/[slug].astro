---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import { fetchPlayerProfile, fetchABPlayers } from '@/lib/si/client';
import type { SIPlayerProfile } from '@/lib/si/client';
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

export const prerender = false;

// Slug format: {playerId}-{name}  e.g. "987654-mikkel-hansen"
const { slug } = Astro.params;
const playerId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(playerId)) {
  return Astro.redirect('/hold');
}

let player: SIPlayerProfile | null = null;

try {
  player = await fetchPlayerProfile(playerId, 'da');
} catch {
  // fall through to redirect
}

if (!player) {
  return Astro.redirect('/hold');
}

const { name, position, countryName, birthDate, height } = player;

// Get jersey number from the squad list
const squadPlayers = await fetchABPlayers('da').catch(() => []);
const squadPlayer = squadPlayers.find(p => p.id === playerId);
const shirtNumber = squadPlayer?.shirtNumber;

const photoUrl = getPlayerPhotoUrl(name);

const posLabels: Record<string, string> = {
  keeper:     'Målmand',
  defender:   'Forsvarer',
  midfielder: 'Midtbane',
  forward:    'Angriber',
};
const posLabel = posLabels[position?.toLowerCase() ?? ''] ?? position;

const pageTitle = `${name} | Akademisk Boldklub`;

const dob = birthDate
  ? new Date(birthDate).toLocaleDateString('da-DK', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const WIDGET_TEAM_ID = 10202;
const WIDGET_SEASON_ID = 16387;
---

<Base locale="da" title={pageTitle}>
  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <div class="w-full overflow-hidden flex" style="background:#006A52; min-height:clamp(460px,36vw,560px);">

    <!-- Left: name / position / number -->
    <div class="flex-none flex flex-col justify-center relative z-20"
         style="width:clamp(260px,38vw,500px); padding:3.5rem max(1.5rem,5vw) 3.5rem max(1.5rem,8vw);">
      <a href="/hold"
         class="inline-flex items-center gap-1 text-xs font-bold uppercase mb-8 hover:opacity-100 transition-opacity"
         style="color:rgba(255,255,255,0.6); letter-spacing:0.16em;">
        ← Holdet
      </a>
      <p class="font-bold uppercase mb-3" style="font-size:0.6rem; color:rgba(255,255,255,0.45); letter-spacing:0.24em;">
        Akademisk Boldklub 1889
      </p>
      <h1 class="font-black text-white leading-none mb-3"
          style="font-size:clamp(2rem,4.5vw,4.5rem); letter-spacing:-0.04em;">
        {name}
      </h1>
      <p class="text-white mb-10" style="font-size:clamp(1rem,1.4vw,1.25rem); opacity:0.7;">
        {posLabel}
      </p>
      {shirtNumber != null && (
        <p class="font-black text-white leading-none select-none"
           style="font-size:clamp(5rem,10.5vw,11rem); letter-spacing:-0.05em; opacity:0.85;">
          {shirtNumber}
        </p>
      )}
    </div>

    <!-- Center: player photo -->
    <div class="flex-1 relative overflow-hidden" style="min-width:0;">
      {photoUrl && (
        <>
          <img
            src={photoUrl}
            alt={name}
            loading="eager"
            class="absolute bottom-0 h-full w-auto max-w-none"
            style="left:50%; transform:translateX(-50%);"
          />
          <div class="absolute inset-0 pointer-events-none"
               style="background:linear-gradient(to right, #006A52 0%, transparent 25%);"></div>
          <div class="absolute inset-0 pointer-events-none"
               style="background:linear-gradient(to left, #006A52 0%, transparent 25%);"></div>
        </>
      )}
    </div>

    <!-- Right: AB crest badge watermark (desktop only) -->
    <div class="hidden lg:flex flex-none items-center justify-center"
         style="width:clamp(200px,30vw,400px); padding:2.5rem max(2rem,5vw) 2.5rem 0;">
      <img
        src="/images/ab-crest.svg"
        alt=""
        aria-hidden="true"
        style="width:100%; max-width:360px; opacity:0.12; filter:brightness(0) invert(1);"
      />
    </div>

  </div>

  <!-- ── Metadata bar ───────────────────────────────────────────────── -->
  <div style="background:#fff; border-top:1px solid #E5E7EB; border-bottom:1px solid #E5E7EB;">
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <div class="flex overflow-x-auto divide-x divide-gray-200">
        <div class="py-5 pr-8 flex-none text-center">
          <p class="mb-1.5 uppercase" style="font-size:0.7rem; color:#6B7280; letter-spacing:0.14em;">Position</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{posLabel}</p>
        </div>
        {countryName && (
          <div class="py-5 px-8 flex-none text-center">
            <p class="mb-1.5 uppercase" style="font-size:0.7rem; color:#6B7280; letter-spacing:0.14em;">Nationalitet</p>
            <p class="font-black" style="font-size:0.9rem; color:#111;">{countryName}</p>
          </div>
        )}
        {height && (
          <div class="py-5 px-8 flex-none text-center">
            <p class="mb-1.5 uppercase" style="font-size:0.7rem; color:#6B7280; letter-spacing:0.14em;">Højde</p>
            <p class="font-black" style="font-size:0.9rem; color:#111;">{height} cm</p>
          </div>
        )}
        {dob && (
          <div class="py-5 px-8 flex-none text-center">
            <p class="mb-1.5 uppercase" style="font-size:0.7rem; color:#6B7280; letter-spacing:0.14em;">Fødselsdato</p>
            <p class="font-black" style="font-size:0.9rem; color:#111;">{dob}</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ── Widgets ────────────────────────────────────────────────────── -->
  <div style="background:#fff;">

    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14 space-y-14">

      <section>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerProfile"
            params={{ playerId, card: 'true', showTShirt: 'true', teamId: WIDGET_TEAM_ID }}
            minHeight={360}
            label={`${name} — profil`}
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Sæsonstatistik
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Sæsonen
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerSeasonStats"
            params={{ playerId, card: 'true', nopadding: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID }}
            minHeight={280}
            label="Sæsonstatistik oversigt"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Detaljeret
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Statistik
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerStatsGrid"
            params={{ playerId, nopadding: 'false', transparent: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID }}
            minHeight={400}
            label="Statistik grid"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Video
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Mål i sæsonen
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKGoalsHighlights"
            params={{
              type: 'VIDEO_BY_PLAYER',
              viewList: 'VIEW_SLIDER',
              viewCard: 'PLAYER_MIN_MATCH_INFO',
              playerId,
              seasonId: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
            }}
            minHeight={300}
            label="Mål highlights"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Sammenligning
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Radar
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="PlayerH2HSeasonRadarStatsOPTA"
            params={{
              playerId1: playerId,
              seasonId1: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
            }}
            minHeight={480}
            label="Radar sammenligning"
          />
        </div>
      </section>

    </div>
  </div>
</Base>
