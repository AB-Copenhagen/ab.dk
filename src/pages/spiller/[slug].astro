---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import { fetchPlayerProfile, fetchABPlayers } from '@/lib/si/client';
import type { SIPlayerProfile } from '@/lib/si/client';
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

export const prerender = false;

// Slug format: {playerId}-{name}  e.g. "987654-mikkel-hansen"
const { slug } = Astro.params;
const playerId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(playerId)) {
  return Astro.redirect('/hold');
}

let player: SIPlayerProfile | null = null;

try {
  player = await fetchPlayerProfile(playerId, 'da');
} catch {
  // fall through to redirect
}

if (!player) {
  return Astro.redirect('/hold');
}

const { name, position, countryName, birthDate } = player;

// Get jersey number from the squad list
const squadPlayers = await fetchABPlayers('da').catch(() => []);
const squadPlayer = squadPlayers.find(p => p.id === playerId);
const shirtNumber = squadPlayer?.shirtNumber;

const photoUrl = getPlayerPhotoUrl(name);

const posLabels: Record<string, string> = {
  keeper:     'Målmand',
  defender:   'Forsvarer',
  midfielder: 'Midtbane',
  forward:    'Angriber',
};
const posLabel = posLabels[position?.toLowerCase() ?? ''] ?? position;

const pageTitle = `${name} | Akademisk Boldklub`;

const dob = birthDate
  ? new Date(birthDate).toLocaleDateString('da-DK', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const WIDGET_TEAM_ID = 10202;
const WIDGET_SEASON_ID = 16387;
---

<Base locale="da" title={pageTitle}>
  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <div class="relative overflow-hidden" style="background:#006A52; min-height:clamp(360px,42vw,520px);">
    <!-- "AB" watermark -->
    <div class="absolute right-0 inset-y-0 flex items-center justify-end pr-8 pointer-events-none select-none overflow-hidden" aria-hidden="true">
      <span class="font-black text-white opacity-[0.06]" style="font-size:clamp(16rem,34vw,26rem); letter-spacing:-0.06em; line-height:1;">AB</span>
    </div>

    <!-- Player photo (right side, overflowing) -->
    {photoUrl && (
      <div class="absolute right-0 bottom-0 overflow-hidden" style="width:clamp(220px,38vw,480px); height:110%;">
        <img
          src={photoUrl}
          alt={name}
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover object-top"
        />
        <div class="absolute inset-0" style="background:linear-gradient(to right, #006A52 0%, transparent 35%);"></div>
      </div>
    )}

    <!-- Text -->
    <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-12 py-14 md:py-20">
      <a href="/hold" class="inline-flex items-center gap-1 text-xs font-bold uppercase mb-8 opacity-70 hover:opacity-100 transition-opacity" style="color:#fff; letter-spacing:0.16em;">
        ← Holdet
      </a>
      <p class="font-bold uppercase mb-3" style="font-size:0.6rem; color:rgba(255,255,255,0.55); letter-spacing:0.24em;">
        Akademisk Boldklub 1889
      </p>
      <h1 class="font-black text-white leading-none mb-3" style="font-size:clamp(2.2rem,6vw,5.5rem); letter-spacing:-0.04em;">
        {name}
      </h1>
      <p class="font-medium text-base" style="color:rgba(255,255,255,0.65);">{posLabel}</p>
      {shirtNumber != null && (
        <p class="font-black text-white leading-none mt-8 select-none" style="font-size:clamp(4rem,10vw,8rem); letter-spacing:-0.05em; opacity:0.9;">
          {shirtNumber}
        </p>
      )}
    </div>
  </div>

  <!-- ── Metadata strip ─────────────────────────────────────────────── -->
  <div style="background:#fff; border-bottom:1px solid #E5E7EB;">
    <div class="max-w-7xl mx-auto px-5 md:px-12">
      <div class="flex flex-wrap divide-x" style="divide-color:#E5E7EB;">
        <div class="py-5 pr-8">
          <p class="text-xs font-bold uppercase mb-1" style="color:#9CA3AF; letter-spacing:0.14em;">Position</p>
          <p class="font-black text-sm" style="color:#111;">{posLabel}</p>
        </div>
        {countryName && (
          <div class="py-5 px-8">
            <p class="text-xs font-bold uppercase mb-1" style="color:#9CA3AF; letter-spacing:0.14em;">Nationalitet</p>
            <p class="font-black text-sm" style="color:#111;">{countryName}</p>
          </div>
        )}
        {dob && (
          <div class="py-5 px-8">
            <p class="text-xs font-bold uppercase mb-1" style="color:#9CA3AF; letter-spacing:0.14em;">Fødselsdato</p>
            <p class="font-black text-sm" style="color:#111;">{dob}</p>
          </div>
        )}
        {shirtNumber != null && (
          <div class="py-5 pl-8">
            <p class="text-xs font-bold uppercase mb-1" style="color:#9CA3AF; letter-spacing:0.14em;">Trøjenummer</p>
            <p class="font-black text-sm" style="color:#111;">#{shirtNumber}</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ── Widgets ────────────────────────────────────────────────────── -->
  <div style="background:#fff;">

    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14 space-y-14">

      <section>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerProfile"
            params={{ playerId, card: 'true', showTShirt: 'true', teamId: WIDGET_TEAM_ID }}
            minHeight={360}
            label={`${name} — profil`}
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Sæsonstatistik
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Sæsonen
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerSeasonStats"
            params={{ playerId, card: 'true', nopadding: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID }}
            minHeight={280}
            label="Sæsonstatistik oversigt"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Detaljeret
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Statistik
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerStatsGrid"
            params={{ playerId, nopadding: 'false', transparent: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID }}
            minHeight={400}
            label="Statistik grid"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Video
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Mål i sæsonen
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKGoalsHighlights"
            params={{
              type: 'VIDEO_BY_PLAYER',
              viewList: 'VIEW_SLIDER',
              viewCard: 'PLAYER_MIN_MATCH_INFO',
              playerId,
              seasonId: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
            }}
            minHeight={300}
            label="Mål highlights"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Sammenligning
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Radar
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="PlayerH2HSeasonRadarStatsOPTA"
            params={{
              playerId1: playerId,
              seasonId1: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
            }}
            minHeight={480}
            label="Radar sammenligning"
          />
        </div>
      </section>

    </div>
  </div>
</Base>
