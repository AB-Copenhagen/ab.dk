---
import Base from '@/layouts/Base.astro';
import heroImage from '@/assets/images/IMG_7926.jpeg';

export const prerender = true;

const mainSponsors = [
  {
    name: 'Myriad360',
    src: '/images/sponsors/myriad360.png',
    href: 'https://myriad360.com/',
    sz: 'w-[230px] h-[78px]',
  },
  {
    name: 'Plane',
    src: '/images/sponsors/plane.png',
    href: 'https://plane.so/',
    sz: 'w-[200px] h-[65px]',
  },
  {
    name: 'Datum',
    src: '/images/sponsors/datum.png',
    href: 'https://datum.net/',
    sz: 'w-[300px] h-[100px]',
  },
  {
    name: 'Select',
    src: '/images/sponsors/select-sport.png',
    href: 'https://dk.select-sport.com/',
    sz: 'w-[200px] h-[65px]',
  },
  {
    name: 'Carlsberg',
    src: '/images/sponsors/carlsberg.png',
    href: 'https://carlsbergdanmark.dk/',
    sz: 'w-[262px] h-[88px]',
  },
];

const partners = [
  { name: 'T4C A/S', src: '/images/sponsors/partners/t4c.jpg' },
  { name: 'K/S Jydekrogen', src: '/images/sponsors/partners/ks-jydekrogen.png' },
  { name: 'Fodeksperterne', src: '/images/sponsors/partners/fodeksperterne.png' },
  {
    name: 'Weibel Data og overvågning',
    src: '/images/sponsors/partners/weibel-data.png',
  },
  { name: 'Unisport', src: '/images/sponsors/partners/unisport.png' },
  { name: 'Lomax', src: '/images/sponsors/partners/lomax.jpeg' },
  { name: 'Waseen', src: '/images/sponsors/partners/waseen.jpeg' },
  { name: 'Steaking', src: '/images/sponsors/partners/steaking.jpg' },
  {
    name: 'Kasper Svenstrup Media',
    src: '/images/sponsors/partners/kasper-svenstrup-media.png',
  },
  { name: 'Poul Holm Sport', src: '/images/sponsors/partners/poul-holm-sport.gif' },
  { name: 'Lind Advokater', src: '/images/sponsors/partners/lind-advokater.png' },
  { name: 'Laudrup Vin', src: '/images/sponsors/partners/laudrup-vin.png' },
  { name: 'Symbion', src: '/images/sponsors/partners/symbion.png' },
  { name: 'Pure Shots', src: '/images/sponsors/partners/pure-shots.png' },
  { name: 'Baker Tilly', src: '/images/sponsors/partners/baker-tilly.png' },
  {
    name: 'Virum Torv Advokater',
    src: '/images/sponsors/partners/virum-torv-advokater.svg',
  },
  { name: 'SoccerZoom', src: '/images/sponsors/partners/soccerzoom.png' },
  { name: 'Apo Pharm', src: '/images/sponsors/partners/apo-pharm.png' },
  { name: 'Plus Leasing', src: '/images/sponsors/partners/plus-leasing.png' },
  { name: 'Dancontainer', src: '/images/sponsors/partners/dancontainer.jpg' },
  { name: 'Søpromenaden', src: '/images/sponsors/partners/soepromenaden.webp' },
  { name: 'View2net', src: '/images/sponsors/partners/view2net.png' },
  { name: 'Buffetkompagniet', src: '/images/sponsors/partners/buffetkompagniet.png' },
  { name: 'Weibel El-teknik', src: '/images/sponsors/partners/weibel-el-teknik.png' },
  { name: 'Meny Kaffe', src: '/images/sponsors/partners/meny-kaffe.png' },
  {
    name: 'Nordsjælland Sportsfysioterapi',
    src: '/images/sponsors/partners/nordsjaelland-sportsfysioterapi.png',
  },
  { name: 'Meny Søborg', src: '/images/sponsors/partners/meny-soeborg.png' },
  {
    name: 'Capio Privathospital',
    src: '/images/sponsors/partners/capio-privathospital.png',
  },
  {
    name: 'Bella - Skilte & Print',
    src: '/images/sponsors/partners/bella-skilte-print.png',
  },
  { name: 'Ejendomsfoto', src: '/images/sponsors/partners/ejendomsfoto.png' },
];
---

<Base
  locale="da"
  title="Sponsorer | AB 1889"
  description="Mød de virksomheder og partnere, der støtter Akademisk Boldklub — fra hovedsponsorer til AB Partner-netværket.">
  <!-- Hero -->
  <div class="relative overflow-hidden h-[clamp(260px,36vw,420px)]">
    <img
      src={heroImage.src}
      alt="Sponsorskilte på Gladsaxe Stadion"
      width={heroImage.width}
      height={heroImage.height}
      class="absolute inset-0 w-full h-full object-cover object-center brightness-[0.5] saturate-[0.6]"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.55)_0%,rgba(0,0,0,0.1)_70%)]">
    </div>
    <div
      class="relative h-full flex flex-col justify-end px-8 lg:px-16 pb-12 max-w-7xl mx-auto w-full">
      <h1
        class="font-black text-white text-[clamp(3rem,9vw,7rem)] tracking-[-0.04em] leading-[0.9]">
        Sponsorer
      </h1>
    </div>
  </div>

  <!-- Intro -->
  <div class="w-full bg-ab-black px-8 lg:px-20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto">
      <p class="text-surface-muted text-[1.0625rem] leading-[1.7] max-w-[56ch]">
        AB 1889 er stolte af at samarbejde med en bred vifte af virksomheder,
        der støtter klubben — fra hovedsponsorer til lokale AB Partner-brands.
        Sammen gør de det muligt at udvikle talentet, faciliteterne og
        fællesskabet omkring Akademisk Boldklub.
      </p>
    </div>
  </div>

  <!-- Main sponsors -->
  <section class="bg-white py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div
        class="inline-flex items-center mb-6 bg-ab-beige rounded-full py-[7px] px-[18px]">
        <span
          class="font-black text-[0.75rem] text-[#111] tracking-[0.1em] uppercase"
          >Hovedsponsor</span
        >
      </div>
      <h2
        class="font-black text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] text-ab-black mb-4">
        Vores hovedsponsorer
      </h2>
      <p class="text-[#444] text-[1.0625rem] leading-[1.75] max-w-[60ch] mb-14">
        Disse virksomheder er tættest knyttet til AB 1889 og bidrager
        direkte til klubbens sportslige og kommercielle udvikling.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
        {
          mainSponsors.map(({ name, src, href, sz }) => (
            <a
              href={href}
              target="_blank"
              rel="noreferrer"
              aria-label={name}
              class="flex items-center justify-center border border-gray-100 rounded-lg py-12 px-8 hover:border-ab-green/40 transition-colors">
              <img
                src={src}
                alt={name}
                class:list={['object-contain object-center', sz]}
              />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- AB Partner -->
  <section class="bg-surface-base py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div
        class="inline-flex items-center mb-6 border border-ab-green/40 rounded-full py-[7px] px-[18px]">
        <span
          class="font-black text-[0.75rem] text-surface-muted tracking-[0.1em] uppercase"
          >AB Partner</span
        >
      </div>
      <h2
        class="font-black text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] text-white mb-4">
        AB Partner-netværket
      </h2>
      <p class="text-surface-muted text-[1.0625rem] leading-[1.75] max-w-[60ch] mb-14">
        Et stærkt netværk af lokale og landsdækkende virksomheder, der
        støtter AB 1889 år efter år — inden for alt fra sport og sundhed til
        rådgivning og gastronomi.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {
          partners.map(({ name, src }) => (
            <div class="flex items-center justify-center bg-white rounded-lg h-36 px-6 py-6 border border-surface-border hover:border-ab-green/50 transition-colors">
              <img
                src={src}
                alt={name}
                title={name}
                class="max-h-24 max-w-full object-contain"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
