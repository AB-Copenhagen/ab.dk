---
import Base from '@/layouts/Base.astro';

export const prerender = true;

const departments = [
  { label: 'General enquiries', email: 'info@ab.dk' },
  { label: 'Club operations', email: 'creinhardt@ab.dk' },
  { label: 'Accounting', email: 'regnskab@ab.dk' },
  { label: 'Partnerships', email: 'partners@ab.dk' },
];
---

<Base locale="en" title="Contact | AB 1889">

  <!-- Hero -->
  <div class="bg-ab-black py-16 px-8 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <span class="inline-block font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-neon mb-5">AB 1889</span>
      <h1 class="font-black text-white leading-none text-[clamp(3.5rem,9vw,7rem)] tracking-[-0.04em]">Contact</h1>
    </div>
  </div>

  <!-- Main contact -->
  <section class="bg-white py-[clamp(56px,8vw,96px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- Left: Primary contact -->
        <div>
          <div class="inline-flex items-center mb-8 bg-ab-beige rounded-full py-[7px] px-[18px]">
            <span class="font-black text-[0.75rem] text-[#111] tracking-[0.1em] uppercase">Get in touch</span>
          </div>
          <div class="flex flex-col gap-5">
            <a href="mailto:info@ab.dk" class="flex items-center gap-4 group no-underline">
              <div class="w-10 h-10 rounded-full bg-ab-green flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999] mb-0.5">Email</p>
                <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em] group-hover:text-ab-green transition-colors">info@ab.dk</p>
              </div>
            </a>

            <a href="tel:+4560399901" class="flex items-center gap-4 group no-underline">
              <div class="w-10 h-10 rounded-full bg-ab-green flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.5 2 2 0 0 1 3.6 1.5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999] mb-0.5">Phone</p>
                <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em] group-hover:text-ab-green transition-colors">+45 60399901</p>
              </div>
            </a>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-ab-green flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999] mb-0.5">Address</p>
                <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em] leading-snug">Gladsaxevej 202<br>2860 Søborg, Denmark</p>
                <a
                  href="https://maps.google.com/?q=Gladsaxevej+202,+2860+Søborg"
                  target="_blank"
                  rel="noreferrer"
                  class="inline-block mt-2 text-[0.72rem] font-black text-ab-green no-underline hover:opacity-70 tracking-[-0.01em]"
                >
                  Open in Google Maps →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Departments -->
        <div>
          <div class="inline-flex items-center mb-8 bg-ab-beige rounded-full py-[7px] px-[18px]">
            <span class="font-black text-[0.75rem] text-[#111] tracking-[0.1em] uppercase">Departments</span>
          </div>
          <div class="flex flex-col gap-3">
            {departments.map(({ label, email }) => (
              <div class="border border-[#E5E7EB] py-4 px-5 flex items-center justify-between gap-4">
                <p class="font-black text-[0.9rem] text-[#111] tracking-[-0.02em]">{label}</p>
                <a href={`mailto:${email}`} class="text-[0.82rem] text-ab-green font-medium tracking-[-0.01em] no-underline hover:opacity-70 shrink-0">{email}</a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other contacts -->
  <section class="bg-[#F2F2F0] py-[clamp(40px,6vw,64px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid sm:grid-cols-2 gap-6">
        <!-- Mother club -->
        <div class="bg-white border border-[#E5E7EB] p-6">
          <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-green mb-4">Mother Club</p>
          <p class="font-black text-[1.1rem] text-[#111] tracking-[-0.03em] mb-3">AB Gladsaxe</p>
          <div class="flex flex-col gap-1.5 text-[0.88rem] text-[#555]">
            <p>Skovdiget 1, 2880 Bagsværd</p>
            <a href="mailto:info@abgladsaxe.dk" class="text-ab-green no-underline hover:opacity-70">info@abgladsaxe.dk</a>
          </div>
        </div>

        <!-- AB Forever -->
        <div class="bg-white border border-[#E5E7EB] p-6">
          <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-green mb-4">AB Forever — Stadium Venue</p>
          <p class="font-black text-[1.1rem] text-[#111] tracking-[-0.03em] mb-3">Chairman: Kasper V. Petersen</p>
          <div class="flex flex-col gap-1.5 text-[0.88rem] text-[#555]">
            <p>Gladsaxevej 200, 2860 Søborg</p>
            <a href="mailto:formand@abforever.dk" class="text-ab-green no-underline hover:opacity-70">formand@abforever.dk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
