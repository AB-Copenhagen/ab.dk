---
import Base from '@/layouts/Base.astro';
import PlayerHeroContent from '@/components/player/PlayerHeroContent.astro';
import PlayerMetadataBar from '@/components/player/PlayerMetadataBar.astro';
import PlayerSeasonStatsTable from '@/components/player/PlayerSeasonStatsTable.astro';
import { fetchPlayerProfile, fetchABPlayers, fetchPlayerStats, aggregateSeasonStats } from '@/lib/si/client';
import type { SIPlayerProfile } from '@/lib/si/client';
import { fetchPlayerCmsData, strapiMediaUrl } from '@/lib/strapi/client';
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

export const prerender = false;

const { slug } = Astro.params;
const playerId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(playerId)) {
  return Astro.redirect('/en/squad');
}

let player: SIPlayerProfile | null = null;

try {
  player = await fetchPlayerProfile(playerId, 'en');
} catch {
  // fall through to redirect
}

if (!player) {
  return Astro.redirect('/en/squad');
}

const { name, position, countryName, birthDate, height } = player;

// Fetch in parallel: jersey number, season stats, CMS content
const [squadPlayers, matchStats, cmsPlayer] = await Promise.all([
  fetchABPlayers('en').catch(() => []),
  fetchPlayerStats(playerId).catch(() => []),
  fetchPlayerCmsData(playerId, 'en').catch(() => null),
]);

const shirtNumber = squadPlayers.find(p => p.id === playerId)?.shirtNumber;
const photoUrl = getPlayerPhotoUrl(name);
const seasonStats = aggregateSeasonStats(matchStats);

const posLabels: Record<string, string> = {
  keeper:     'Goalkeeper',
  defender:   'Defender',
  midfielder: 'Midfielder',
  forward:    'Forward',
};
const posLabel = posLabels[position?.toLowerCase() ?? ''] ?? position;

const pageTitle = `${name} | Akademisk Boldklub`;

const dob = birthDate
  ? new Date(birthDate).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

// Gallery images with absolute URLs
const galleryImages = (cmsPlayer?.gallery ?? []).map(img => ({
  ...img,
  src: strapiMediaUrl(img.url),
}));
---

<Base locale="en" title={pageTitle}>
  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <div class="relative w-full overflow-hidden"
       style="background:linear-gradient(to right, #002A1A 0%, #006A52 42%, #00C018 100%); min-height:clamp(460px,36vw,560px);">

    <!-- AB 1889 logo watermark behind photo -->
    <img src="/images/logo-behind-player.svg" alt="" aria-hidden="true"
         class="absolute hidden md:block pointer-events-none select-none"
         style="left:40%; top:50%; transform:translate(-50%,-50%); z-index:1;
                width:clamp(320px,33vw,580px); height:auto; opacity:1;" />

    <!-- Circular crest — right side, visible against bright green -->
    <img src="/images/crest-behind-player.svg" alt="" aria-hidden="true"
         class="absolute hidden lg:block pointer-events-none select-none"
         style="right:1%; top:50%; transform:translateY(-50%); z-index:1;
                width:clamp(280px,29vw,500px); height:auto; opacity:0.45;" />

    <!-- Player photo (no side gradients) -->
    {photoUrl && (
      <div class="absolute inset-0 flex items-end justify-center pointer-events-none" style="z-index:2;">
        <img src={photoUrl} alt={name} loading="eager" class="h-full w-auto max-w-none" />
      </div>
    )}

    <PlayerHeroContent
      locale="en"
      name={name}
      positionLabel={posLabel}
      shirtNumber={shirtNumber}
    />

  </div>

  <PlayerMetadataBar
    locale="en"
    positionLabel={posLabel}
    nickname={cmsPlayer?.nickname}
    formerClubs={cmsPlayer?.formerClubs}
    countryName={countryName}
    height={height}
    dateOfBirth={dob}
  />

  <!-- ── Bio + Latest Results ───────────────────────────────────────── -->
  <section style="background:#fff;">
    <div class="max-w-7xl mx-auto px-5 md:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-10 lg:gap-16 items-start">

        <!-- Left: Player Bio + Quote -->
        <div>
          <h2 class="font-black text-xl mb-4" style="color:#111;">Player Bio</h2>
          {cmsPlayer?.bio ? (
            <div class="space-y-4">
              {cmsPlayer.bio.split('\n\n').filter(Boolean).map(para => (
                <p style="color:#444; line-height:1.75; font-size:0.9375rem;">{para}</p>
              ))}
            </div>
          ) : (
            <p style="color:#aaa; font-size:0.875rem; line-height:1.7;">
              Player bio coming soon.
            </p>
          )}
          {cmsPlayer?.quote && (
            <div class="relative mt-8 pl-3">
              <span aria-hidden="true" class="absolute top-0 left-0 font-black leading-none select-none pointer-events-none"
                    style="font-size:5rem; color:#D3BC8D; opacity:0.25; line-height:1;">&ldquo;</span>
              <blockquote class="relative font-medium italic leading-snug pt-5"
                          style="font-size:clamp(1.1rem,2vw,1.5rem); color:#006A52; letter-spacing:-0.01em;">
                {cmsPlayer.quote}
              </blockquote>
            </div>
          )}
        </div>

        <!-- Right: Latest Results -->
        <PlayerSeasonStatsTable locale="en" rows={seasonStats} />

      </div>
    </div>
  </section>

  <!-- ── Photo gallery ─────────────────────────────────────────────── -->
  {galleryImages.length > 0 && (
    <section>
      <!-- Full-width first image -->
      <div class="w-full overflow-hidden" style="aspect-ratio:16/7;">
        <img
          src={galleryImages[0].src}
          alt={galleryImages[0].alternativeText ?? name}
          class="w-full h-full object-cover"
        />
      </div>
      <!-- 3-column grid for remaining images -->
      {galleryImages.length > 1 && (
        <div class="grid grid-cols-3">
          {galleryImages.slice(1, 4).map(img => (
            <div class="overflow-hidden" style="aspect-ratio:1/1;">
              <img
                src={img.src}
                alt={img.alternativeText ?? name}
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>
      )}
    </section>
  )}
</Base>
