---
import AppScreenshotCarousel from '@/components/AppScreenshotCarousel.astro';
import Base from '@/layouts/Base.astro';

export const prerender = true;

interface Group {
  title: string;
  intro: string;
  items: string[];
}

const appShots = [
  { src: '/images/myab-app-shot-1-home.jpg', alt: 'MyAB app home screen with upcoming match and news' },
  { src: '/images/myab-app-shot-2-wallet.jpg', alt: 'Tickets and membership card in MyAB Wallet' },
  { src: '/images/myab-app-shot-3-competitions.jpg', alt: 'Enter competitions for tickets and prizes' },
  { src: '/images/myab-app-shot-4-matches.jpg', alt: "See all of AB's matches and buy tickets" },
  { src: '/images/myab-app-shot-5-tv.jpg', alt: 'Watch highlights and livestreams in MyAB' },
  { src: '/images/myab-app-shot-6-matchday.jpg', alt: 'Detailed match info and standings on matchday' },
];

const groups: Group[] = [
  {
    title: 'Exclusive Content',
    intro: 'A MyAB subscription includes exclusive, first looks and behind-the-scenes content like:',
    items: [
      'Extended interviews',
      'First looks at ABTV Originals',
      "Player Q&A's",
      'Matchday or match recap features',
    ],
  },
  {
    title: 'Members-Only Benefits',
    intro: 'Special perks and rewards available only to subscribers:',
    items: [
      'Special match day promotions, e.g. beer happy hour',
      'Early access to in-app flash sales',
      'Merchandise offers and limited edition drops',
    ],
  },
  {
    title: 'Partner Offers',
    intro: 'Exclusive game day and post-match offers from AB partners:',
    items: ['Restaurants', 'Coffee', 'Retail', 'Etc.'],
  },
];
---

<Base
  locale="en"
  title="MyAB Membership | Akademisk Boldklub"
  description="Become an AB Insider with MyAB — exclusive content, member-only rewards, and partner discounts in the AB fan app."
  ogTitle="Join MyAB – AB's Fan Membership"
  ogDescription="Get exclusive content, discounts and live streams with MyAB, the official fan membership from Akademisk Boldklub."
>

  <!-- App download -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-4xl mx-auto px-8 text-center">
      <h1 class="font-black text-[#111] text-center max-w-[32ch] mx-auto mb-10" style="font-size:clamp(1.75rem,4vw,2.75rem);line-height:1.2;letter-spacing:-0.02em">
        Become an AB Insider with MyAB, exclusively within the AB fan app!
      </h1>

      <div class="inline-flex p-4 border border-[#E5E7EB] bg-white">
        <img
          src="/api/qr/app.png"
          alt="QR code to download the MyAB app"
          width="150"
          height="150"
          class="w-[150px] h-[150px]"
          loading="lazy"
        />
      </div>
      <p class="text-[#333] mt-6 mb-14" style="font-size:1rem;line-height:1.6">
        To download the app, open the camera on your mobile device.
        Point it at the QR code, and you're good to go.
      </p>

      <AppScreenshotCarousel shots={appShots} />

      <p class="text-[#666] text-[0.9rem] mt-10 max-w-[48ch] mx-auto" style="line-height:1.7">
        MyAB is available exclusively through AB's official fan app —
        download it by scanning the QR code, or download directly on{' '}
        <a
          href="https://play.google.com/store/apps/details?id=dk.ab.club&hl=en_US&pli=1"
          target="_blank"
          rel="noreferrer noopener"
          class="underline hover:text-ab-green transition-colors"
        >Google Play</a>{' '}
        or{' '}
        <a
          href="https://apps.apple.com/id/app/myab/id6760774439"
          target="_blank"
          rel="noreferrer noopener"
          class="underline hover:text-ab-green transition-colors"
        >Apple App Store</a>.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-[#F2F2F0] border-t border-[#E5E7EB] py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <h2 class="font-black mb-10 text-[#111]" style="font-size:clamp(1.5rem,3.5vw,2.5rem);letter-spacing:-0.03em">
        What a MyAB subscription gets you
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {groups.map((group) => (
          <div class="bg-white border border-[#E5E7EB] p-7">
            <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-green mb-4">{group.title}</p>
            <p class="text-[0.85rem] text-[#666] leading-relaxed mb-4">{group.intro}</p>
            <ul class="space-y-2.5">
              {group.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.9rem] text-[#333] leading-snug">
                  <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5 6.5 12 2.5 8" stroke="var(--ab-green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
