  <!-- 2004: Beige bg — text left, placeholder image right -->
  <section id="2004" class="bg-ab-beige py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-[1.65fr_minmax(0,360px)] gap-16 lg:gap-20 items-start">
