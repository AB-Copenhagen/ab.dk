---
import Base from '@/layouts/Base.astro';
import { fetchABEvents } from '@/lib/si/client';
import { abConfig } from '@/lib/config/ab';
import { fetchBilletTicketMap, findTicketUrl } from '@/lib/billet';

export const prerender = false;

const now = new Date();
const toDate = new Date(now);
toDate.setMonth(toDate.getMonth() + 4);

let upcomingHome: Awaited<ReturnType<typeof fetchABEvents>> = [];
try {
  const events = await fetchABEvents({
    locale: 'en',
    limit: 50,
    fromDate: now.toISOString().slice(0, 10),
    toDate: toDate.toISOString().slice(0, 10),
  });
  upcomingHome = events.filter((e) => e.homeId === abConfig.teamId);
} catch { /* SI API unavailable */ }

const billetMap = await fetchBilletTicketMap().catch(() => new Map<string, string>());
function ticketUrl(opponentName: string): string {
  return findTicketUrl(billetMap, opponentName) ?? 'https://billet.ab.dk/';
}

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
}
function fmtTime(d: string) {
  return new Date(d).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}
---

<Base locale="en" title="Events | AB 1889">

  <!-- Slim header -->
  <div class="bg-ab-black border-b border-white/10 py-10 px-8 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-black text-white text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] leading-tight">Events</h1>
    </div>
  </div>

  <!-- Watch parties -->
  <section class="bg-[#F2F2F0] py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-16 lg:mb-20">
        <div>
          <h2 class="font-black text-[clamp(1.5rem,3vw,2.25rem)] tracking-[-0.03em] text-[#111] mb-4">
            Find Your Local Watch Party
          </h2>
          <p class="text-[1rem] leading-[1.75] text-[#555] max-w-[48ch] mb-3">
            Can't make it to the stadium or to the away match?
          </p>
          <p class="text-[1rem] leading-[1.75] text-[#555] max-w-[48ch]">
            AB hosts global and local watch parties, everywhere from London,
            New York City, Washington D.C., Los Alamos and more! Be sure to
            check the calendar to see if there is a city near you.
          </p>
        </div>
        <img
          src="/images/watch-party-2.jpg"
          alt="AB fans gathered for a watch party"
          class="w-full h-full object-cover aspect-[4/3]"
          loading="lazy"
        />
      </div>

      <!-- Club calendar -->
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <img
          src="/images/watch-party-1.jpg"
          alt="AB fans at a local watch party"
          class="w-full h-full object-cover aspect-[4/3]"
          loading="lazy"
        />
        <div>
          <h2 class="font-black text-[clamp(1.5rem,3vw,2.25rem)] tracking-[-0.03em] text-[#111] mb-4">
            Event Calendar
          </h2>
          <p class="text-[1.0625rem] leading-[1.75] text-[#444] max-w-[48ch] mb-6">
            Want to stay updated on everything happening at AB and Gladsaxe Stadium? AB regularly holds a number of great events throughout the year.
          </p>
          <a
            href="https://luma.com/abdk"
            target="_blank"
            rel="noreferrer noopener"
            aria-label="View our club calendar on Luma (opens in new tab)"
            class="inline-flex items-center gap-2 font-black text-[0.8rem] uppercase tracking-[0.08em] bg-ab-green text-white px-7 py-3.5 no-underline transition-opacity hover:opacity-80"
          >
            View club calendar →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Events list -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <h2 class="font-black text-[clamp(1.5rem,3vw,2.25rem)] tracking-[-0.03em] text-[#111] mb-8">
        Match Days
      </h2>

      {upcomingHome.length > 0 ? (
        <div class="flex flex-col gap-0 divide-y divide-[#F0F0F0]">
          {upcomingHome.map((event) => {
            const opponent = event.awayId === abConfig.teamId ? event.homeName : event.awayName;
            const venue = event.properties?.venueName ?? 'Gladsaxe Stadion';
            return (
              <div class="group relative flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8 py-6 hover:bg-[#FAFAFA] transition-colors -mx-4 px-4">
                <a href={`/en/match/${event.eventId}`} class="absolute inset-0 z-0" aria-label={`View match: AB 1889 vs ${opponent}`} />
                <!-- Date column -->
                <div class="shrink-0 sm:w-40 relative z-10 pointer-events-none">
                  <p class="font-black text-[0.65rem] uppercase tracking-[0.1em] text-ab-neon mb-0.5">Match Day</p>
                  <p class="font-black text-[1rem] text-[#111] tracking-[-0.03em] leading-tight">{fmtDate(event.startDate)}</p>
                  <p class="text-[0.85rem] text-[#888] mt-0.5">{fmtTime(event.startDate)}</p>
                </div>
                <!-- Match info -->
                <div class="flex-1 min-w-0 relative z-10 pointer-events-none">
                  <p class="font-black text-[1.15rem] text-[#111] tracking-[-0.03em]">AB 1889 vs {opponent}</p>
                  <p class="text-[0.88rem] text-[#666] mt-0.5">{venue}</p>
                </div>
                <!-- CTA -->
                <div class="shrink-0 flex items-center gap-3 relative z-10">
                  <a
                    class="vivenu-btn text-[0.75rem] font-black uppercase tracking-[0.08em] bg-ab-neon text-ab-green px-4 py-2.5 no-underline hover:opacity-80 transition-opacity"
                    href={`${ticketUrl(event.awayName ?? '')}?useEmbed=true`}>
                    Tickets
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="py-20 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#F5F5F5] mb-6">
            <svg class="w-7 h-7 text-[#CCC]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <p class="font-black text-[1.1rem] text-[#111] tracking-[-0.03em] mb-2">No upcoming events</p>
          <p class="text-[0.9rem] text-[#888]">Check back soon — more events will be announced here.</p>
        </div>
      )}

    </div>
  </section>

  <!-- Connect Through Football -->
  <section class="bg-[#F2F2F0] border-t border-[#E5E7EB] py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <h2 class="font-black text-[clamp(1.5rem,3vw,2.25rem)] tracking-[-0.03em] text-[#111] mb-4">
        Connect Through Football
      </h2>
      <p class="text-[1rem] leading-[1.75] text-[#555] max-w-[64ch] mb-4">
        Build meaningful relationships, discover new opportunities, and
        connect with other business professionals who share a passion for
        football and community. You can learn more about becoming a
        partner in the AB Business Network by contacting
        <a href="mailto:info@ab.dk" class="text-ab-green font-black no-underline hover:opacity-70">info@ab.dk</a>.
      </p>
    </div>
  </section>

  <!-- Hospitality CTA -->
  <section class="bg-ab-green py-[clamp(40px,6vw,64px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-neon mb-2">Private Events</p>
        <h2 class="font-black text-white text-[clamp(1.4rem,3vw,2.2rem)] tracking-[-0.04em] leading-tight">Host your event at Gladsaxe Stadion</h2>
        <p class="text-white/70 text-[0.95rem] mt-2 max-w-[44ch]">Our Knud Lundberg Lounge and The Mad Owl Pub are available for conferences, dinners and private events.</p>
      </div>
      <a
        href="/en/hospitality"
        class="shrink-0 inline-flex items-center gap-2 font-black text-[0.8rem] uppercase tracking-[0.08em] bg-ab-neon text-ab-green px-7 py-3.5 no-underline hover:opacity-90 transition-opacity whitespace-nowrap">
        View hospitality →
      </a>
    </div>
  </section>

</Base>
