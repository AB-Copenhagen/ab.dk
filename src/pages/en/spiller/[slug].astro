---
import Base from '@/layouts/Base.astro';
import { fetchPlayerProfile, fetchABPlayers, fetchPlayerStats, aggregateSeasonStats } from '@/lib/si/client';
import type { SIPlayerProfile } from '@/lib/si/client';
import { fetchPlayerCmsData, strapiMediaUrl } from '@/lib/strapi/client';
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

export const prerender = false;

const { slug } = Astro.params;
const playerId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(playerId)) {
  return Astro.redirect('/en/hold');
}

let player: SIPlayerProfile | null = null;

try {
  player = await fetchPlayerProfile(playerId, 'en');
} catch {
  // fall through to redirect
}

if (!player) {
  return Astro.redirect('/en/hold');
}

const { name, position, countryName, birthDate, height } = player;

// Fetch in parallel: jersey number, season stats, CMS content
const [squadPlayers, matchStats, cmsPlayer] = await Promise.all([
  fetchABPlayers('en').catch(() => []),
  fetchPlayerStats(playerId).catch(() => []),
  fetchPlayerCmsData(playerId, 'en').catch(() => null),
]);

const shirtNumber = squadPlayers.find(p => p.id === playerId)?.shirtNumber;
const photoUrl = getPlayerPhotoUrl(name);
const seasonStats = aggregateSeasonStats(matchStats);

const posLabels: Record<string, string> = {
  keeper:     'Goalkeeper',
  defender:   'Defender',
  midfielder: 'Midfielder',
  forward:    'Forward',
};
const posLabel = posLabels[position?.toLowerCase() ?? ''] ?? position;

const pageTitle = `${name} | Akademisk Boldklub`;

const dob = birthDate
  ? new Date(birthDate).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

// Gallery images with absolute URLs
const galleryImages = (cmsPlayer?.gallery ?? []).map(img => ({
  ...img,
  src: strapiMediaUrl(img.url),
}));
---

<Base locale="en" title={pageTitle}>
  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <div class="relative w-full overflow-hidden"
       style="background:linear-gradient(135deg, #004A38 0%, #006A52 55%, #007A5E 100%); min-height:clamp(460px,36vw,560px);">

    <!-- AB 1889 logo watermark behind photo -->
    <img src="/images/logo-behind-player.svg" alt="" aria-hidden="true"
         class="absolute hidden md:block pointer-events-none select-none"
         style="left:50%; top:50%; transform:translate(-50%,-50%); z-index:1;
                width:clamp(320px,44vw,580px); height:auto;
                filter:brightness(0) opacity(0.18);" />

    <!-- Circular crest behind player photo -->
    <img src="/images/crest-behind-player.svg" alt="" aria-hidden="true"
         class="absolute hidden lg:block pointer-events-none select-none"
         style="left:55%; top:50%; transform:translate(-50%,-50%); z-index:1;
                width:clamp(300px,42vw,520px); height:auto; opacity:0.22;" />

    <!-- Player photo (no side gradients) -->
    {photoUrl && (
      <div class="absolute inset-0 flex items-end justify-center pointer-events-none" style="z-index:2;">
        <img src={photoUrl} alt={name} loading="eager" class="h-full w-auto max-w-none" />
      </div>
    )}

    <!-- Left: text content -->
    <div class="relative flex flex-col justify-center"
         style="z-index:10; width:clamp(260px,38vw,500px); min-height:clamp(460px,36vw,560px);
                padding:3.5rem max(1.5rem,5vw) 3.5rem max(1.5rem,8vw);">
      <a href="/en/hold"
         class="inline-flex items-center gap-1 text-xs font-bold uppercase mb-8 hover:opacity-100 transition-opacity"
         style="color:rgba(255,255,255,0.6); letter-spacing:0.16em;">
        ← The Squad
      </a>
      <p class="font-bold uppercase mb-3" style="font-size:0.6rem; color:rgba(255,255,255,0.45); letter-spacing:0.24em;">
        Akademisk Boldklub 1889
      </p>
      <h1 class="font-black text-white leading-none mb-3"
          style="font-size:clamp(2rem,4.5vw,4.5rem); letter-spacing:-0.04em;">
        {name}
      </h1>
      <p class="text-white mb-10" style="font-size:clamp(1rem,1.4vw,1.25rem); opacity:0.7;">
        {posLabel}
      </p>
      {shirtNumber != null && (
        <p class="font-black text-white leading-none select-none"
           style="font-size:clamp(5rem,10.5vw,11rem); letter-spacing:-0.05em; opacity:0.85;">
          {shirtNumber}
        </p>
      )}
    </div>

  </div>

  <!-- ── Metadata bar (full-width, equal cells) ─────────────────────── -->
  <div style="background:#fff; border-bottom:1px solid #E5E7EB;">
    <div class="flex overflow-x-auto divide-x divide-gray-200">
      <div class="py-5 px-6 flex-1 text-center" style="min-width:90px;">
        <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Position</p>
        <p class="font-black" style="font-size:0.9rem; color:#111;">{posLabel}</p>
      </div>
      {cmsPlayer?.nickname && (
        <div class="py-5 px-6 flex-1 text-center" style="min-width:90px;">
          <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Nickname</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{cmsPlayer.nickname}</p>
        </div>
      )}
      {cmsPlayer?.formerClubs && (
        <div class="py-5 px-6 flex-1 text-center" style="min-width:110px;">
          <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Former Clubs</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{cmsPlayer.formerClubs}</p>
        </div>
      )}
      {countryName && (
        <div class="py-5 px-6 flex-1 text-center" style="min-width:90px;">
          <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Nationality</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{countryName}</p>
        </div>
      )}
      {height && (
        <div class="py-5 px-6 flex-1 text-center" style="min-width:80px;">
          <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Height</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{height} cm</p>
        </div>
      )}
      {dob && (
        <div class="py-5 px-6 flex-1 text-center" style="min-width:110px;">
          <p class="mb-1.5 uppercase" style="font-size:0.65rem; color:#6B7280; letter-spacing:0.14em;">Birthday</p>
          <p class="font-black" style="font-size:0.9rem; color:#111;">{dob}</p>
        </div>
      )}
    </div>
  </div>

  <!-- ── Bio + Latest Results ───────────────────────────────────────── -->
  <section style="background:#fff;">
    <div class="max-w-7xl mx-auto px-5 md:px-12 py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-10 lg:gap-16 items-start">

        <!-- Left: Player Bio -->
        <div>
          <h2 class="font-black text-xl mb-4" style="color:#111;">Player Bio</h2>
          {cmsPlayer?.bio ? (
            <div class="space-y-4">
              {cmsPlayer.bio.split('\n\n').filter(Boolean).map(para => (
                <p style="color:#444; line-height:1.75; font-size:0.9375rem;">{para}</p>
              ))}
            </div>
          ) : (
            <p style="color:#aaa; font-size:0.875rem; line-height:1.7;">
              Player bio coming soon.
            </p>
          )}
        </div>

        <!-- Right: Latest Results -->
        {seasonStats.length > 0 && (
          <div>
            <div style="background:#00FF1F; padding:0.75rem 1.25rem;">
              <h2 class="font-black text-xl" style="color:#006A52;">Latest Results</h2>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr style="background:#006A52;">
                    <th class="text-left py-2.5 px-4 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Season</th>
                    <th class="text-left py-2.5 px-4 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Club</th>
                    <th class="text-center py-2.5 px-3 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Goals</th>
                    <th class="text-center py-2.5 px-3 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Assists</th>
                    <th class="text-center py-2.5 px-3 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Yellow Cards</th>
                    <th class="text-center py-2.5 px-3 font-black text-xs" style="color:#00FF1F; letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;">Red Cards</th>
                  </tr>
                </thead>
                <tbody>
                  {seasonStats.map((s, i) => (
                    <tr style={i % 2 === 0 ? 'background:#F9FAF9;' : 'background:#fff;'}>
                      <td class="py-3 px-4 font-black text-sm" style="color:#006A52; white-space:nowrap;">{s.seasonName}</td>
                      <td class="py-3 px-4" style="color:#111; white-space:nowrap;">{s.teamName}</td>
                      <td class="py-3 px-3 text-center font-bold" style="color:#111;">{s.goals}</td>
                      <td class="py-3 px-3 text-center font-bold" style="color:#111;">{s.assists}</td>
                      <td class="py-3 px-3 text-center font-bold" style="color:#111;">{s.yellowCards}</td>
                      <td class="py-3 px-3 text-center font-bold" style="color:#111;">{s.redCards}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- ── Quote ──────────────────────────────────────────────────────── -->
  {cmsPlayer?.quote && (
    <section style="background:#fff; border-top:1px solid #E5E7EB; padding:5rem 0;">
      <div class="max-w-4xl mx-auto px-5 md:px-12 text-center">
        <blockquote class="font-black italic leading-tight"
                    style="font-size:clamp(1.75rem,4.5vw,3.5rem); color:#111; letter-spacing:-0.03em;">
          &ldquo;{cmsPlayer.quote}&rdquo;
        </blockquote>
        <p class="mt-5" style="color:#888; font-size:0.875rem; letter-spacing:0.05em;">
          — {name}
        </p>
      </div>
    </section>
  )}

  <!-- ── Photo gallery ─────────────────────────────────────────────── -->
  {galleryImages.length > 0 && (
    <section>
      <!-- Full-width first image -->
      <div class="w-full overflow-hidden" style="aspect-ratio:16/7;">
        <img
          src={galleryImages[0].src}
          alt={galleryImages[0].alternativeText ?? name}
          class="w-full h-full object-cover"
        />
      </div>
      <!-- 3-column grid for remaining images -->
      {galleryImages.length > 1 && (
        <div class="grid grid-cols-3">
          {galleryImages.slice(1, 4).map(img => (
            <div class="overflow-hidden" style="aspect-ratio:1/1;">
              <img
                src={img.src}
                alt={img.alternativeText ?? name}
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>
      )}
    </section>
  )}
</Base>
