---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import { fetchPlayerProfile } from '@/lib/si/client';
import type { SIPlayerProfile } from '@/lib/si/client';

export const prerender = false;

const { slug } = Astro.params;
const playerId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(playerId)) {
  return Astro.redirect('/en/hold');
}

let player: SIPlayerProfile | null = null;

try {
  player = await fetchPlayerProfile(playerId, 'en');
} catch {
  // fall through to redirect
}

if (!player) {
  return Astro.redirect('/en/hold');
}

const { name, position, nationality, dateOfBirth, stats } = player;

const pageTitle = `${name} | AB 1889`;

const dob = dateOfBirth
  ? new Date(dateOfBirth).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const WIDGET_TEAM_ID = 10202;
const WIDGET_SEASON_ID = 16387;
---

<Base locale="en" title={pageTitle}>
  <div style="background:#fff">
    <div class="border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-5 md:px-12">
        <div class="pt-10 pb-8">
          <a
            href="/en/hold"
            class="inline-flex items-center gap-2 text-xs font-bold uppercase mb-8 hover:underline"
            style="color:#006A52;letter-spacing:0.15em"
          >
            ← All players
          </a>
          <p class="text-xs font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
            {position}
            {nationality && ` · ${nationality}`}
          </p>
          <h1
            class="font-black"
            style="font-size:clamp(2.5rem,7vw,5rem);letter-spacing:-0.03em;line-height:0.92;color:#111"
          >
            {name}
          </h1>
          {dob && (
            <p class="mt-3 text-sm" style="color:#6B7280">Born {dob}</p>
          )}
          {stats && (
            <div class="flex flex-wrap gap-6 mt-6">
              {[
                { label: 'Appearances', value: stats.appearances },
                { label: 'Goals', value: stats.goals },
                { label: 'Assists', value: stats.assists },
                { label: 'Yellow cards', value: stats.yellowCards },
                { label: 'Red cards', value: stats.redCards },
              ].map(({ label, value }) => (
                <div>
                  <p class="text-2xl font-black tabular-nums" style="color:#D6A02A">{value}</p>
                  <p class="text-[0.6rem] font-bold uppercase" style="color:#9CA3AF;letter-spacing:0.15em">{label}</p>
                </div>
              ))}
            </div>
          )}
          <div class="mt-6 h-0.5 w-12" style="background:#006A52"></div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14 space-y-14">

      <section>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerProfile"
            params={{ playerId, card: 'true', showTShirt: 'true', teamId: WIDGET_TEAM_ID, lang: 'en' }}
            minHeight={360}
            label={`${name} — profile`}
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Season statistics
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          The season
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerSeasonStats"
            params={{ playerId, card: 'true', nopadding: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID, lang: 'en' }}
            minHeight={280}
            label="Season stats summary"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Detailed
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Statistics
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKPlayerStatsGrid"
            params={{ playerId, nopadding: 'false', transparent: 'true', teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID, lang: 'en' }}
            minHeight={400}
            label="Statistics grid"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Video
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Goals this season
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="SPDKGoalsHighlights"
            params={{
              type: 'VIDEO_BY_PLAYER',
              viewList: 'VIEW_SLIDER',
              viewCard: 'PLAYER_MIN_MATCH_INFO',
              playerId,
              seasonId: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
              lang: 'en',
            }}
            minHeight={300}
            label="Goals highlights"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">
          Comparison
        </p>
        <h2
          class="font-black mb-6"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em;color:#111"
        >
          Radar
        </h2>
        <div style="background:#060806;border:1px solid #152214;overflow:hidden">
          <SiWidget
            widget="PlayerH2HSeasonRadarStatsOPTA"
            params={{
              playerId1: playerId,
              seasonId1: WIDGET_SEASON_ID,
              teamId: WIDGET_TEAM_ID,
              lang: 'en',
            }}
            minHeight={480}
            label="Radar comparison"
          />
        </div>
      </section>

    </div>
  </div>
</Base>
