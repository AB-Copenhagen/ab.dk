---
import Base from '@/layouts/Base.astro';
import { fetchCollectionType } from '@/lib/strapi/client';
import { strapiMediaUrl } from '@/lib/strapi/client';
export const prerender = false;

const { slug } = Astro.params;
const locale = 'en';

const results = await fetchCollectionType<any[]>('pages', {
  locale,
  filters: { slug: { $eq: slug } },
}).catch(() => [] as any[]);

const page = results[0];

if (!page) {
  return Astro.redirect('/en/');
}

const title = page.seo?.metaTitle ?? page.title ?? 'Akademisk Boldklub';
const description = page.seo?.metaDescription ?? page.description ?? '';
const blocks: any[] = page.dynamic_zone ?? [];
---

<Base locale="en" title={`${title} | Akademisk Boldklub`} description={description}>
  {blocks.length === 0 ? (
    <div class="bg-white">
      <div class="border-b border-gray-200">
        <div class="max-w-3xl mx-auto px-5 md:px-8 py-16">
          <p class="text-xs font-bold uppercase mb-3 text-ab-green tracking-[0.2em]">
            Akademisk Boldklub
          </p>
          <h1 class="font-black mb-6 text-[#111]" style="font-size:clamp(2rem,6vw,4rem);letter-spacing:-0.03em">
            {page.title}
          </h1>
          {page.description && (
            <p class="text-base leading-relaxed text-[#374151]">{page.description}</p>
          )}
        </div>
      </div>
    </div>
  ) : (
    <div class="bg-white">
      {blocks.map((block: any) => {
        const type = block.__component ?? '';

        if (type === 'dynamic-zone.hero') {
          return (
            <section class="relative min-h-[60vh] flex flex-col justify-end overflow-hidden px-5 md:px-12 pb-16" style="background:#060806">
              {block.image?.url && (
                <div class="absolute inset-0">
                  <img src={strapiMediaUrl(block.image.url)} alt="" class="w-full h-full object-cover opacity-40" />
                  <div class="absolute inset-0" style="background:linear-gradient(to top,#060806 0%,transparent 60%)"></div>
                </div>
              )}
              <div class="relative z-10 max-w-4xl">
                <h1 class="font-black text-white mb-4" style="font-size:clamp(3rem,10vw,7rem);letter-spacing:-0.04em;line-height:0.9">
                  {block.heading ?? block.title}
                </h1>
                {(block.subheading ?? block.description) && (
                  <p class="text-base leading-relaxed max-w-xl" style="color:rgba(255,255,255,0.6)">
                    {block.subheading ?? block.description}
                  </p>
                )}
                {block.cta && (
                  <a href={block.cta.href ?? block.cta.url ?? '#'} class="inline-flex items-center gap-2 mt-6 font-bold text-white uppercase text-xs px-6 py-3 bg-ab-green tracking-[0.15em]">
                    {block.cta.label ?? block.cta.text ?? 'Read more'} →
                  </a>
                )}
              </div>
            </section>
          );
        }

        if (type === 'dynamic-zone.cta') {
          return (
            <section class="border-y border-gray-200 py-16 px-5 md:px-12 bg-[#F9FAFB]">
              <div class="max-w-3xl mx-auto text-center">
                {block.heading && (
                  <h2 class="font-black mb-4 text-[#111]" style="font-size:clamp(1.5rem,4vw,2.5rem);letter-spacing:-0.03em">
                    {block.heading}
                  </h2>
                )}
                {block.description && (
                  <p class="text-sm leading-relaxed mb-8 text-[#6B7280]">{block.description}</p>
                )}
                {block.cta && (
                  <a href={block.cta.href ?? block.cta.url ?? '#'} class="inline-flex items-center gap-2 font-bold text-white uppercase text-xs px-7 py-4 bg-ab-green tracking-[0.15em]">
                    {block.cta.label ?? block.cta.text ?? 'Read more'} →
                  </a>
                )}
              </div>
            </section>
          );
        }

        if (type === 'dynamic-zone.faq') {
          const items: any[] = block.faqs ?? block.items ?? [];
          return (
            <section class="max-w-3xl mx-auto px-5 md:px-8 py-16">
              {block.heading && (
                <h2 class="font-black mb-8 text-[#111]" style="font-size:clamp(1.5rem,3vw,2rem);letter-spacing:-0.02em">
                  {block.heading}
                </h2>
              )}
              <div class="divide-y divide-gray-200">
                {items.map((item: any) => (
                  <details class="py-5 group">
                    <summary class="flex items-center justify-between cursor-pointer text-sm font-bold text-[#111]" style="letter-spacing:-0.01em">
                      {item.question ?? item.title}
                      <span class="text-lg transition-transform group-open:rotate-45 text-ab-green">+</span>
                    </summary>
                    <p class="mt-3 text-sm leading-relaxed text-[#374151]">
                      {item.answer ?? item.content}
                    </p>
                  </details>
                ))}
              </div>
            </section>
          );
        }

        if (type === 'dynamic-zone.features') {
          const items: any[] = block.features ?? block.items ?? [];
          return (
            <section class="max-w-7xl mx-auto px-5 md:px-12 py-16">
              {block.heading && (
                <h2 class="font-black mb-10 text-center text-[#111]" style="font-size:clamp(1.5rem,3vw,2rem);letter-spacing:-0.02em">
                  {block.heading}
                </h2>
              )}
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {items.map((item: any) => (
                  <div class="border border-gray-200 p-6 bg-white">
                    <h3 class="text-sm font-bold mb-2 text-[#111]" style="letter-spacing:-0.01em">
                      {item.title ?? item.heading}
                    </h3>
                    <p class="text-xs leading-relaxed text-[#6B7280]">
                      {item.description ?? item.content}
                    </p>
                  </div>
                ))}
              </div>
            </section>
          );
        }

        return null;
      })}
    </div>
  )}
</Base>
