---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import { fetchEvent } from '@/lib/si/client';
import type { SIEvent } from '@/lib/si/client';

export const prerender = false;

const { slug } = Astro.params;
const eventId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(eventId)) {
  return Astro.redirect('/en/matches');
}

let event: SIEvent | null = null;

try {
  event = await fetchEvent(eventId, 'en');
} catch {
  // fall through to redirect
}

if (!event) {
  return Astro.redirect('/en/matches');
}

const { homeName, awayName, startDate, statusType, score, tournamentName } = event;

const pageTitle = `${homeName} vs ${awayName} | AB 1889`;
const matchDate = new Date(startDate).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});

const isLive = statusType === 'inprogress';
const isFinished = statusType === 'finished';

const WIDGET_TEAM_ID = 10202;
const WIDGET_TOURNAMENT_ID = 46;
const WIDGET_SEASON_ID = 16387;
---

<Base locale="en" title={pageTitle}>
  <div class="bg-white">
    <div class="border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-5 md:px-12">
        <div class="pt-10 pb-8">
          <a
            href="/en/matches"
            class="inline-flex items-center gap-2 text-xs font-bold uppercase mb-8 hover:underline text-ab-green tracking-[0.15em]"
          >
            ← All matches
          </a>
          <p class="text-xs font-bold uppercase mb-2 text-ab-green tracking-[0.2em]">
            {tournamentName}
          </p>
          <h1
            class="font-black text-[#111]"
            style="font-size:clamp(2rem,6vw,4rem);letter-spacing:-0.03em;line-height:0.95"
          >
            {homeName} <span class="text-ab-green">vs</span> {awayName}
          </h1>
          <p class="mt-3 text-sm text-[#6B7280]">{matchDate}</p>
          {score && (
            <p
              class="mt-3 text-2xl font-black tabular-nums"
              style={`color:${isLive ? '#00FF1F' : '#D6A02A'}`}
            >
              {score}
              {isLive && (
                <span class="ml-3 inline-flex items-center gap-1.5 text-sm font-bold uppercase text-ab-neon tracking-[0.1em]">
                  <span class="w-2 h-2 rounded-full bg-current animate-pulse"></span>
                  LIVE
                </span>
              )}
            </p>
          )}
          <div class="mt-5 h-0.5 w-12 bg-ab-green"></div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14 space-y-16">

      <section>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKMatchPageHeader"
            params={{ eventId, showTicketBtn: 'true', provider: 'unibet', teamId: WIDGET_TEAM_ID, lang: 'en' }}
            minHeight={280}
            label="Match header"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 text-ab-green tracking-[0.2em]">
          Analysis
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Before the match
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Form guide
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="MTSFormH2HSnap"
                params={{ eventId, acrossAllTournaments: 'true', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={200}
                label="Form guide"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Head to head
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="H2HTeams"
                params={{ eventId, teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={260}
                label="Head to head"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Table
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="SPDKTournamentTable"
                params={{ eventId, tournamentId: WIDGET_TOURNAMENT_ID, teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={420}
                label="Table"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Fun stats
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="EventTeamFunStats"
                params={{ eventId, fault: 2, limit: 10, teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={300}
                label="Fun stats"
              />
            </div>
          </div>
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 text-ab-green tracking-[0.2em]">
          Squad
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Line-up
        </h2>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKLineup"
            params={{ eventId, teamId: WIDGET_TEAM_ID, lang: 'en' }}
            minHeight={520}
            label="Line-up"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 text-ab-green tracking-[0.2em]">
          {isLive ? 'Live now' : isFinished ? 'Match report' : 'During the match'}
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          {isLive ? (
            <span class="inline-flex items-center gap-3">
              Live
              <span class="w-3 h-3 rounded-full" style="background:#00FF1F;box-shadow:0 0 8px #00FF1F;animation:pulse 1.5s ease-in-out infinite"></span>
            </span>
          ) : 'Statistics'}
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Momentum
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="MatchMomentum"
                params={{ eventId, teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={220}
                label="Momentum"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Incidents
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="IncidentListOpta"
                params={{ eventId, header: 'true', card: 'true', initialCollapse: 'false', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={320}
                label="Incidents"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Match statistics
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="LivePostMatchStatsOpta"
                params={{ eventId, header: 'false', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                minHeight={360}
                label="Match statistics"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              xG — Expected goals
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="TwoTeamsXGoalsPitch"
                params={{
                  eventId,
                  tournamentId: WIDGET_TOURNAMENT_ID,
                  dotSize: 32.5,
                  header: 'true',
                  teamId: WIDGET_TEAM_ID,
                  lang: 'en',
                }}
                minHeight={480}
                label="xG pitch"
              />
            </div>
          </div>
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 text-ab-green tracking-[0.2em]">
          Video
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Highlights
        </h2>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKMatchVideo"
            params={{ eventId, teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID, lang: 'en' }}
            minHeight={400}
            label="Match video"
          />
        </div>
      </section>

    </div>
  </div>
</Base>
