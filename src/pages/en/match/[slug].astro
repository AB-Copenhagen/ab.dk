---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import TeamForm from '@/components/TeamForm.astro';
import { fetchEvent, fetchTeamForm, formatEventScore, getTeamLogoSrc } from '@/lib/si/client';
import type { SIEvent } from '@/lib/si/client';
import { fetchMatchContent, strapiMediaUrl } from '@/lib/strapi/client';
import { abConfig } from '@/lib/config/ab';
import { fetchBilletTicketMap, findTicketUrl } from '@/lib/billet';
import Img from '@/components/Img.astro';

export const prerender = false;

const { slug } = Astro.params;
const eventId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(eventId)) {
  return Astro.redirect('/en/matches');
}

let event: SIEvent | null = null;

try {
  event = await fetchEvent(eventId, 'en');
} catch {
  // fall through to redirect
}

if (!event) {
  return Astro.redirect('/en/matches');
}

const { homeName, awayName, startDate, statusType, tournamentName } = event;
const score = formatEventScore(event.score);

const pageTitle = `${homeName} vs ${awayName} | AB 1889`;

const isLive = statusType === 'inprogress';
const isFinished = statusType === 'finished';
const isUpcoming = !isLive && !isFinished;
const isHome = event.homeId === abConfig.teamId;

const matchDate = new Date(startDate).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});
const matchDateDay = new Date(startDate).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const matchTime = new Date(startDate).toLocaleTimeString('en-GB', {
  hour: '2-digit',
  minute: '2-digit',
});

const cmsMatch = await fetchMatchContent(eventId).catch(() => null);
const accentColor = cmsMatch?.accentColor ?? '#006a52';
const articles = cmsMatch?.articles ?? [];
const socialEmbeds = cmsMatch?.socialEmbeds ?? [];

const billetFallback = isHome
  ? await fetchBilletTicketMap().then(m => findTicketUrl(m, awayName) ?? 'https://billet.ab.dk/').catch(() => 'https://billet.ab.dk/')
  : null;
const ticketUrl = cmsMatch?.ticketUrl ?? billetFallback;

const venueName = event.properties?.venueName ?? (isHome ? 'Gladsaxe Stadium' : awayName);

const WIDGET_TEAM_ID = 10202;
const WIDGET_TOURNAMENT_ID = 46;
const WIDGET_SEASON_ID = 16387;

const beforeDate = startDate.slice(0, 10);
const [homeForm, awayForm] = await Promise.all([
  fetchTeamForm(event.homeId, { beforeDate, locale: 'en' }).catch(() => []),
  fetchTeamForm(event.awayId, { beforeDate, locale: 'en' }).catch(() => []),
]);

const matchDescription = `${homeName} vs ${awayName} — ${matchDate} at ${venueName}.`;
const ogImageParams = new URLSearchParams({
  home: homeName,
  away: awayName,
  homeLogo: getTeamLogoSrc(event.homeId),
  awayLogo: getTeamLogoSrc(event.awayId),
  tournament: tournamentName ?? '',
  date: matchDateDay,
  time: matchTime,
  venue: venueName,
});
const ogCardImageUrl = `/api/og/match.png?${ogImageParams.toString()}`;

const matchSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: `${homeName} vs ${awayName}`,
  startDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: { '@type': 'Place', name: venueName },
  homeTeam: { '@type': 'SportsTeam', name: homeName },
  awayTeam: { '@type': 'SportsTeam', name: awayName },
  competitor: [
    { '@type': 'SportsTeam', name: homeName },
    { '@type': 'SportsTeam', name: awayName },
  ],
  organizer: { '@type': 'SportsOrganization', name: tournamentName },
  url: `https://ab.dk/en/match/${eventId}`,
};
---

<Base
  locale="en"
  title={pageTitle}
  description={matchDescription}
  ogImage={ogCardImageUrl}
  structuredData={matchSchema}
>

  <!-- Hero -->
  <div style="background:#060806">
    <div class="max-w-5xl mx-auto px-5 md:px-12 pt-8 pb-10">

      <!-- Back link -->
      <a
        href="/en/matches"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.15em] text-white/50 hover:text-white/90 transition-colors mb-8"
      >
        ← All matches
      </a>

      <!-- Competition / round label -->
      {tournamentName && (
        <div class="flex items-center gap-2 mb-6">
          <img src="/images/division-1-logo-white.svg" alt="" aria-hidden="true" class="h-4 w-auto" />
          <p class="text-[0.6rem] font-bold uppercase tracking-[0.22em] text-ab-neon">{tournamentName}</p>
        </div>
      )}

      <!-- Teams row -->
      <div class="flex items-center justify-between gap-4 md:gap-8">

        <!-- Home team -->
        <div class="flex-1 flex flex-col items-center gap-3 md:gap-4">
          <div class="w-20 h-20 md:w-28 md:h-28 flex items-center justify-center">
            <img
              src={event.homeId === abConfig.teamId ? '/images/ab-crest.svg' : getTeamLogoSrc(event.homeId)}
              alt={homeName}
              width="112" height="112"
              class="w-full h-full object-contain"
            />
          </div>
          <span class="font-black text-white text-center leading-tight" style="font-size:clamp(0.75rem,2vw,1rem);max-width:140px">{homeName}</span>
        </div>

        <!-- Centre: score or VS -->
        <div class="flex flex-col items-center gap-2 shrink-0">
          {isUpcoming ? (
            <span class="font-black text-white tracking-[0.12em]" style="font-size:clamp(1.5rem,4vw,2.5rem)">VS</span>
          ) : isLive ? (
            <>
              <span class="font-black tabular-nums text-ab-neon" style="font-size:clamp(2.5rem,7vw,4.5rem);line-height:1">{score}</span>
              <span class="inline-flex items-center gap-1.5 font-bold uppercase tracking-[0.14em] text-ab-neon" style="font-size:0.65rem">
                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                LIVE
              </span>
            </>
          ) : (
            <>
              <span class="font-black tabular-nums text-white" style="font-size:clamp(2.5rem,7vw,4.5rem);line-height:1">{score}</span>
              <span class="font-bold text-white/40 uppercase tracking-[0.18em]" style="font-size:0.6rem">Full time</span>
            </>
          )}
        </div>

        <!-- Away team -->
        <div class="flex-1 flex flex-col items-center gap-3 md:gap-4">
          <div class="w-20 h-20 md:w-28 md:h-28 flex items-center justify-center">
            <img
              src={event.awayId === abConfig.teamId ? '/images/ab-crest.svg' : getTeamLogoSrc(event.awayId)}
              alt={awayName}
              width="112" height="112"
              class="w-full h-full object-contain"
            />
          </div>
          <span class="font-black text-white text-center leading-tight" style="font-size:clamp(0.75rem,2vw,1rem);max-width:140px">{awayName}</span>
        </div>

      </div>

      <!-- Date, time, home/away badge -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-8 pt-7" style="border-top:1px solid rgba(255,255,255,0.08)">
        <!-- Calendar icon + date -->
        <div class="inline-flex items-center gap-2 text-white/60" style="font-size:0.8125rem">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M5 1v3M11 1v3M2 7h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <span class="font-semibold capitalize">{matchDateDay}</span>
        </div>
        <!-- Clock icon + time -->
        <div class="inline-flex items-center gap-2 text-white/60" style="font-size:0.8125rem">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/>
            <path d="M8 5v3.5l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-semibold">{matchTime}</span>
        </div>
        <!-- Home / Away badge -->
        <span
          class="inline-flex items-center px-3 py-1 font-black uppercase tracking-[0.14em] rounded-full"
          style={`font-size:0.6rem;${isHome ? 'background:#006A52;color:#00FF1F' : 'background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.55)'}`}
        >
          {isHome ? 'Home' : 'Away'}
        </span>
        <!-- Venue -->
        <div class="inline-flex items-center gap-2 text-white/40" style="font-size:0.8125rem">
          <svg width="12" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1.5C5.515 1.5 3.5 3.515 3.5 6c0 3.5 4.5 8.5 4.5 8.5s4.5-5 4.5-8.5c0-2.485-2.015-4.5-4.5-4.5Z" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.3"/>
          </svg>
          <span>{venueName}</span>
        </div>
      </div>

    </div>
  </div>

  <div class="bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14">
      <h1 class="font-black text-[#111] mb-8 md:mb-10" style="font-size:clamp(1.5rem,3.5vw,2.5rem);letter-spacing:-0.03em">
        {homeName} vs. {awayName}
      </h1>
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-8 lg:gap-12 items-start">

        <!-- Main content column -->
        <div class="space-y-14">

          {isUpcoming && (
            <TeamForm
              homeId={event.homeId}
              homeName={homeName}
              homeForm={homeForm}
              awayId={event.awayId}
              awayName={awayName}
              awayForm={awayForm}
              locale="en"
            />
          )}

          {!isUpcoming && (
            <>
              <section>
                <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
                  {isLive ? 'Live now' : 'Match report'}
                </p>
                <h2 class="font-black mb-8 text-[#111]" style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em">
                  {isLive ? (
                    <span class="inline-flex items-center gap-3">
                      Live
                      <span class="w-3 h-3 rounded-full" style="background:#00FF1F;box-shadow:0 0 8px #00FF1F;animation:pulse 1.5s ease-in-out infinite"></span>
                    </span>
                  ) : 'Statistics'}
                </h2>
                <div class="space-y-6">
                  <div>
                    <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">Momentum</h3>
                    <div class="overflow-hidden" style="background:#F8F9FA;border:1px solid #E5E7EB">
                      <SiWidget locale="en" widget="MatchMomentum" params={{ eventId, teamId: WIDGET_TEAM_ID, lang: 'en' }} minHeight={220} label="Momentum" />
                    </div>
                  </div>
                  <div>
                    <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">Incidents</h3>
                    <div class="overflow-hidden" style="background:#F8F9FA;border:1px solid #E5E7EB">
                      <SiWidget
                        locale="en"
                        widget="IncidentListOpta"
                        params={{ eventId, header: 'true', card: 'true', initialCollapse: 'false', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                        minHeight={320}
                        label="Incidents"
                      />
                    </div>
                  </div>
                  <div>
                    <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">Match statistics</h3>
                    <div class="overflow-hidden" style="background:#F8F9FA;border:1px solid #E5E7EB">
                      <SiWidget
                        locale="en"
                        widget="LivePostMatchStatsOpta"
                        params={{ eventId, header: 'false', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                        minHeight={360}
                        label="Match statistics"
                      />
                    </div>
                  </div>
                  <div>
                    <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">xG — Expected goals</h3>
                    <div class="overflow-hidden" style="background:#F8F9FA;border:1px solid #E5E7EB">
                      <SiWidget
                        locale="en"
                        widget="TwoTeamsXGoalsPitch"
                        params={{ eventId, tournamentId: WIDGET_TOURNAMENT_ID, dotSize: 32.5, header: 'true', teamId: WIDGET_TEAM_ID, lang: 'en' }}
                        minHeight={480}
                        label="xG pitch"
                      />
                    </div>
                  </div>
                </div>
              </section>

              <section>
                <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>Video</p>
                <h2 class="font-black mb-8 text-[#111]" style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em">
                  Highlights
                </h2>
                <div class="overflow-hidden" style="background:#F8F9FA;border:1px solid #E5E7EB">
                  <SiWidget
                    locale="en"
                    widget="SPDKMatchVideo"
                    params={{ eventId, teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID, lang: 'en' }}
                    minHeight={400}
                    label="Match video"
                  />
                </div>
              </section>
            <TeamForm
              homeId={event.homeId}
              homeName={homeName}
              homeForm={homeForm}
              awayId={event.awayId}
              awayName={awayName}
              awayForm={awayForm}
              locale="en"
            />
            </>
          )}

          {socialEmbeds.length > 0 && (
            <section>
              <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>Social</p>
              <h2 class="font-black mb-8 text-[#111]" style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em">
                From social media
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
                {socialEmbeds.map((embed) => (
                  <div class="flex flex-col gap-3">
                    <div set:html={embed.embedCode} />
                    {embed.caption && <p class="text-sm text-[#6B7280]">{embed.caption}</p>}
                  </div>
                ))}
              </div>
            </section>
          )}

          {isHome && (
            <section class="relative overflow-hidden rounded-[4px]" style="min-height:280px;background:#060806">
              <Img
                src="/images/about-stadium-seat.png"
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover object-center"
                style="opacity:0.75"
              />
              <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(6,8,6,0.72) 30%,rgba(6,8,6,0.35))" />
              <div class="relative z-10 flex flex-col items-center text-center px-8 py-14">
                <p class="text-[0.6rem] font-bold uppercase tracking-[0.2em] mb-4" style="color:#00FF1F">Gladsaxe Stadium</p>
                <h2 class="font-black text-white uppercase mb-4" style="font-size:clamp(1.75rem,4vw,2.75rem);letter-spacing:-0.02em">
                  Matchday Guide
                </h2>
                <p class="text-white/60 max-w-md mb-8 leading-relaxed" style="font-size:0.9375rem">
                  Everything you need to know to have the best time at Gladsaxe Stadium — transport, parking, and stadium info.
                </p>
                <a
                  href="/en/matchday"
                  class="font-black uppercase no-underline px-8 py-3 rounded transition-opacity hover:opacity-90"
                  style="background:#00FF1F;color:#006A52;font-size:0.8rem;letter-spacing:0.08em"
                >
                  Go to guide
                </a>
              </div>
            </section>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="space-y-5 lg:sticky lg:top-24">

          <!-- Match info -->
          <div class="border border-gray-200 rounded-[4px] p-5 space-y-4 bg-white">
            <p class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#888]">Match info</p>
            <div class="space-y-3 text-sm text-[#444]">
              <div class="flex items-start gap-3">
                <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="#888" stroke-width="1.2"/>
                  <path d="M5 1v3M11 1v3M2 7h12" stroke="#888" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <div>
                  <p class="font-bold text-[#111] capitalize">{matchDateDay}</p>
                  <p class="text-[#888] mt-0.5">{matchTime}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M8 1.5C5.515 1.5 3.5 3.515 3.5 6c0 3.5 4.5 8.5 4.5 8.5s4.5-5 4.5-8.5c0-2.485-2.015-4.5-4.5-4.5Z" stroke="#888" stroke-width="1.2"/>
                  <circle cx="8" cy="6" r="1.5" stroke="#888" stroke-width="1.2"/>
                </svg>
                <p class="text-[#444]">{venueName}</p>
              </div>
            </div>
          </div>

          <!-- Ticket CTA (home + upcoming/live only) -->
          {!isFinished && ticketUrl && (
            <a
              class="vivenu-btn flex items-center justify-center gap-2.5 w-full py-4 text-sm font-black uppercase tracking-[0.1em] text-white rounded-[4px] transition-opacity hover:opacity-90"
              href={`${ticketUrl}?useEmbed=true`}
              style="background:#006A52"
            >
              <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="4" width="12" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
                <path d="M10 4v-.5a2 2 0 0 0-4 0V4" stroke="currentColor" stroke-width="1.2"/>
              </svg>
              Buy tickets
            </a>
          )}

          <!-- Related news -->
          {articles.length > 0 && (
            <div class="space-y-4">
              <p class="text-[0.6rem] font-bold uppercase tracking-[0.2em] text-[#888]">Match news</p>
              <div class="space-y-4">
                {articles.slice(0, 3).map((article) => (
                  <a href={`/en/news/${article.slug}`} class="flex items-start gap-3 group no-underline">
                    {article.image ? (
                      <div class="w-16 h-16 rounded overflow-hidden shrink-0 bg-gray-100">
                        <img
                          src={strapiMediaUrl(article.image.url)}
                          alt=""
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <div class="w-16 h-16 rounded shrink-0 bg-[#F0F4F0] flex items-center justify-center">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                          <path d="M4 6h12M4 10h12M4 14h8" stroke="#006A52" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                      </div>
                    )}
                    <p class="text-sm font-bold text-[#111] leading-snug group-hover:underline line-clamp-3">
                      {article.title}
                    </p>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>

      </div>
    </div>
  </div>
</Base>
