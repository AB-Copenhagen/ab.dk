---
import Base from '@/layouts/Base.astro';
import heroImage from '@/assets/images/gladsaxe.webp';

export const prerender = true;

const photos = [
  {
    src: 'https://i0.wp.com/ab.dk/wp-content/uploads/2026/01/DSC09796.jpeg?ssl=1',
    alt: 'Knud Lundberg Lounge interior',
  },
  {
    src: 'https://i0.wp.com/ab.dk/wp-content/uploads/2026/01/DSC09813.jpeg?ssl=1',
    alt: 'The Mad Owl Pub interior',
  },
  {
    src: 'https://i0.wp.com/ab.dk/wp-content/uploads/2026/01/DSC09940.jpeg?ssl=1',
    alt: 'Function room at Gladsaxe Stadion',
  },
  {
    src: 'https://i0.wp.com/ab.dk/wp-content/uploads/2026/01/1784BD9B-1E3E-4FAC-A07D-F128AB864107.jpg?ssl=1',
    alt: 'Event space at AB 1889',
  },
  {
    src: 'https://i0.wp.com/ab.dk/wp-content/uploads/2026/01/2EF799D9-18D0-4293-9805-C62FA32D621F.jpg?ssl=1',
    alt: 'Venue at Gladsaxe Stadion',
  },
];
---

<Base
  locale="en"
  title="Hospitality | AB 1889 VIP Matchday Packages"
  description="Elevate your matchday with AB 1889 hospitality packages — premium seating, dining and VIP experiences at Gladsaxe Stadium."
  ogTitle="AB Hospitality – VIP Matchday Packages"
  ogDescription="Treat yourself or your guests to premium hospitality at Akademisk Boldklub matches."
>

  <!-- Hero -->
  <div class="relative overflow-hidden h-[clamp(240px,30vw,380px)]">
    <img
      src={heroImage.src}
      alt="Gladsaxe Stadion hospitality"
      width={heroImage.width}
      height={heroImage.height}
      class="absolute inset-0 w-full h-full object-cover object-center brightness-[0.45] saturate-[0.5]"
    />
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.5)_0%,rgba(0,0,0,0.1)_70%)]"></div>
    <div class="relative h-full flex flex-col justify-end px-8 lg:px-16 pb-10 max-w-7xl mx-auto w-full">
      <span class="inline-block font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-neon mb-3">AB 1889</span>
      <h1 class="font-black text-white text-[clamp(2.5rem,7vw,5.5rem)] tracking-[-0.04em] leading-[0.95]">
        Hospitality
      </h1>
    </div>
  </div>

  <!-- Intro + Gallery + Lounges -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">

      <!-- Intro -->
      <div class="mb-14">
        <div class="inline-flex items-center mb-6 bg-ab-beige rounded-full py-[7px] px-[18px]">
          <span class="font-black text-[0.75rem] text-[#111] tracking-[0.1em] uppercase">Gladsaxe Stadion</span>
        </div>
        <h2 class="font-black text-[clamp(1.75rem,3.5vw,2.5rem)] tracking-[-0.03em] text-[#111] mb-4 max-w-[26ch]">
          A Great Experience at Gladsaxe Stadium
        </h2>
        <p class="text-[1.05rem] leading-[1.75] text-[#444] max-w-[62ch]">
          Whether you are here for a match, a networking event or a big
          celebration, Gladsaxe Stadium offers a unique setting and
          multiple spaces overlooking one of Denmark's most historic
          football clubs.
        </p>
      </div>

      <!-- Match Day Experience -->
      <div class="mb-14 bg-[#F2F2F0] p-6 sm:p-10">
        <h2 class="font-black text-[clamp(1.4rem,2.8vw,2rem)] tracking-[-0.03em] text-[#111] mb-3">Match Day Experience</h2>
        <p class="text-[0.95rem] leading-[1.75] text-[#666] max-w-[64ch] mb-8">
          From cheering in Section E with AB Forever to a special VIP
          atmosphere, we offer a variety of options to enjoy the match to
          suit your needs and budget.
        </p>

        <div class="grid md:grid-cols-2 gap-8">

          <!-- Knud Lundberg Lounge -->
          <div class="border border-[#E5E7EB] overflow-hidden bg-white">
            <div class="bg-white border-b border-[#E5E7EB] px-6 py-5">
              <span class="font-black text-[0.65rem] uppercase tracking-[0.1em] text-ab-green block mb-1">1st floor</span>
              <h3 class="font-black text-[1.4rem] tracking-[-0.04em] text-[#111] leading-tight">Knud Lundberg Lounge</h3>
            </div>
            <div class="p-6">
              <p class="text-[0.9rem] text-[#555] leading-relaxed">
                Enjoy delicious, organic food and drinks in a premium
                lounge atmosphere while soaking up the electric atmosphere
                of the stadium. New this year is a coffee bar and wine bar.
              </p>
            </div>
          </div>

          <!-- The Mad Owl Pub -->
          <div class="border border-[#E5E7EB] overflow-hidden bg-white">
            <div class="bg-white border-b border-[#E5E7EB] px-6 py-5">
              <span class="font-black text-[0.65rem] uppercase tracking-[0.1em] text-ab-green block mb-1">2nd floor</span>
              <h3 class="font-black text-[1.4rem] tracking-[-0.04em] text-[#111] leading-tight">The Mad Owl Pub</h3>
            </div>
            <div class="p-6">
              <p class="text-[0.9rem] text-[#555] leading-relaxed">
                Prefer a more intimate setting? Our new pub serves a great
                selection of beers and features a stage for live
                performances, offering camaraderie outside the pitch.
              </p>
            </div>
          </div>

        </div>
      </div>

      <!-- Business and Networking / Celebrations and Parties -->
      <div class="grid md:grid-cols-2 gap-8 mb-14">
        <div>
          <h2 class="font-black text-[clamp(1.4rem,2.8vw,2rem)] tracking-[-0.03em] text-[#111] mb-3">Business and Networking</h2>
          <p class="text-[0.95rem] leading-[1.75] text-[#666]">
            Whether you're planning a company meeting, networking event,
            team building or need a private gathering, the Knud Lundberg
            Lounge on the 1st floor offers flexible event space, modern
            amenities, and views of Gladsaxe Stadion.
          </p>
        </div>

        <div>
          <h2 class="font-black text-[clamp(1.4rem,2.8vw,2rem)] tracking-[-0.03em] text-[#111] mb-3">Celebrations and Parties</h2>
          <p class="text-[0.95rem] leading-[1.75] text-[#666] mb-6">
            Lounges were made for celebrating, and The Knud Lundberg Lounge
            can accommodate up to 180 dining guests and has 2 bars. Take in
            the beautiful view of Denmark's greenest stadium. Our events are
            equipped with event furniture, a projector and AV equipment.
          </p>
          <div class="grid grid-cols-2 sm:w-fit sm:grid-cols-2 gap-3">
            <div class="bg-white border border-[#E5E7EB] p-4">
              <p class="text-[0.65rem] font-black uppercase tracking-[0.1em] text-[#999] mb-1">Capacity</p>
              <p class="font-black text-[1.1rem] text-[#111] tracking-[-0.03em]">180 guests</p>
            </div>
            <div class="bg-white border border-[#E5E7EB] p-4">
              <p class="text-[0.65rem] font-black uppercase tracking-[0.1em] text-[#999] mb-1">Bars</p>
              <p class="font-black text-[1.1rem] text-[#111] tracking-[-0.03em]">2 bars</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Photo gallery -->
      <div class="mb-14">
        <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-[#bbb] mb-3">Photos</p>
        <div class="venue-gallery">
          {photos.map((photo, i) => (
            <button
              class={`gitem gitem-${i + 1}`}
              data-src={photo.src}
              data-alt={photo.alt}
              aria-label={`View: ${photo.alt}`}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <div class="gitem-overlay" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                </svg>
              </div>
            </button>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Contact / CTA -->
  <section class="bg-ab-green py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Left: Pitch + contact info -->
        <div>
          <div class="inline-flex items-center mb-6 bg-ab-neon rounded-full py-[7px] px-[18px]">
            <span class="font-black text-[0.75rem] text-ab-green tracking-[0.1em] uppercase">Enquiries</span>
          </div>
          <h2 class="font-black text-white text-[clamp(1.8rem,4vw,3rem)] tracking-[-0.04em] leading-[1.05] mb-4">
            Let's plan your event.
          </h2>
          <p class="text-white/80 text-[1rem] leading-[1.75] max-w-[44ch] mb-8">
            Fill out the form and our team will get back to you with availability, catering options, and pricing for your event at Gladsaxe Stadion.
          </p>
          <div class="flex flex-col gap-4">
            <div class="bg-white/10 border border-white/20 p-5 flex items-center gap-4">
              <svg class="w-5 h-5 text-ab-neon shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <div>
                <p class="text-white/50 text-[0.7rem] font-black uppercase tracking-[0.1em] mb-0.5">Email</p>
                <a href="mailto:info@ab.dk" class="font-black text-white text-[1rem] tracking-[-0.02em] no-underline hover:opacity-70">info@ab.dk</a>
              </div>
            </div>
            <div class="bg-white/10 border border-white/20 p-5 flex items-center gap-4">
              <svg class="w-5 h-5 text-ab-neon shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.5 2 2 0 0 1 3.6 1.5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <p class="text-white/50 text-[0.7rem] font-black uppercase tracking-[0.1em] mb-0.5">Phone</p>
                <a href="tel:+4560399901" class="font-black text-white text-[1rem] tracking-[-0.02em] no-underline hover:opacity-70">+45 60399901</a>
              </div>
            </div>
            <div class="bg-white/10 border border-white/20 p-5 flex items-center gap-4">
              <svg class="w-5 h-5 text-ab-neon shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <p class="text-white/50 text-[0.7rem] font-black uppercase tracking-[0.1em] mb-0.5">Location</p>
                <p class="font-black text-white text-[1rem] tracking-[-0.02em] leading-snug">Gladsaxevej 202<br>2860 Søborg (Stand 4)</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Event inquiry form -->
        <div class="bg-white p-6 sm:p-8">
          <form id="ei-form" class="flex flex-col gap-4" novalidate>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="ei-name" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Name</label>
                <input id="ei-name" name="name" type="text" required autocomplete="name"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium placeholder:text-[#CCC] focus:outline-none focus:border-ab-green transition-colors" placeholder="Your name" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="ei-email" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Email</label>
                <input id="ei-email" name="email" type="email" required autocomplete="email"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium placeholder:text-[#CCC] focus:outline-none focus:border-ab-green transition-colors" placeholder="you@email.com" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="ei-phone" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Phone (optional)</label>
                <input id="ei-phone" name="phone" type="tel" autocomplete="tel"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium placeholder:text-[#CCC] focus:outline-none focus:border-ab-green transition-colors" placeholder="+45 ..." />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="ei-type" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Event type</label>
                <select id="ei-type" name="eventType"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium bg-white focus:outline-none focus:border-ab-green transition-colors">
                  <option value="">Select a type</option>
                  <option value="Business meeting / networking">Business meeting / networking</option>
                  <option value="Celebration / party">Celebration / party</option>
                  <option value="Match day experience">Match day experience</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="ei-date" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Preferred date (optional)</label>
                <input id="ei-date" name="eventDate" type="date"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium focus:outline-none focus:border-ab-green transition-colors" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="ei-guests" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Number of guests (optional)</label>
                <input id="ei-guests" name="guestCount" type="number" min="1"
                  class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium placeholder:text-[#CCC] focus:outline-none focus:border-ab-green transition-colors" placeholder="e.g. 50" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="ei-message" class="text-[0.7rem] font-black uppercase tracking-[0.1em] text-[#999]">Message</label>
              <textarea id="ei-message" name="message" required rows="4"
                class="border border-[#E5E7EB] px-4 py-3 text-[0.9rem] text-[#111] font-medium placeholder:text-[#CCC] focus:outline-none focus:border-ab-green transition-colors resize-none" placeholder="Tell us about your event..."></textarea>
            </div>

            <div id="ei-status" class="hidden text-[0.85rem] font-medium px-4 py-3"></div>
            <button type="submit" id="ei-submit"
              class="self-start inline-flex items-center gap-2 font-black text-[0.8rem] uppercase tracking-[0.08em] bg-ab-green text-white px-7 py-3.5 transition-opacity hover:opacity-80 disabled:opacity-50">
              Send inquiry
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <dialog id="lb">
    <div id="lb-backdrop">
      <button id="lb-close" aria-label="Close photo">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      <img id="lb-img" src="" alt="" />
    </div>
  </dialog>

</Base>

<style>
  /* ── Gallery grid ───────────────────────────────────────────────── */
  .venue-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  @media (min-width: 640px) {
    .venue-gallery {
      grid-template-columns: repeat(3, 1fr);
    }
    /* Portrait #1 spans both rows */
    .gitem-1 { grid-column: 1; grid-row: 1 / 3; }
    .gitem-2 { grid-column: 2; grid-row: 1; aspect-ratio: 3/2; }
    .gitem-3 { grid-column: 3; grid-row: 1; aspect-ratio: 3/2; }
    .gitem-4 { grid-column: 2; grid-row: 2; aspect-ratio: 3/4; }
    .gitem-5 { grid-column: 3; grid-row: 2; aspect-ratio: 3/4; }
  }

  .gitem {
    position: relative;
    overflow: hidden;
    cursor: zoom-in;
    aspect-ratio: 4/3;
    display: block;
    background: none;
    border: none;
    padding: 0;
  }
  @media (min-width: 640px) {
    .gitem-1 { aspect-ratio: auto; }
  }

  .gitem img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }
  .gitem:hover img {
    transform: scale(1.06);
  }

  .gitem-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease;
    pointer-events: none;
  }
  .gitem:hover .gitem-overlay {
    background: rgba(0, 0, 0, 0.18);
  }
  .gitem-overlay svg {
    width: 28px;
    height: 28px;
    color: white;
    opacity: 0;
    transition: opacity 0.25s ease;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.6));
  }
  .gitem:hover .gitem-overlay svg {
    opacity: 1;
  }

  /* ── Lightbox ───────────────────────────────────────────────────── */
  #lb {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
  }
  #lb::backdrop {
    background: rgba(0, 0, 0, 0.92);
  }
  #lb-backdrop {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: default;
  }
  #lb-img {
    max-width: 92vw;
    max-height: 90vh;
    object-fit: contain;
    display: block;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
  }
  #lb-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    transition: background 0.2s;
    z-index: 1;
  }
  #lb-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }
</style>

<script>
  const lb = document.getElementById('lb') as HTMLDialogElement;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;

  function openLightbox(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lb.showModal();
  }

  document.querySelectorAll<HTMLButtonElement>('.gitem').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src;
      const alt = btn.dataset.alt || '';
      if (src) openLightbox(src, alt);
    });
  });

  document.getElementById('lb-close')?.addEventListener('click', () => lb.close());

  document.getElementById('lb-backdrop')?.addEventListener('click', e => {
    if (e.target === e.currentTarget) lb.close();
  });
</script>

<script>
  const eiForm = document.getElementById('ei-form') as HTMLFormElement | null;
  const eiStatus = document.getElementById('ei-status');
  const eiSubmit = document.getElementById('ei-submit') as HTMLButtonElement | null;

  eiForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!eiForm || !eiSubmit || !eiStatus) return;

    const data = {
      name: (eiForm.elements.namedItem('name') as HTMLInputElement).value.trim(),
      email: (eiForm.elements.namedItem('email') as HTMLInputElement).value.trim(),
      phone: (eiForm.elements.namedItem('phone') as HTMLInputElement).value.trim(),
      eventType: (eiForm.elements.namedItem('eventType') as HTMLSelectElement).value,
      eventDate: (eiForm.elements.namedItem('eventDate') as HTMLInputElement).value,
      guestCount: (eiForm.elements.namedItem('guestCount') as HTMLInputElement).value,
      message: (eiForm.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
    };

    eiSubmit.disabled = true;
    eiSubmit.textContent = 'Sending…';
    eiStatus.className = 'hidden text-[0.85rem] font-medium px-4 py-3';

    try {
      const res = await fetch('/api/event-inquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (json.success) {
        eiStatus.textContent = 'Thanks — we will get back to you shortly.';
        eiStatus.className = 'text-[0.85rem] font-medium px-4 py-3 bg-[#F0FAF4] text-ab-green border border-ab-green/20';
        eiForm.reset();
      } else {
        throw new Error(json.error || 'Error');
      }
    } catch {
      eiStatus.textContent = 'Something went wrong — email us directly at info@ab.dk.';
      eiStatus.className = 'text-[0.85rem] font-medium px-4 py-3 bg-[#FFF0F0] text-red-600 border border-red-200';
    } finally {
      eiSubmit.disabled = false;
      eiSubmit.textContent = 'Send inquiry';
    }
  });
</script>
