---
import Base from '@/layouts/Base.astro';
import Img from '@/components/Img.astro';
import heroImage from '@/assets/images/IMG_7926.jpeg';
import { principalPartners, networkPartners } from '@/data/partners';
---

<Base
  locale="en"
  title="Partners | Akademisk Boldklub Sponsorship Network"
  description="Meet the sponsors and partners supporting Akademisk Boldklub, from principal partners to the wider AB partner network."
  ogTitle="AB's Partner Network"
  ogDescription="Discover the brands partnering with Akademisk Boldklub, and how to join the AB partner network."
>

  <!-- Hero -->
  <div class="relative overflow-hidden h-[clamp(260px,36vw,420px)]">
    <Img
      src={heroImage}
      alt="Partner boards at Gladsaxe Stadium"
      class="absolute inset-0 w-full h-full object-cover object-center brightness-[0.5] saturate-[0.6]"
    />
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.55)_0%,rgba(0,0,0,0.1)_70%)]"></div>
    <div class="relative h-full flex flex-col justify-end px-8 lg:px-16 pb-12 max-w-7xl mx-auto w-full">
      <h1 class="font-black text-white text-[clamp(3rem,9vw,7rem)] tracking-[-0.04em] leading-[0.9]">
        Partners
      </h1>
    </div>
  </div>

  <!-- Intro -->
  <div class="w-full bg-ab-black px-8 lg:px-20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-black text-white text-[clamp(1.5rem,3vw,2.25rem)] tracking-[-0.03em] mb-5 max-w-[24ch]">
        Become part of something bigger than football
      </h2>
      <div class="space-y-4 text-surface-muted text-[1.0625rem] leading-[1.7] w-full">
        <p>
          At AB, partnership is more than signage in the stadium. It's an
          opportunity to connect with a passionate community, support the
          development of modern, attacking football, and help shape the
          future of one of Denmark's most historic clubs.
        </p>
        <p>
          Whether you're a local business, a global brand, or an innovative
          startup, we work with partners to create meaningful experiences,
          authentic storytelling, and build long-term value on and off the
          pitch.
        </p>
      </div>
      <p class="font-black text-ab-neon text-[1rem] tracking-[-0.01em] mt-6">
        Join the team. Let's build the future together.
      </p>
    </div>
  </div>

  <!-- Principal partners -->
  <section class="bg-white py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="inline-flex items-center mb-6 bg-ab-beige rounded-full py-[7px] px-[18px]">
        <span class="font-black text-[0.75rem] text-[#111] tracking-[0.1em] uppercase">Principal Partners</span>
      </div>
      <h2 class="font-black text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] text-ab-black mb-4">Our principal partners</h2>
      <p class="text-[#444] text-[1.0625rem] leading-[1.75] max-w-[60ch] mb-14">
        These companies are most closely tied to AB 1889 and contribute directly to the club's sporting and commercial development.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {principalPartners.map((p) => (
          <a
            href={`/en/partners/${p.slug}`}
            class="group relative flex flex-col bg-white border border-gray-100 rounded-lg overflow-hidden hover:border-ab-green/50 hover:shadow-[0_4px_20px_color-mix(in_srgb,var(--ab-green)_10%,transparent)] transition-all">
            <div class="flex items-center justify-center px-6 py-10 flex-1">
              <Img
                src={p.logo}
                alt={p.name}
                class:list={['object-contain object-center', p.logoSize ?? 'max-h-16 max-w-full']}
                loading="lazy"
              />
            </div>
            <div class="flex items-center justify-between px-4 py-3 border-t border-gray-100 bg-[#FAFAFA]">
              <span class="font-black text-[0.72rem] text-[#555] tracking-[-0.01em] truncate pr-2">{p.name}</span>
              <svg class="w-3.5 h-3.5 text-[#CCC] group-hover:text-ab-green transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AB Partner network -->
  <section class="bg-surface-base py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="inline-flex items-center mb-6 border border-ab-green/40 rounded-full py-[7px] px-[18px]">
        <span class="font-black text-[0.75rem] text-surface-muted tracking-[0.1em] uppercase">AB Partner</span>
      </div>
      <h2 class="font-black text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] text-white mb-4">The AB Partner network</h2>
      <p class="text-surface-muted text-[1.0625rem] leading-[1.75] max-w-[60ch] mb-14">
        A strong network of local and national companies that have supported AB 1889 year after year — spanning sport, health, advisory, and hospitality.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {networkPartners.map((p) => (
          <a
            href={`/en/partners/${p.slug}`}
            class="group relative flex flex-col bg-white border border-surface-border rounded-[4px] overflow-hidden hover:border-ab-green/60 hover:shadow-[0_4px_20px_color-mix(in_srgb,var(--ab-green)_12%,transparent)] transition-all">
            <div class="flex items-center justify-center px-5 py-7 min-h-[96px]">
              <Img
                src={p.logo}
                alt={p.name}
                class="max-h-14 max-w-full object-contain"
                loading="lazy"
              />
            </div>
            <div class="flex items-center justify-between px-3.5 py-2.5 border-t border-[#f0f0f0]">
              <span class="font-black text-[0.68rem] text-[#555] tracking-[-0.01em] truncate pr-1.5 leading-tight">{p.name}</span>
              <svg class="w-3 h-3 text-[#CCC] group-hover:text-ab-green transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
