---
import Base from '@/layouts/Base.astro';
import { fetchABEvents } from '@/lib/si/client';
import StandingsWidget from '@/components/StandingsWidget.astro';
export const prerender = false;

const locale = 'en';

let events: any[] = [];
try {
  events = await fetchABEvents({ locale, limit: 30 });
} catch { /* SI API unavailable */ }

const now = new Date();
const upcoming = events.filter((e: any) => e.statusType !== 'finished' && new Date(e.startDate) >= now);
const results = events.filter((e: any) => e.statusType === 'finished');

function fmtDay(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { weekday: 'long' });
}
function fmtMonthDay(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { month: 'long', day: 'numeric' });
}
function fmtTime(d: string) {
  return new Date(d).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}
---

<Base locale={locale} title="Matches | Akademisk Boldklub">
  <!-- Hero -->
  <div class="relative w-full">
    <img
      src="/images/matches-header-bg.png"
      alt="AB 1889 Matches"
      class="w-full h-auto block"
      loading="eager"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 55%, transparent 100%);"></div>
    <div class="absolute inset-0 flex items-end px-8 lg:px-16 pb-10">
      <h1 class="font-black text-white leading-none" style="font-size:clamp(3.5rem,10vw,8rem); letter-spacing:-0.04em; text-transform:none;">Matches</h1>
    </div>
  </div>

  <!-- Tab bar -->
  <div style="background:#fff; border-bottom:1px solid #E5E7EB;">
    <div class="max-w-7xl mx-auto px-8 flex items-center justify-between" style="height:56px;">
      <div class="flex items-center gap-2">
        <a href="/en/kampe" class="font-black text-sm px-4 py-1.5 rounded-full" style="background:#D3BC8D; color:#006A52; text-decoration:none; letter-spacing:-0.02em;">Upcoming</a>
        <a href="/en/kampe?all=1" class="font-black text-sm px-4 py-1.5" style="color:#555; text-decoration:none; letter-spacing:-0.02em;">All</a>
      </div>
      <div class="hidden md:flex items-center gap-6">
        <a href="/en/om/stadion" class="text-sm font-bold" style="color:#555; text-decoration:none; letter-spacing:-0.02em;">Stadium Info</a>
        <a href="/en/kampe#results" class="text-sm font-bold" style="color:#555; text-decoration:none; letter-spacing:-0.02em;">Results</a>
        <a href="/en/kampe#standings" class="text-sm font-bold" style="color:#555; text-decoration:none; letter-spacing:-0.02em;">Standings</a>
      </div>
    </div>
  </div>

  <!-- CampoBet Division Banner -->
  <div style="background:#006A52; padding:0;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex items-center justify-between" style="height:56px;">
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect width="20" height="20" rx="4" fill="rgba(255,255,255,0.15)"/>
            <path d="M4 6h12M4 10h12M4 14h8" stroke="#D3BC8D" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="font-black text-white text-sm" style="letter-spacing:-0.02em;">CampoBet Division</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-xs hidden sm:block" style="color:rgba(255,255,255,0.7);">Add AB's schedule to your calendar</span>
          <button class="font-black text-sm px-4 py-1.5 rounded" style="background:#00FF1F; color:#006A52; border:none; cursor:pointer; letter-spacing:-0.02em;">Sync</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Match list -->
  <div style="background:#F5F5F5; padding:32px 0 48px;">
    <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col gap-3">
      {upcoming.length === 0 && (
        <div class="text-center py-12 text-sm" style="color:#777;">No upcoming fixtures found.</div>
      )}
      {upcoming.map((event: any) => {
        const isABHome = event.homeId === 9805;
        const opponent = isABHome ? event.awayName : event.homeName;
        const venue = event.venue ?? 'Gladsaxe Stadium';
        const round = event.round ? `Round ${event.round}` : '';
        return (
          <div style="background:#fff; border:1px solid #E5E7EB; border-radius:4px; overflow:hidden;">
            <div class="px-5 py-1.5" style="background:#F0F4F0; border-bottom:1px solid #E5E7EB;">
              <span class="text-xs font-bold" style="color:#006A52; letter-spacing:0.04em;">Regular Season</span>
            </div>
            <div class="grid items-center gap-4 px-5 py-4" style="grid-template-columns:140px 1fr auto;">
              <!-- Date -->
              <div>
                <p class="font-black text-xs capitalize" style="color:#006A52; letter-spacing:-0.01em;">{fmtDay(event.startDate)}</p>
                <p class="font-black" style="font-size:1.5rem; line-height:1.1; letter-spacing:-0.04em; color:#111;">{fmtMonthDay(event.startDate)}</p>
                <p class="text-sm font-bold mt-0.5" style="color:#555;">{fmtTime(event.startDate)}</p>
              </div>

              <!-- Teams -->
              <div class="flex items-center justify-center gap-4">
                <div class="flex flex-col items-center gap-1.5">
                  <img src="/images/ab-crest.svg" alt="AB" width="44" height="44" class="object-contain" />
                  <span class="text-xs font-bold" style="color:#111;">AB</span>
                </div>
                <div class="text-center">
                  {round && <p class="text-xs mb-1" style="color:#999;">{round}</p>}
                  <span class="font-black text-lg" style="color:#111; letter-spacing:-0.04em;">VS</span>
                  <p class="text-xs mt-1" style="color:#777;">{venue}</p>
                </div>
                <div class="flex flex-col items-center gap-1.5">
                  <div class="w-11 h-11 rounded-full flex items-center justify-center" style="background:#F5F5F5; border:1px solid #E5E7EB;">
                    <span class="text-xs font-bold" style="color:#555;">{opponent?.slice(0,3).toUpperCase()}</span>
                  </div>
                  <span class="text-xs font-bold" style="color:#111;">{opponent}</span>
                </div>
              </div>

              <!-- Tickets CTA -->
              <a
                href="https://billet.ab.dk"
                target="_blank"
                rel="noreferrer"
                class="flex items-center gap-2 font-black text-sm px-4 py-2.5 whitespace-nowrap"
                style="background:#00FF1F; color:#006A52; text-decoration:none; border-radius:4px; letter-spacing:-0.02em;"
              >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <rect x="1" y="4" width="12" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M10 4v-.5a2 2 0 0 0-4 0V4" stroke="currentColor" stroke-width="1.2"/>
                </svg>
                Tickets
              </a>
            </div>
            <!-- Watch row -->
            <div class="px-5 py-2.5 flex items-center gap-4" style="border-top:1px solid #F0F0F0;">
              <span class="text-xs" style="color:#999;">Watch on</span>
              <a href="https://abtv.ab.dk" target="_blank" rel="noreferrer" class="text-xs font-bold" style="color:#006A52; text-decoration:none;">Online</a>
              <a href="https://abtv.ab.dk" target="_blank" rel="noreferrer" class="text-xs font-bold" style="color:#006A52; text-decoration:none;">ABTV</a>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Results section -->
  {results.length > 0 && (
    <div id="results" style="background:#fff; padding:40px 0 48px;">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <h2 class="font-black mb-6" style="font-size:clamp(1.75rem,4vw,2.5rem); letter-spacing:-0.04em; color:#111;">Results</h2>
        <div class="flex flex-col gap-2">
          {results.slice(0, 10).map((event: any) => {
            const isABHome = event.homeId === 9805;
            const opponent = isABHome ? event.awayName : event.homeName;
            return (
              <div class="flex items-center justify-between px-5 py-3 gap-4" style="background:#F9FAFB; border:1px solid #E5E7EB; border-radius:4px;">
                <span class="text-sm" style="color:#777; min-width:120px;">{new Date(event.startDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}</span>
                <div class="flex items-center gap-3 flex-1">
                  <span class="text-sm font-black" style="color:#006A52;">AB</span>
                  <span class="text-sm font-black tabular-nums px-2 py-0.5" style="background:#F0F4F0; color:#006A52;">{event.score ?? '—'}</span>
                  <span class="text-sm font-bold" style="color:#111;">{opponent}</span>
                </div>
                <span class="text-xs uppercase" style="color:#999; letter-spacing:0.08em;">FT</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- Standings section -->
  <div id="standings" style="background:#EBEBEB; padding:40px 0 48px;">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <h2 class="font-black mb-6" style="font-size:clamp(1.75rem,4vw,2.5rem); letter-spacing:-0.04em; color:#111;">Standings</h2>
      <div style="max-width:680px;">
        <StandingsWidget locale="en" showHeader={false} />
      </div>
    </div>
  </div>

</Base>
