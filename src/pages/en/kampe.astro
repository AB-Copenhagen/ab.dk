---
import Base from '@/layouts/Base.astro';
import FixturesWidget from '@/components/FixturesWidget.astro';
import StandingsWidget from '@/components/StandingsWidget.astro';
export const prerender = false;
---

<Base locale="en" title="Fixtures | Akademisk Boldklub">
  <div style="background:#fff">
    <div class="border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-5 md:px-12">
        <div class="py-14 md:py-20">
          <p class="text-xs font-bold uppercase mb-3" style="color:#006A52;letter-spacing:0.2em">Season 2024/25</p>
          <h1 class="font-black" style="font-size:clamp(3rem,8vw,5rem);letter-spacing:-0.03em;line-height:0.95;color:#111">Fixtures</h1>
          <div class="mt-5 h-0.5 w-12" style="background:#006A52"></div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14">
      <div class="grid lg:grid-cols-[1fr_320px] gap-8 items-start">
        <section>
          <h2 class="text-[0.6rem] font-bold uppercase mb-5" style="color:#9CA3AF;letter-spacing:0.18em">
            Fixtures &amp; Results
          </h2>
          <div style="background:#060806;border:1px solid #152214">
            <FixturesWidget locale="en" limit={30} />
          </div>
        </section>

        <section>
          <h2 class="text-[0.6rem] font-bold uppercase mb-5" style="color:#9CA3AF;letter-spacing:0.18em">
            1st Division — Table
          </h2>
          <div style="background:#060806;border:1px solid #152214">
            <StandingsWidget locale="en" />
          </div>
        </section>
      </div>
    </div>
  </div>
</Base>
