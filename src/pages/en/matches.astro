---
import Base from '@/layouts/Base.astro';
import MatchList, { type MatchListFilter } from '@/components/MatchList.astro';
import StandingsWidget from '@/components/StandingsWidget.astro';
import { fetchABEvents } from '@/lib/si/client';
import { abConfig } from '@/lib/config/ab';
export const prerender = false;

const locale = 'en';

let events: Awaited<ReturnType<typeof fetchABEvents>> = [];
try {
  events = await fetchABEvents({ locale, limit: 100 });
} catch { /* SI API unavailable */ }

const now = new Date();
const filter = (Astro.url.searchParams.get('filter') ?? 'upcoming') as MatchListFilter;
const upcoming = events.filter((e) => new Date(e.startDate) >= now);
const finished = events.filter((e) => new Date(e.startDate) < now).reverse();

const displayEvents =
  filter === 'home'    ? upcoming.filter((e) => e.homeId === abConfig.teamId) :
  filter === 'away'    ? upcoming.filter((e) => e.homeId !== abConfig.teamId) :
  filter === 'results' ? finished :
  upcoming;
---

<Base locale={locale} title="Matches | Akademisk Boldklub">
  <!-- Hero -->
  <div class="relative w-full">
    <img
      src="/images/matches-header-bg.png"
      alt="AB 1889 Matches"
      class="w-full h-auto block"
      loading="eager"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 55%, transparent 100%);"></div>
    <div class="absolute inset-0 flex items-end px-8 lg:px-16 pb-10">
      <h1 class="font-black text-white leading-none tracking-[-0.04em] normal-case" style="font-size:clamp(3.5rem,10vw,8rem);">Matches</h1>
    </div>
  </div>

  <!-- Tab bar -->
  <div class="bg-white border-b border-[#E5E7EB]">
    <div class="max-w-7xl mx-auto px-8 flex items-center justify-between h-[56px]">
      <div class="flex items-center gap-1">
        {[
          { label: 'Upcoming', value: 'upcoming', href: '/en/matches' },
          { label: 'Home',     value: 'home',     href: '/en/matches?filter=home' },
          { label: 'Away',     value: 'away',     href: '/en/matches?filter=away' },
          { label: 'Results',  value: 'results',  href: '/en/matches?filter=results' },
        ].map(tab => (
          <a
            href={tab.href}
            class="font-black text-sm px-4 py-1.5 rounded-full"
            style={`text-decoration:none; letter-spacing:-0.02em; ${filter === tab.value ? 'background:#D3BC8D; color:#006A52;' : 'color:#555;'}`}
          >{tab.label}</a>
        ))}
      </div>
      <div class="hidden md:flex items-center gap-3">
        <a href="https://billet.ab.dk/" target="_blank" rel="noreferrer" class="btn btn-sm btn-green">Buy Tickets</a>
        <a href="https://billet.ab.dk/event/seasonal-ticket-pass-26-27-copy-u8hk6v" target="_blank" rel="noreferrer" class="btn btn-sm bg-ab-beige text-ab-green">Buy Season Card</a>
      </div>
    </div>
  </div>

  <!-- CampoBet Division Banner -->
  <div class="bg-ab-green p-0">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex items-center justify-between h-[56px]">
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect width="20" height="20" rx="4" fill="rgba(255,255,255,0.15)"/>
            <path d="M4 6h12M4 10h12M4 14h8" stroke="#D3BC8D" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="font-black text-white text-sm tracking-[-0.02em]">Betinia Liga</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-xs hidden sm:block text-white/70">Add AB's schedule to your calendar</span>
          <button class="font-black text-sm px-4 py-1.5 rounded bg-ab-neon text-ab-green border-0 cursor-pointer tracking-[-0.02em]">Sync</button>
        </div>
      </div>
    </div>
  </div>

  <MatchList locale={locale} events={displayEvents} filter={filter} />

  <!-- Standings section -->
  <div id="standings" class="bg-[#EBEBEB] pt-[40px] pb-[48px]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <h2 class="font-black mb-6 tracking-[-0.04em] text-[#111]" style="font-size:clamp(1.75rem,4vw,2.5rem);">Standings</h2>
      <div>
        <StandingsWidget locale="en" showHeader={false} />
      </div>
    </div>
  </div>

</Base>
