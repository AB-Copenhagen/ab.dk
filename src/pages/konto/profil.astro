---
import Base from '@/layouts/Base.astro';

export const prerender = false;

// Middleware validates the session and populates Astro.locals.user for this route —
// if we reach here without a user, something's off, so fall back to a login redirect.
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/konto?redirect=/konto/profil');
}
const { name, email, picture } = user;

const DESCOPE_PROJECT_ID = import.meta.env.DESCOPE_PROJECT_ID ?? '';

const quickLinks = [
  { label: 'Se ABTV', desc: 'Kamphøjdepunkter og eksklusivt videoindhold', href: '/abtv' },
  { label: 'MyAB-medlemskab', desc: 'Administrer dine MyAB-fordele', href: '/myab' },
  { label: 'Køb billetter', desc: 'Kampbilletter via Vivenu', href: 'https://billet.ab.dk/', external: true },
  { label: 'Mine ordrer', desc: 'Se din ordrehistorik i AB Store på Shopify', href: 'https://shop.ab.dk/account', external: true },
];
---

<Base locale="da" title="Min profil | AB 1889">
  <main class="min-h-screen px-4 py-24 bg-[#060806]">
    <div class="max-w-2xl mx-auto">

      {/* Header */}
      <div class="flex items-center gap-4 mb-10">
        {picture ? (
          <img
            src={picture}
            alt={name || 'Profil'}
            class="w-14 h-14 rounded-full object-cover"
          />
        ) : (
          <div
            class="w-14 h-14 rounded-full flex items-center justify-center text-white font-black text-lg bg-ab-green"
          >
            {(name?.charAt(0) || email?.charAt(0) || '?').toUpperCase()}
          </div>
        )}
        <div>
          <p
            class="text-xs font-bold uppercase tracking-widest mb-0.5"
            style="color:#D6A02A;letter-spacing:0.14em"
          >
            Akademisk Boldklub
          </p>
          <h1 class="text-xl font-black text-white">{name || email || 'Min profil'}</h1>
        </div>
      </div>

      {/* Quick links */}
      <div class="border overflow-hidden mb-8" style="border-color:#152214">
        <div class="px-5 py-3 border-b text-xs font-bold uppercase tracking-widest" style="border-color:#152214;color:#D6A02A;letter-spacing:0.14em">
          Genveje
        </div>
        <div class="divide-y" style="background:#0D1A10;border-color:#152214">
          {quickLinks.map((link) => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noreferrer' : undefined}
              class="flex items-center justify-between gap-4 px-5 py-4 no-underline hover:bg-white/5 transition-colors"
              style="border-color:#152214"
            >
              <div>
                <p class="font-black text-white text-sm">{link.label}</p>
                <p class="text-xs mt-0.5" style="color:#8AA898">{link.desc}</p>
              </div>
              <span style="color:#8AA898">→</span>
            </a>
          ))}
        </div>
      </div>

      {/* Balance & Rewards (rise.ai) */}
      <div class="border overflow-hidden mb-8" style="border-color:#152214">
        <div class="px-5 py-3 border-b text-xs font-bold uppercase tracking-widest" style="border-color:#152214;color:#D6A02A;letter-spacing:0.14em">
          Saldo &amp; Fordele
        </div>
        <div class="px-5 py-8 text-center text-sm" style="background:#0D1A10;color:#8AA898">
          Kommer snart.
        </div>
      </div>

      {/* Profile management widget */}
      <div class="border overflow-hidden" style="border-color:#152214">
        <div
          class="px-5 py-3 border-b text-xs font-bold uppercase tracking-widest"
          style="border-color:#152214;color:#D6A02A;letter-spacing:0.14em"
        >
          Kontoadministration
        </div>
        <div class="p-2" style="background:#0D1A10">
          {DESCOPE_PROJECT_ID ? (
            <div id="descope-profile-container"></div>
          ) : (
            <div class="p-8 text-center text-sm" style="color:#8AA898">
              Profilstyring kræver konfiguration.
            </div>
          )}
        </div>
      </div>

      {/* Log out */}
      <div class="mt-8">
        <button
          id="logout-btn"
          class="text-xs font-bold uppercase"
          style="color:#8AA898;letter-spacing:0.12em"
        >
          Log ud
        </button>
      </div>

    </div>
  </main>

  {DESCOPE_PROJECT_ID && (
    <script is:inline type="module" define:vars={{ DESCOPE_PROJECT_ID }}>
      import('https://unpkg.com/@descope/web-component@3/dist/index.js').then(() => {
        const el = document.createElement('descope-user-profile');
        el.setAttribute('project-id', DESCOPE_PROJECT_ID);
        el.setAttribute('widget-id', 'user-profile-widget');
        document.getElementById('descope-profile-container')?.appendChild(el);
      });

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        document.cookie = 'DS=; Max-Age=0; path=/';
        location.href = '/konto';
      });
    </script>
  )}

  {!DESCOPE_PROJECT_ID && (
    <script>
      document.getElementById('logout-btn')?.addEventListener('click', () => {
        document.cookie = 'DS=; Max-Age=0; path=/';
        location.href = '/konto';
      });
    </script>
  )}
</Base>
