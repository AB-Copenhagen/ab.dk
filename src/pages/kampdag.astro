---
import Base from '@/layouts/Base.astro';
export const prerender = false;

const SECTIONS = [
  { id: 'kom-hertil',      label: 'Kom hertil' },
  { id: 'mad-drikke',      label: 'Mad & drikke' },
  { id: 'billetter',       label: 'Billetter' },
  { id: 'stadioninfo',     label: 'Stadioninfo' },
  { id: 'tilgaengelighed', label: 'Tilgængelighed' },
  { id: 'regler',          label: 'Regler' },
  { id: 'presse',          label: 'Presse' },
];

const TICKET_PRICES = [
  { type: 'Almen adgang',                                     price: 'DKK 110 + gebyrer' },
  { type: 'Nedsat (Studerende / Pensionister / Under 17 år)', price: 'DKK 60 + gebyrer' },
  { type: 'Sæsonkort — Almen',                                price: 'DKK 1.600 + gebyrer' },
  { type: 'Sæsonkort — Nedsat',                               price: 'DKK 800 + gebyrer' },
  { type: 'Billetter ved kassen (tillæg)',                    price: '+ DKK 40' },
];

const PROHIBITED_ITEMS = [
  'Kufferter, computertasker, attachémapper, rygsække, store tasker, kameratui, kølebokse, termokander eller iscontainere',
  'Skydevåben eller våben af enhver art',
  'Flasker, dåser, kølebokse og beholdere',
  'Støjmaskiner, plastikhorn, lufthorn, fløjter, trommer eller musikinstrumenter',
  'Fyrværkeri, blus, røgbomber eller lignende',
  'Kæledyr eller dyr (undtagen certificerede servicehunde)',
  'Selfie-sticks, professionelt kameraudstyr, stativer, laserpointere',
  'Vandpistoler, legetøjsvåben, sæbebobler',
  'Strandbolde, frisbees, balloner, skateboards, hoverboards, rulleskøjter',
  'Streamers eller konfetti',
  'Klapvogne, der ikke kan stå under sæderne',
  'Fuldt oppustede fodbolde (skal tømmes for luft inden indgang)',
];
---

<Base locale="da" title="Kampdag | Akademisk Boldklub">

  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <div class="relative w-full">
    <img src="/api/media/uploads/bring_the_kids_along_for_a_fun_football_experience_gladsaxe_stadium_0b4d4095f3.jpg" alt="AB-fans jubler på Gladsaxe Stadion"
         class="block h-auto w-full max-h-[480px] object-cover object-top" loading="eager" />
    <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);"></div>
    <div class="absolute inset-0 flex flex-col justify-end px-8 pb-10 lg:px-16">
      <p class="mb-2 text-xs font-black tracking-widest text-ab-beige">GLADSAXE STADION</p>
      <h1 class="font-black leading-none normal-case text-white tracking-[-0.04em]" style="font-size:clamp(3.5rem,10vw,8rem);">Kampdag</h1>
    </div>
  </div>

  <div class="bg-white">
    <div class="mx-auto max-w-7xl px-5 md:px-10 lg:grid lg:grid-cols-[230px_minmax(0,1fr)] lg:gap-14">

      <!-- ── Left sticky subnav (desktop) ───────────────────────────── -->
      <aside class="hidden lg:block">
        <nav class="sticky top-24 py-12">
          <p class="mb-4 text-xs font-black tracking-widest text-neutral-400">KAMPDAGSGUIDE</p>
          <ul class="flex flex-col">
            {SECTIONS.map(s => (
              <li>
                <a href={`#${s.id}`} data-matchday-link
                   class="matchday-link block py-2 pl-4 text-sm font-black tracking-tight">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- ── Content column ─────────────────────────────────────────── -->
      <div class="pb-20 pt-10 lg:pt-12">

        <!-- Mobile quick links -->
        <nav class="mb-10 lg:hidden">
          <p class="mb-3 text-xs font-black tracking-widest text-neutral-400">KAMPDAGSGUIDE</p>
          <div class="grid grid-cols-2 gap-2">
            {SECTIONS.map(s => (
              <a href={`#${s.id}`}
                 class="rounded bg-neutral-100 px-4 py-2.5 text-sm font-black tracking-tight text-ab-green">
                {s.label}
              </a>
            ))}
          </div>
        </nav>

        <!-- ── Kom hertil ───────────────────────────────────────────── -->
        <section id="kom-hertil" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Kom til Gladsaxe</h2>
          </div>

          <div class="mb-7 rounded bg-ab-green/5 p-5">
            <p class="mb-0.5 text-base font-black text-ab-green">Gladsaxe Stadion</p>
            <p class="text-body text-neutral-600">Gladsaxevej 202, 2860 Søborg, Danmark</p>
            <a href="https://maps.google.com/?q=Gladsaxevej+202,+2860+Søborg" target="_blank" rel="noreferrer"
               class="mt-3 inline-block rounded bg-ab-green px-3 py-1.5 text-xs font-black text-white">
              Åbn i Google Maps ↗
            </a>
          </div>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div>
              <h3 class="mb-3 text-base font-black text-neutral-900">Offentlig transport</h3>
              <ul class="space-y-3 text-body leading-[1.75] text-neutral-700">
                <li><strong>Bus:</strong> Linjerne 4A, 30E, 68 og 164 kører til døren. Stå af ved stoppestedet <em>Høje Gladsaxe</em>.</li>
                <li><strong>S-tog:</strong> Nærmeste stationer er Buddinge og Kildebakke. Derfra kan du gå 10–15 min eller tage bus direkte til Gladsaxevej 202. Stå af ved <em>Høje Gladsaxe</em>.</li>
              </ul>
              <div class="mt-4 flex gap-2">
                <a href="https://www.rejseplanen.dk/" target="_blank" rel="noreferrer"
                   class="rounded bg-ab-green/5 px-3 py-1.5 text-xs font-black text-ab-green">Busplan ↗</a>
                <a href="https://www.dsb.dk/" target="_blank" rel="noreferrer"
                   class="rounded bg-ab-green/5 px-3 py-1.5 text-xs font-black text-ab-green">S-tog ↗</a>
              </div>
            </div>
            <div>
              <h3 class="mb-3 text-base font-black text-neutral-900">Parkering</h3>
              <ul class="space-y-3 text-body leading-[1.75] text-neutral-700">
                <li><strong>Generel:</strong> Stor, åben parkeringsplads direkte ved Gladsaxevej. Yderligere pladser ved Høje Gladsaxe, Gladsaxe Skøjtehal og Gladsaxe Svømmehal på Vandtårnsvej.</li>
                <li><strong>Handicap:</strong> 2 dedikerede handicappladser på Gladsaxevej ved tennisbanerne, ca. 50–100 m fra hovedtribunen. Gyldigt handicapparkeringskort skal vises tydeligt i forruden.</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- ── Mad & drikke ─────────────────────────────────────────── -->
        <section id="mad-drikke" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Mad & drikke</h2>
          </div>

          <p class="mb-6 text-body leading-[1.75] text-neutral-700">
            Hos AB går vi op i, hvad vi serverer — al mad på Gladsaxe Stadion er <strong>100% økologisk</strong>. Vi tilbyder et bredt udvalg med fokus på kvalitet og god smag, herunder sunde måltider samt veganske og glutenfrie muligheder. I vores kaffebar forkæler vi vores gæster med økologisk kaffe og bagværk fra lokale bagerier.
          </p>
          <div class="mb-6 rounded border-l-[3px] border-ab-beige bg-ab-green/5 p-5">
            <p class="mb-1 text-base font-black text-ab-green">The Mad Owl Pub</p>
            <p class="text-body leading-[1.75] text-neutral-600">Øl fra hele verden — alkoholiske og alkoholfrie — samt gode drinks. På første sal. Åbner <strong>2 timer før kampstart</strong>.</p>
          </div>
          <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="rounded bg-neutral-100 p-5">
              <p class="mb-1 text-xs font-black tracking-wider text-ab-green">MADSALG & KAFFEBAR</p>
              <p class="text-body text-neutral-700">Åbner <strong>1,5 time</strong> før kampstart</p>
            </div>
            <div class="rounded bg-neutral-100 p-5">
              <p class="mb-1 text-xs font-black tracking-wider text-ab-green">THE MAD OWL PUB</p>
              <p class="text-body text-neutral-700">Åbner <strong>2 timer</strong> før kampstart</p>
            </div>
          </div>
          <p class="rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-neutral-500">
            Det er ikke tilladt at medbringe mad eller drikke udefra, medmindre det er af medicinske årsager.
          </p>
        </section>

        <!-- ── Billetter ────────────────────────────────────────────── -->
        <section id="billetter" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2z"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Billetter</h2>
          </div>

          <h3 class="mb-3 text-base font-black text-neutral-900">Billetpriser</h3>
          <div class="mb-7 overflow-x-auto">
            <table class="w-full border-collapse text-base">
              <thead>
                <tr class="bg-ab-green text-white">
                  <th class="px-4 py-2.5 text-left font-black">Type</th>
                  <th class="px-4 py-2.5 text-right font-black">Pris</th>
                </tr>
              </thead>
              <tbody>
                {TICKET_PRICES.map(row => (
                  <tr class="border-b border-neutral-200 even:bg-ab-green/[0.03]">
                    <td class="px-4 py-3 text-neutral-700">{row.type}</td>
                    <td class="px-4 py-3 text-right font-black tabular-nums text-ab-green">{row.price}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <h3 class="mb-3 text-base font-black text-neutral-900">Mobilbilletter</h3>
          <p class="mb-4 text-body leading-[1.75] text-neutral-700">
            Gladsaxe Stadion er et <strong>mobilbilletsted</strong>. Tilgå dine billetter ved at logge ind på MyAB-appen med den e-mailadresse, der er tilknyttet dine billetter. Har du problemer med login, kan du nulstille din adgangskode via den e-mail, du brugte ved købet.
          </p>
          <p class="mb-6 text-body leading-[1.75] text-neutral-700">
            Alle billetter er underlagt billetvilkår og regler samt Fan Code of Conduct. Er du tilknyttet gæsteholdet, bedes du købe billet til gæsteafsnittet.
          </p>
          <div class="mb-7 flex flex-wrap gap-3">
            <a class="vivenu-btn rounded bg-ab-neon px-5 py-2.5 text-sm font-black tracking-tight text-ab-green"
               href="https://billet.ab.dk/?useEmbed=true">
              Køb billetter
            </a>
            <a class="vivenu-btn rounded bg-ab-beige px-5 py-2.5 text-sm font-black tracking-tight text-ab-green"
               href="https://billet.ab.dk/event/seasonal-ticket-pass-26-27-copy-u8hk6v?useEmbed=true">
              Sæsonkort
            </a>
          </div>
          <div class="rounded bg-ab-green/5 p-5">
            <p class="mb-1 text-base font-black text-ab-green">Gæsteservice</p>
            <p class="text-body leading-[1.75] text-neutral-600">
              Besøg Gæsteservicevinduet direkte ved <strong>Indgang B</strong>. Vi anbefaler, at du tilføjer dine billetter til Apple Wallet eller Google Pay, inden du ankommer, for at undgå problemer med mobilforbindelsen ved indgangen.
            </p>
            <p class="mt-2 text-body text-neutral-600">
              Spørgsmål? Skriv til <a href="mailto:info@ab.dk" class="font-bold text-ab-green">info@ab.dk</a>
            </p>
          </div>
        </section>

        <!-- ── Stadioninfo ──────────────────────────────────────────── -->
        <section id="stadioninfo" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7 12 2"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Stadioninfo</h2>
          </div>

          <h3 class="mb-3 text-base font-black text-neutral-900">Taskepolitik</h3>
          <div class="mb-7 rounded bg-ab-green/5 p-5">
            <p class="text-body leading-[1.75] text-neutral-700">
              Tasker på højst <strong>14"×14"×6"</strong> er tilladt. Rygsække af enhver art eller tasker, der er større end dette, er ikke tilladt. Medicin- og babytasker er undtaget men vil blive gennemset.
            </p>
          </div>

          <h3 class="mb-3 text-base font-black text-neutral-900">Forbudte genstande</h3>
          <ul class="mb-6 grid grid-cols-1 gap-x-8 gap-y-2.5 text-body text-neutral-700 md:grid-cols-2">
            {PROHIBITED_ITEMS.map(item => (
              <li class="flex items-start gap-2 leading-relaxed">
                <span class="mt-0.5 shrink-0 text-red-400">✕</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-neutral-500">
            Forbudte genstande fundet ved indgangene skal afleveres i køretøjet eller smides ud — der er ingen opbevaring. Spørgsmål: <a href="mailto:info@ab.dk" class="font-bold text-ab-green">info@ab.dk</a>
          </p>
        </section>

        <!-- ── Tilgængelighed ───────────────────────────────────────── -->
        <section id="tilgaengelighed" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="4" r="1"/><path d="m18 19 1-7-6 1"/><path d="m5 8 3-3 5.5 3-2.36 3.5"/><path d="M4.24 14.5a5 5 0 0 0 6.88 6"/><path d="M13.76 17.5a5 5 0 0 0-6.88-6"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Tilgængelighed</h2>
          </div>

          <p class="mb-6 text-body leading-[1.75] text-neutral-700">
            Det er højt prioriteret hos Gladsaxe Stadion at imødekomme behovene hos alle gæster, herunder gæster med handicap og deres ledsagere. For hjælp, kontakt <a href="mailto:info@ab.dk" class="font-bold text-ab-green">info@ab.dk</a>.
          </p>
          <div class="space-y-4">
            <div class="rounded bg-ab-green/5 p-5">
              <p class="mb-1.5 text-base font-black text-ab-green">Kørestolspladser</p>
              <p class="text-body leading-[1.75] text-neutral-700">
                Kørestolsvenlige tilskuerpladser er placeret i den nye tribune (Tribune 3) med forhøjet udsigt over banen. Adgang via elevatoren ved <strong>indgang 4</strong>. Gæster i Knud Lundberg Lounge benytter elevatoren ved <strong>indgang 3</strong>.
              </p>
              <p class="mt-2 text-body leading-[1.75] text-neutral-700">
                Fuldt tilgængelige handicaptoiletter er placeret i begge ender af hovedtribunen. Mad og drikkevarer er tilgængelige via flade overflader. Elmotorkøretøjer er tilladt i gangfart.
              </p>
            </div>
            <div class="rounded bg-ab-green/5 p-5">
              <p class="mb-1.5 text-base font-black text-ab-green">Ledsagerkort</p>
              <p class="text-body leading-[1.75] text-neutral-700">
                Et gyldigt ledsagerkort udstedt af en autoriseret instans skal fremvises fysisk eller digitalt ved indgangene. Det er ikke nødvendigt ved onlinekøb af billetter.
              </p>
            </div>
            <p class="rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-neutral-500">
              Den kørestolstilgængelige infrastruktur med liftadgang er udelukkende placeret i hovedtribunen. Det er ikke muligt at sidde i gæsteafsnittet med kørestolsadgang.
            </p>
          </div>
        </section>

        <!-- ── Regler ───────────────────────────────────────────────── -->
        <section id="regler" class="mb-14 scroll-mt-28 border-b border-neutral-200 pb-14">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Regler & sikkerhed</h2>
          </div>

          <div class="space-y-4">
            <div class="rounded bg-ab-green/5 p-5">
              <p class="mb-1.5 text-base font-black text-ab-green">Gæstehold-fans</p>
              <p class="text-body leading-[1.75] text-neutral-700">
                AB ønsker at skabe en stadionoplevelse, hvor alle er velkomne. Det er fuldt ud tilladt at bære gæsteholdets merchandise i det neutrale afsnit og handicapafsnittet. Sikkerhedspersonalet forbeholder sig retten til at nægte adgang eller bortvise tilskuere, der overtræder adfærdskodekset.
              </p>
            </div>
            <div class="rounded bg-ab-green/5 p-5">
              <p class="mb-1.5 text-base font-black text-ab-green">Sikkerhed</p>
              <p class="text-body leading-[1.75] text-neutral-700">
                ABs autoriserede sikkerhedsleder er <strong>Bo Jørgensen</strong>. Kontakt ham på <a href="mailto:bjorgensen@ab.dk" class="font-bold text-ab-green">bjorgensen@ab.dk</a>.
              </p>
            </div>
          </div>
        </section>

        <!-- ── Presse ───────────────────────────────────────────────── -->
        <section id="presse" class="scroll-mt-28">
          <div class="mb-7 flex items-center gap-4">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-ab-green">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6z"/></svg>
            </span>
            <h2 class="text-2xl font-black tracking-tight text-neutral-900 lg:text-3xl">Presseadgang</h2>
          </div>

          <p class="mb-4 text-body leading-[1.75] text-neutral-700">
            Presserepræsentanter optages ved indgangen mod fremvisning af gyldigt pressekort. Holdopstillinger kan afhentes ved receptionen ca. 20 minutter før kampstart. Efter kampen er spillere og trænere tilgængelige til interviews via receptionen ved den nye tribune.
          </p>
          <p class="mb-6 text-body leading-[1.75] text-neutral-700">
            Kommercielle aktiviteter af enhver art på stadion kræver forudgående aftale med klubben, herunder salg af varer, dataindsamling eller billede/lyd til kommercielle formål.
          </p>
          <a href="mailto:press@ab.dk"
             class="inline-block rounded bg-ab-green px-5 py-2.5 text-sm font-black tracking-tight text-white">
            Kontakt presseteamet ↗
          </a>
        </section>

      </div>
    </div>
  </div>

  <style>
    .matchday-link {
      color: var(--color-neutral-400);
      border-left: 2px solid var(--color-neutral-200);
      transition:
        color 0.15s,
        border-color 0.15s;
    }
    .matchday-link:hover {
      color: var(--color-ab-green);
    }
    .matchday-link.is-active {
      color: var(--color-ab-green);
      border-left-color: var(--color-ab-neon);
    }
  </style>

  <script>
    const HEADER_OFFSET = 100;
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-matchday-link]'));
    const sections = links
      .map(l => document.querySelector<HTMLElement>(l.getAttribute('href') ?? ''))
      .filter((s): s is HTMLElement => s !== null);

    // ── Scrollspy ──
    const setActive = (id: string) => {
      links.forEach(l => l.classList.toggle('is-active', l.getAttribute('href') === `#${id}`));
    };

    const update = () => {
      let current = sections[0]?.id ?? '';
      for (const s of sections) {
        if (s.getBoundingClientRect().top <= HEADER_OFFSET + 40) current = s.id;
      }
      setActive(current);
    };

    document.addEventListener('scroll', update, { passive: true });
    update();

    // ── Eased smooth scroll for all in-page anchors ──
    const easeInOutCubic = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const smoothScrollTo = (targetY: number, duration = 650) => {
      const startY = window.scrollY;
      const diff = targetY - startY;
      let start: number | undefined;
      const step = (ts: number) => {
        start ??= ts;
        const p = Math.min((ts - start) / duration, 1);
        window.scrollTo(0, startY + diff * easeInOutCubic(p));
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const id = a.getAttribute('href')?.slice(1);
        const target = id ? document.getElementById(id) : null;
        if (!target) return;
        e.preventDefault();
        const y = target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
        if (reducedMotion.matches) window.scrollTo(0, y);
        else smoothScrollTo(y);
        history.pushState(null, '', `#${id}`);
      });
    });
  </script>

</Base>
