---
import AppScreenshotCarousel from '@/components/AppScreenshotCarousel.astro';
import Base from '@/layouts/Base.astro';

export const prerender = true;

interface Group {
  title: string;
  intro: string;
  items: string[];
}

const appShots = [
  { src: '/images/myab-app-shot-1-home.jpg', alt: 'MyAB-appens forside med kommende kamp og nyheder' },
  { src: '/images/myab-app-shot-2-wallet.jpg', alt: 'Billetter og medlemskort i MyAB Wallet' },
  { src: '/images/myab-app-shot-3-competitions.jpg', alt: 'Deltag i konkurrencer om billetter og præmier' },
  { src: '/images/myab-app-shot-4-matches.jpg', alt: "Se alle AB's kampe og køb billetter" },
  { src: '/images/myab-app-shot-5-tv.jpg', alt: 'Se highlights og livestream i MyAB' },
  { src: '/images/myab-app-shot-6-matchday.jpg', alt: 'Detaljeret kampinfo og stilling på kampdag' },
];

const groups: Group[] = [
  {
    title: 'Eksklusivt indhold',
    intro: 'Et MyAB-abonnement giver dig eksklusivt indhold og et kig bag kulisserne, som:',
    items: [
      'Udvidede interviews',
      'Første kig på ABTV Originals',
      "Spiller-Q&A'er",
      'Kampdags- eller kampreferat-features',
    ],
  },
  {
    title: 'Medlemsfordele',
    intro: 'Særlige fordele og goder, der kun er tilgængelige for abonnenter:',
    items: [
      'Særlige kampdagstilbud, fx happy hour på øl',
      'Tidlig adgang til flash-sales i appen',
      'Merchandise-tilbud og limited edition-drops',
    ],
  },
  {
    title: 'Partnertilbud',
    intro: "Eksklusive kampdags- og efter-kamp-tilbud fra AB's partnere:",
    items: ['Restauranter', 'Kaffe', 'Butikker', 'Osv.'],
  },
];
---

<Base
  locale="da"
  title="MyAB | AB 1889"
  description="Bliv AB Insider med MyAB — eksklusivt indhold, medlemsfordele og partnerrabatter i AB's fan-app.">

  <!-- App download -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-4xl mx-auto px-8 text-center">
      <h1 class="font-black text-[#111] text-center max-w-[32ch] mx-auto mb-10" style="font-size:clamp(1.75rem,4vw,2.75rem);line-height:1.2;letter-spacing:-0.02em">
        Bliv AB Insider med MyAB — kun i AB's fan-app!
      </h1>

      <div class="inline-flex p-4 border border-[#E5E7EB] bg-white">
        <img
          src="/api/qr/app.png"
          alt="QR-kode til download af MyAB-appen"
          width="150"
          height="150"
          class="w-[150px] h-[150px]"
          loading="lazy"
        />
      </div>
      <p class="text-[#333] mt-6 mb-14" style="font-size:1rem;line-height:1.6">
        Hent appen ved at åbne kameraet på din mobil.
        Ret det mod QR-koden, så er du klar.
      </p>

      <AppScreenshotCarousel shots={appShots} />

      <p class="text-[#666] text-[0.9rem] mt-10 max-w-[48ch] mx-auto" style="line-height:1.7">
        MyAB findes udelukkende i AB's officielle fan-app — hent den ved at
        scanne QR-koden, eller hent den direkte via{' '}
        <a
          href="https://play.google.com/store/apps/details?id=dk.ab.club&hl=en_US&pli=1"
          target="_blank"
          rel="noreferrer noopener"
          class="underline hover:text-ab-green transition-colors"
        >Google Play</a>{' '}
        eller{' '}
        <a
          href="https://apps.apple.com/id/app/myab/id6760774439"
          target="_blank"
          rel="noreferrer noopener"
          class="underline hover:text-ab-green transition-colors"
        >Apple App Store</a>.
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-[#F2F2F0] border-t border-[#E5E7EB] py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <h2 class="font-black mb-10 text-[#111]" style="font-size:clamp(1.5rem,3.5vw,2.5rem);letter-spacing:-0.03em">
        Det får du med et MyAB-abonnement
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {groups.map((group) => (
          <div class="bg-white border border-[#E5E7EB] p-7">
            <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-green mb-4">{group.title}</p>
            <p class="text-[0.85rem] text-[#666] leading-relaxed mb-4">{group.intro}</p>
            <ul class="space-y-2.5">
              {group.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.9rem] text-[#333] leading-snug">
                  <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5 6.5 12 2.5 8" stroke="var(--ab-green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
