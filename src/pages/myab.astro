---
import Base from '@/layouts/Base.astro';
import Img from '@/components/Img.astro';

export const prerender = true;

interface Group {
  title: string;
  intro: string;
  items: string[];
}

const groups: Group[] = [
  {
    title: 'Eksklusivt indhold',
    intro: 'Et MyAB-abonnement giver dig eksklusivt indhold og et kig bag kulisserne, som:',
    items: [
      'Udvidede interviews',
      'Første kig på ABTV Originals',
      "Spiller-Q&A'er",
      'Kampdags- eller kampreferat-features',
    ],
  },
  {
    title: 'Medlemsfordele',
    intro: 'Særlige fordele og goder, der kun er tilgængelige for abonnenter:',
    items: [
      'Særlige kampdagstilbud, fx happy hour på øl',
      'Tidlig adgang til flash-sales i appen',
      'Merchandise-tilbud og limited edition-drops',
    ],
  },
  {
    title: 'Partnertilbud',
    intro: "Eksklusive kampdags- og efter-kamp-tilbud fra AB's partnere:",
    items: ['Restauranter', 'Kaffe', 'Butikker', 'Osv.'],
  },
];
---

<Base
  locale="da"
  title="MyAB | AB 1889"
  description="Bliv AB Insider med MyAB — eksklusivt indhold, medlemsfordele og partnerrabatter i AB's fan-app.">

  <!-- Hero -->
  <div class="bg-ab-black py-16 px-8 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <span class="inline-block font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-neon mb-5">AB 1889</span>
      <h1 class="font-black text-white leading-none text-[clamp(3.5rem,9vw,7rem)] tracking-[-0.04em] mb-6">MyAB</h1>
      <p class="font-black text-white max-w-[42ch]" style="font-size:clamp(1.1rem,2.2vw,1.4rem);line-height:1.4">
        Bliv AB Insider med MyAB — kun i AB's fan-app!
      </p>
    </div>
  </div>

  <!-- Price + pitch + app download -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <p class="text-[#333] max-w-[62ch] mb-8" style="font-size:clamp(1rem,1.6vw,1.1875rem);line-height:1.7">
            Vil du følge med i alt om AB og være den ultimative fan? Kom tættere
            på klubben med eksklusivt indhold, medlemsfordele, partnerrabatter
            og premium app-funktioner.
          </p>
          <p class="text-[#666] text-[0.9rem] mb-4">
            MyAB findes udelukkende i AB's officielle fan-app — hent den nedenfor.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="https://apps.apple.com/id/app/myab/id6760774439"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Hent i App Store (åbner i nyt vindue)"
              class="inline-flex hover:opacity-85 transition-opacity"
            >
              <img
                src="https://toolbox.marketingtools.apple.com/api/badges/download-on-the-app-store/black/da-dk?size=250x83"
                alt="Hent i App Store"
                width="144"
                height="48"
                class="h-12 w-auto"
                loading="lazy"
              />
            </a>
            <a
              href="https://play.google.com/store/apps/details?id=dk.ab.club&hl=en_US&pli=1"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Hent i Google Play (åbner i nyt vindue)"
              class="inline-flex hover:opacity-85 transition-opacity"
            >
              <img
                src="https://play.google.com/intl/da/badges/static/images/badges/da_badge_web_generic.png"
                alt="Hent i Google Play"
                width="124"
                height="48"
                class="h-12 w-auto"
                loading="lazy"
              />
            </a>
          </div>
        </div>
        <div class="flex justify-center lg:items-start lg:-mt-[380px] relative z-10">
          <Img
            src="/images/myab-app-preview.png"
            alt="Skærmbillede af AB's fan-app"
            class="w-full max-w-[210px] h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-[#F2F2F0] border-t border-[#E5E7EB] py-[clamp(48px,7vw,80px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <h2 class="font-black mb-10 text-[#111]" style="font-size:clamp(1.5rem,3.5vw,2.5rem);letter-spacing:-0.03em">
        Det får du med et MyAB-abonnement
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {groups.map((group) => (
          <div class="bg-white border border-[#E5E7EB] p-7">
            <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-green mb-4">{group.title}</p>
            <p class="text-[0.85rem] text-[#666] leading-relaxed mb-4">{group.intro}</p>
            <ul class="space-y-2.5">
              {group.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.9rem] text-[#333] leading-snug">
                  <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5 6.5 12 2.5 8" stroke="var(--ab-green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
