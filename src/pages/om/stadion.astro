---
import Base from '@/layouts/Base.astro';
import heroImage from '@/assets/images/gladsaxe.webp';
import stadiumImage from '@/assets/images/pro-OPKh7A3o.webp';

export const prerender = true;

const facilities = [
  { label: 'Samlet kapacitet', value: '13.507' },
  { label: 'Siddepladser', value: '7.707' },
  { label: 'Ståpladser', value: '5.800' },
  { label: 'Hjemmebane siden', value: '1930' },
  { label: 'Banestørrelse', value: '68 × 105 m' },
  { label: 'Belysning', value: '715 lux' },
];
---

<Base
  locale="da"
  title="Stadioninfo | AB 1889">
  <!-- Hero -->
  <div class="relative overflow-hidden h-[clamp(260px,36vw,420px)]">
    <img
      src={heroImage.src}
      alt="Gladsaxe Stadion"
      width={heroImage.width}
      height={heroImage.height}
      class="absolute inset-0 w-full h-full object-cover object-center brightness-[0.5] saturate-[0.6]"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.55)_0%,rgba(0,0,0,0.1)_70%)]">
    </div>
    <div
      class="relative h-full flex flex-col justify-end px-8 lg:px-16 pb-12 max-w-7xl mx-auto w-full">
      <h1
        class="font-black text-white text-[clamp(3rem,9vw,7rem)] tracking-[-0.04em] leading-[0.9]">
        Gladsaxe Stadion
      </h1>
    </div>
  </div>

  <!-- Tab breadcrumb — hidden for now
  <div class="bg-white border-b border-[#E5E7EB]">
    <div class="max-w-7xl mx-auto px-8 flex items-center gap-6 h-12">
      <a
        href="/kampe"
        class="text-sm font-bold text-[#555] no-underline tracking-[-0.02em]"
        >← Kampe</a
      >
      <span class="text-[#DDD]">/</span>
      <span class="text-sm font-bold text-ab-green tracking-[-0.02em]"
        >Stadioninfo</span
      >
    </div>
  </div>
  -->

  <!-- Info grid -->
  <section class="bg-white py-[clamp(40px,6vw,72px)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 flex flex-col gap-10">

      <!-- Row 1: Intro + photo -->
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="inline-block font-black text-xs px-3 py-1 mb-6 bg-ab-beige text-ab-green tracking-[0.12em]">HJEMMEBANE</span>
          <h2 class="font-black mb-4 text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.05em] leading-[0.95] text-[#111]">
            Hvor AB kommer til live.
          </h2>
          <p class="text-sm leading-relaxed text-[#555] max-w-[44ch]">
            AB's hjemmebane siden 1930. Gladsaxe Stadion har en samlet kapacitet på 13.507, med 7.707 siddepladser fordelt på to tribuner og store ståpladser bag hvert mål. Stadionet ligger i grønne og rolige omgivelser i Gladsaxe og er nemt tilgængeligt med offentlig transport.
          </p>
        </div>
        <div class="rounded overflow-hidden aspect-[4/3] border border-[#E5E7EB]">
          <img
            src={stadiumImage.src}
            alt="Gladsaxe Stadion"
            width={stadiumImage.width}
            height={stadiumImage.height}
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- Row 2: Stats cards — full width -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {facilities.map(({ label, value }) => (
          <div class="border border-[#E5E7EB] py-4 px-5">
            <p class="text-xs uppercase mb-1 text-[#999] tracking-[0.12em]">{label}</p>
            <p class="font-black text-lg text-[#111] tracking-[-0.04em]">{value}</p>
          </div>
        ))}
      </div>

      <!-- Row 3: Grandstands — full width, 3 cols -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-[#F5F5F5] p-4">
          <p class="font-black text-[0.7rem] uppercase tracking-[0.1em] text-[#999] mb-1">Tribune 1</p>
          <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em]">3.977 pladser</p>
          <p class="text-xs text-[#666] mt-0.5">"Den gamle tribune" — Bygget 1940</p>
        </div>
        <div class="bg-[#F5F5F5] p-4">
          <p class="font-black text-[0.7rem] uppercase tracking-[0.1em] text-[#999] mb-1">Tribune 3</p>
          <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em]">3.730 pladser</p>
          <p class="text-xs text-[#666] mt-0.5">"Den nye tribune" — Bygget 1999</p>
        </div>
        <div class="bg-[#F5F5F5] p-4">
          <p class="font-black text-[0.7rem] uppercase tracking-[0.1em] text-[#999] mb-1">Ståpladser (bag mål)</p>
          <p class="font-black text-[1.05rem] text-[#111] tracking-[-0.03em]">2.900 pr. ende</p>
          <p class="text-xs text-[#666] mt-0.5">5.800 i alt</p>
        </div>
      </div>

      <!-- Row 4: Address + map btn | Record + tickets btn -->
      <div class="grid lg:grid-cols-2 gap-6">
        <div class="border border-[#E5E7EB] p-6 flex flex-col justify-between gap-6">
          <div class="border-l-[3px] border-ab-green pl-4">
            <p class="text-xs uppercase mb-2 text-[#999] tracking-[0.12em]">Adresse</p>
            <p class="text-sm font-bold text-[#111]">Gladsaxevej 202</p>
            <p class="text-sm text-[#555]">2860 Søborg, Danmark</p>
          </div>
          <a
            href="https://maps.google.com/?q=Gladsaxevej+202,+2860+Søborg"
            target="_blank"
            rel="noreferrer"
            class="font-black text-sm px-5 py-3 bg-ab-green text-white no-underline tracking-[-0.02em] self-start">
            Åbn i Google Maps
          </a>
        </div>
        <div class="border border-[#E5E7EB] p-6 flex flex-col justify-between gap-6">
          <div>
            <p class="font-black text-[0.65rem] uppercase tracking-[0.14em] text-[#999] mb-2">Tilskuerrekord</p>
            <p class="font-black text-[#111] text-[1.05rem] tracking-[-0.03em] leading-[1.3]">10.039 tilskuere</p>
            <p class="text-[#666] text-xs mt-1">AB vs. FC København · Superligaen · April 2004 · Slutresultat 0-2</p>
          </div>
          <a
            class="vivenu-btn font-black text-sm px-5 py-3 bg-ab-green text-white no-underline tracking-[-0.02em] self-start"
            href="https://billet.ab.dk/?useEmbed=true">
            Køb billetter
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Getting there -->
  <section class="bg-[#EBEBEB] py-[clamp(40px,6vw,64px)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <h2
        class="font-black mb-10 text-[clamp(1.5rem,4vw,2.5rem)] tracking-[-0.04em] text-[#111]">
        Kom til stadion
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        {
          [
            {
              icon: '🚇',
              title: 'Metro / S-Tog',
              desc: 'Tag S-banen til Buddinge St. (5 min gåtur), eller bus 200S fra Lyngby/Glostrup.',
            },
            {
              icon: '🚗',
              title: 'Bil',
              desc: 'Gratis parkering tilgængelig ved stadionet. Følg skiltning fra Ring 2 / Gladsaxevej.',
            },
            {
              icon: '🚲',
              title: 'Cykel',
              desc: 'Cykelstier langs Gladsaxevej. Sikker cykelparkering ved alle indgange.',
            },
          ].map(({ icon, title, desc }) => (
            <div class="bg-white p-6 border border-[#E5E7EB]">
              <span class="text-[2rem]">{icon}</span>
              <h3 class="font-black mt-3 mb-2 text-[1.1rem] tracking-[-0.03em] text-[#111]">
                {title}
              </h3>
              <p class="text-sm leading-relaxed text-[#555]">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
