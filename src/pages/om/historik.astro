---
import Base from '@/layouts/Base.astro';
export const prerender = true;

const milestones = [
  {
    year: '1883',
    heading: "AB's velkendte farver — grønt og hvidt.",
    body: 'Da Præstedan og det latinske Skole slog sig sammen i 1883, var det nødvendigt at aftale farverne. Eleverne fra de to skoler holdt møde og fandt frem til en løsning, der har overlevet til i dag: Akademisk Boldklubs farver er grønt og hvidt. Denne enkle beslutning fik stor betydning for klubbens identitet og sammenhørighed.',
    img: '/images/squad-banner.png',
    imgAlt: 'AB 1883',
    layout: 'text-left',
    bg: '#fff',
  },
  {
    year: '1887',
    heading: 'Optaget i FSK i 1887',
    body: "Gradually in 1887, the game of football was adopted by the FSK. The cooperative editor Globalt became a decisive voice of one of the most major representatives of the association. On 25 February 1889, the Founders' Cooperative was reformed as Akademisk Boldklub. A dramatic move that saw the adoption of much younger players in the club's roster.",
    img: '/images/player-featured.png',
    imgAlt: 'AB 1887',
    layout: 'img-left',
    bg: '#EBEBEB',
  },
  {
    year: '1889',
    heading: 'Kontingent på 50 ØRE om måneden i 1889',
    body: "I 1889 fastsatte den nystiftede klub et månedligt kontingent på 50 øre. I juni 1889 spillede AB sin første kamp på Frederiksberg-sletten. Banen var fri, og holdet kunne bevæge sig frit rundt på pladsen. Resultatet af den første kamp i AB's historie er ikke overleveret, men entusiasmen var stor.",
    subHeading: 'En af de største personligheder i AB',
    subBody: 'Most of the oldest personalities in the history of the Athlone in Munich Bayer (Kjell Frank) (Czech Republic) have played for AB and constituted a genuinely important part of the club. Baumann created a tournament-famous football club that was not yet complete for all positions at the time. He carried the club in a tremendously important way in the 1890s. Wonderfully charming, it\'s a fact that his spirit has never yet quite died out among the great ones. After he made his name as a footballer, he took on the role of administrator for many years, which included the position which was held for a surprising 40 years.',
    img: '/images/ab-crest.svg',
    imgAlt: 'AB crest 1889',
    layout: 'two-col',
    bg: '#fff',
  },
  {
    year: '1894',
    heading: 'Etablering af juniorafdeling i 1894',
    body: 'Da den professionelle afdeling led under manglende rekruttering i 1894, valgte AB at oprette en juniorafdeling i 1893–94. Akademisk Boldklub oprettede i løbet af de næste år en junior afdeling. Sæsonen for juniorer var den første egentlige del til AB\'s program. Juniorafdelingen gav mulighed for at rekruttere og pleje nye talenter, som ville forme det næste kapitel i AB\'s glorværdige historie og bidrage til at opretholde den akademiske tradition, som klubben stolte var baseret på.',
    img: null,
    imgAlt: '',
    layout: 'text-only',
    bg: '#EBEBEB',
  },
];
---

<Base locale="da" title="Historik | AB 1889">
  <!-- Hero -->
  <div class="relative overflow-hidden" style="height:clamp(280px,40vw,480px);">
    <img
      src="/images/squad-banner.png"
      alt="AB 1889 Historie"
      class="absolute inset-0 w-full h-full object-cover object-top"
      style="filter:brightness(0.35) saturate(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);"></div>
    <div class="relative h-full flex flex-col justify-end px-8 lg:px-16 pb-12 max-w-7xl mx-auto w-full">
      <h1 class="font-black text-white" style="font-size:clamp(4rem,10vw,8rem);letter-spacing:-0.05em;line-height:0.88;">Historik</h1>
    </div>
  </div>

  <!-- Timeline sections -->
  {milestones.map((m) => (
    <section style={`background:${m.bg}; padding: clamp(48px,7vw,80px) 0;`}>
      <div class="max-w-7xl mx-auto px-6 lg:px-16">
        {m.layout === 'text-left' && (
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <div>
              <span class="inline-block font-black text-xs px-3 py-1 mb-5" style="background:#D3BC8D; color:#006A52; letter-spacing:0.12em;">{m.year}</span>
              <h2 class="font-black mb-5" style="font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.04em; line-height:1.05; color:#111;">{m.heading}</h2>
              <p class="text-sm leading-relaxed" style="color:#555; max-width:48ch;">{m.body}</p>
            </div>
            <div class="rounded overflow-hidden aspect-[4/3]">
              <img src={m.img!} alt={m.imgAlt} class="w-full h-full object-cover" />
            </div>
          </div>
        )}

        {m.layout === 'img-left' && (
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <div class="rounded overflow-hidden aspect-[4/3] order-2 lg:order-1">
              <img src={m.img!} alt={m.imgAlt} class="w-full h-full object-cover object-top" />
            </div>
            <div class="order-1 lg:order-2">
              <span class="inline-block font-black text-xs px-3 py-1 mb-5" style="background:#D3BC8D; color:#006A52; letter-spacing:0.12em;">{m.year}</span>
              <h2 class="font-black mb-5" style="font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.04em; line-height:1.05; color:#111;">{m.heading}</h2>
              <p class="text-sm leading-relaxed" style="color:#555; max-width:48ch;">{m.body}</p>
            </div>
          </div>
        )}

        {m.layout === 'two-col' && (
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
            <div>
              <span class="inline-block font-black text-xs px-3 py-1 mb-5" style="background:#D3BC8D; color:#006A52; letter-spacing:0.12em;">{m.year}</span>
              <h2 class="font-black mb-5" style="font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.04em; line-height:1.05; color:#111;">{m.heading}</h2>
              <p class="text-sm leading-relaxed mb-10" style="color:#555;">{m.body}</p>
              <div class="flex items-end gap-6">
                <img src="/images/ab-crest.svg" alt="AB 1889 crest" width="120" height="120" style="opacity:0.15;" />
              </div>
            </div>
            <div>
              <h3 class="font-black mb-4" style="font-size:clamp(1.5rem,3vw,2rem); letter-spacing:-0.04em; line-height:1.1; color:#111;">{m.subHeading}</h3>
              <p class="text-sm leading-relaxed" style="color:#555;">{m.subBody}</p>
            </div>
          </div>
        )}

        {m.layout === 'text-only' && (
          <div class="max-w-3xl">
            <span class="inline-block font-black text-xs px-3 py-1 mb-5" style="background:#D3BC8D; color:#006A52; letter-spacing:0.12em;">{m.year}</span>
            <h2 class="font-black mb-5" style="font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.04em; line-height:1.05; color:#111;">{m.heading}</h2>
            <p class="text-sm leading-relaxed" style="color:#555;">{m.body}</p>
          </div>
        )}
      </div>
    </section>
  ))}

  <!-- Dark interlude: Board of directors -->
  <section style="background:#0A0A09; padding: clamp(48px,7vw,80px) 0;">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="rounded overflow-hidden aspect-video">
          <img src="/images/hero.jpg" alt="AB 1889 bestyrelse" class="w-full h-full object-cover" style="filter:saturate(0.4);" />
        </div>
        <div>
          <h2 class="font-black mb-6" style="font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.04em; line-height:1.05; color:#fff;">AB's nye bestyrelse</h2>
          <p class="text-sm leading-relaxed mb-6" style="color:rgba(255,255,255,0.6);">AB's bestyrelse arbejder dedikeret på at føre klubben ind i en ny æra med fokus på sportslig succes og stærke fællesskabsrødder.</p>
          <ul class="flex flex-col gap-2">
            {['Jens Andersen — Formand', 'Lars Nielsen — Næstformand', 'Sofie Larsen', 'Michael Christensen', 'Anna Pedersen'].map((name) => (
              <li class="text-sm" style="color:rgba(255,255,255,0.5);">{name}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Base>
