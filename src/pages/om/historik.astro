---
import Base from '@/layouts/Base.astro';
import TimelineNav from '@/components/history/TimelineNav.astro';
import PlaceholderImage from '@/components/history/PlaceholderImage.astro';

export const prerender = true;

const olympiskeLondon1948 = [
  'Knud Lundberg',
  'Georg Dahlfelt',
  'Karl Aage Hansen',
  'Ivan Jensen',
  'Poul Petersen',
  'Knud Bastrup-Birk',
];

const treStoreSpillere = [
  { navn: 'René Henriksen', note: 'Landsholdsdebut som 28-årig' },
  { navn: 'Peter Frandsen', note: '392 kampe for AB' },
  { navn: 'Peter Rasmussen', note: 'Klubrekord: 394 kampe' },
];

const fiveCastlesLedelse = [
  { navn: 'Erik Stover', rolle: 'CEO', note: 'Tidl. CEO, New York Red Bulls' },
  { navn: 'Jen Hsiang Chang', rolle: 'Formand & Sporting Director', note: 'Tidl. CEO, New York Cosmos' },
  { navn: 'Ben Lyttleton', rolle: 'Fodboldskribent', note: '' },
  { navn: 'Simon Young', rolle: 'Medstifter, ClipperData', note: '' },
  { navn: 'Andy Glockner', rolle: 'Sportsanalyse-konsulent', note: '' },
  { navn: 'Alex Lee', rolle: 'Talentchef, Dell', note: '' },
];

const trenerregnskab = [
  { navn: 'Patrick Braune', note: '13 S – 9 U – 10 N' },
  { navn: 'David Roufpanah (23/24)', note: '9 S – 13 U – 10 N' },
  { navn: 'Joey Guðjónsson (24/25)', note: '14 S – 9 U – 9 N · 4. plads' },
];
---

<Base
  locale="da"
  title="Historik | AB 1889">
  <!-- Hero -->
  <div class="relative w-full">
    <img
      src="/images/about-history-hero.png"
      alt="AB 1889 Historie"
      class="w-full h-auto block"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.1)_30%,rgba(0,0,0,0.55)_100%)]">
    </div>
    <div class="absolute inset-0 flex items-end px-8 lg:px-20 pb-14">
      <h1
        class="font-black text-white leading-none text-[clamp(3.5rem,10vw,8rem)] tracking-[-0.04em]">
        Historik
      </h1>
    </div>
  </div>

  <TimelineNav locale="da" />

  <!-- 1883: White bg — tekst venstre, billede højre -->
  <section id="1883" class="bg-white py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-28 items-center">
        <div>
          <div
            class="inline-flex items-center mb-7 bg-ab-beige rounded-full py-[9px] px-[22px]">
            <span
              class="font-black text-[1.4rem] text-[#111] tracking-[-0.04em]"
              >1883</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
            AB's velkendte farver — grønt og hvidt.
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] max-w-[44ch]">
            Da eleverne fra Fredericia Latinskole kom til København i 1883,
            medbragte de mere end akademisk viden. Da fodbold endnu ikke havde
            slået an i Danmark, startede disse studerende i stedet en
            Kricketklub som samlingssted for deres sportslige aktiviteter.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] max-w-[44ch] mt-5">
            Denne klub fik navnet "Fredericia-studenternes Kricketklub" (FSK),
            som en afsluttende hyldest til deres gamle skole. Spillernes
            uniformer var allerede i de kendte AB-farver: Grønt og hvidt.
          </p>
        </div>
        <div class="overflow-hidden rounded-md aspect-4/3">
          <img
            src="/images/about-frederician-latin-school-building.png"
            alt="Fredericia Latinskole"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 1887: Beige bg — billede venstre, tekst højre -->
  <section id="1887" class="bg-ab-beige py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-28 items-center">
        <div class="overflow-hidden order-2 lg:order-1 rounded-md aspect-4/3">
          <img
            src="/images/about-board-of-directors.png"
            alt="AB hold 1887"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="order-1 lg:order-2">
          <div
            class="inline-flex items-center mb-7 bg-ab-neon rounded-full py-[9px] px-[22px]">
            <span
              class="font-black text-[1.4rem] text-[#111] tracking-[-0.04em]"
              >1887</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
            Optaget i FSK i 1887
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-[#111] max-w-[44ch]">
            Allerede i 1887 blev fodboldspillet optaget i FSK. Dette skete efter
            at en dansk oversættelse af det engelske Football Associations love
            var blevet lavet i efteråret 1886/87.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#111] max-w-[44ch] mt-5">
            Efterhånden som tilstrømningen af københavnere steg, aftalte man at
            klubbens navn ikke længere repræsenterede dens medlemmer. Den 26.
            februar 1889 fusionerede "Fredericia-studenternes Kricketklub" med
            den lidt yngre "Polyteknisk Klub". Navnet blev: Akademisk Boldklub.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 1889: Lysegrå bg — tekst venstre, billede højre -->
  <section id="1889" class="bg-[#E7E7E7] py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-28 items-center">
        <div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
            Krav til den nystiftede akademiske fodboldklub
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] max-w-[44ch]">
            Optagelseskravene for at blive medlem af den nystiftede Akademiske
            Fodboldklub blev ændret efter fusionen, så alle der havde aflagt
            adgangseksamen til et universitet eller en polyteknisk skole kunne
            blive medlemmer. Dette gjaldt også studerende fra andre
            skandinaviske universiteter.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] max-w-[44ch] mt-5">
            Derudover kunne ikke-akademiske fodboldspillere med potentiale
            optages i AB ved at blive enstemmigt foreslået af bestyrelsen eller
            af 15 af klubbens medlemmer.
          </p>
        </div>
        <div class="overflow-hidden rounded-md aspect-4/3">
          <img
            src="/images/about-stadium-seat.png"
            alt="AB stadion"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 1889 sort: Ny bestyrelse -->
  <section id="1889-board" class="bg-rich-black py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-28 items-center">
        <div class="overflow-hidden rounded-md aspect-4/3">
          <img
            src="/images/about-board-of-directors.png"
            alt="AB bestyrelse 1889"
            class="w-full h-full object-cover"
          />
        </div>
        <div>
          <div
            class="inline-flex items-center mb-7 bg-ab-green rounded-full py-[9px] px-[22px]">
            <span class="font-black text-[1.4rem] text-white tracking-[-0.04em]"
              >1889</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-ab-beige">
            AB's nye bestyrelse
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-ab-beige mb-4">
            AB's nye bestyrelse efter fusionen bestod af:
          </p>
          <ul
            class="flex flex-col gap-2 text-ab-beige text-[1.1rem] leading-[1.75]">
            <li>
              ME Pagh — Formand (tidl. formand for Fredericia-studenternes
              Kricketklub)
            </li>
            <li>E. Faber</li>
            <li>H. Forchhammer</li>
            <li>H.C. Lund</li>
            <li>H. Birk</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 1889 hvid: To kolonner -->
  <section id="1889-dues" class="bg-white py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-28 items-start">
        <div>
          <div
            class="inline-flex items-center mb-7 bg-ab-green rounded-full py-[9px] px-[22px]">
            <span class="font-black text-[1.4rem] text-white tracking-[-0.04em]"
              >1889</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
            Kontingent på 50 ØRE om måneden i 1889
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-[#444]">
            I 1889 var kontingent for aktive AB-medlemmer blot 50 øre om
            måneden.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
            Den 1. april 1889 flyttede klubben til nye lokaler på Helgesensgade
            5, hvor de blev vel modtaget af klubbens første beklædningssponsor.
            Da de ikke havde råd til at købe håndklæder, købte en AB-spillers
            mor stof på kredit og syede selv 6 håndklæder til de entusiastiske
            spillere.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
            DBU skaffede en flot pokal for den nette sum af 150 kroner, og
            resultatet af DBU's første turnering (1889-1890) var at AB vandt
            finalen over KB 2-0.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
            Omkring århundredeskiftet havde KB og B93 begge egne baner, og AB
            mente de burde have det samme. Den nødvendige kapital på 60.000 kr.
            blev skaffet hos klubbens støtter, og det var dermed muligt at leje
            et areal på Lammefælleden på Tagensvej af Københavns Kommune. Banen
            stod klar i 1903.
          </p>
        </div>
        <div class="pt-[calc(1.4rem+18px+1.75rem)]">
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
            En af de største personligheder i AB
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-[#444]">
            En af tidens største personligheder i AB var afdelingsleder Charles
            Buchwald, som spillede alle tre boldspil tilgængelige i AB: fodbold,
            tennis og cricket. Buchwald spillede på landsholdet i fodbold og
            cricket og var klubmester i tennis.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
            Buchwald debuterede på AB's første hold som 16-årig — samme alder
            som Harald Bohr, der nåede 4 landskampe. Hans bror Niels, der
            sandsynligvis blev bedre kendt uden for banen, var målmand.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
            'AB var ganske overlegen i en kamp mod det tyske hold Mittweida — og
            Niels Bohr fik tiden til at gå ved at stå og læne sig op ad en af
            målstolperne. Pludselig blev der sparket en lang bold mod AB's mål.
            Alle ventede at Niels ville gå ud og tage bolden, men han gjorde
            ingenting. Efter kampen måtte han indrømme at hans tanker var
            optaget af et matematisk problem.'
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 1894: Grøn bg — crest venstre, tekst højre -->
  <section id="1894" class="bg-ab-green py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-[minmax(0,400px)_1.35fr] gap-16 lg:gap-20 items-center">
        <div
          class="flex items-center justify-center aspect-square max-h-[420px]">
          <img
            src="/images/about-crest-original.png"
            alt="AB 1889 crest"
            class="w-[min(360px,90%)]"
          />
        </div>
        <div>
          <div
            class="inline-flex items-center mb-7 bg-ab-neon rounded-full py-[9px] px-[22px]">
            <span
              class="font-black text-[1.4rem] text-[#111] tracking-[-0.04em]"
              >1894</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-white">
            Etablering af juniorafdeling i 1894
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-white/85">
            Da det nye spil endnu ikke havde nået skolerne, forsøgte klubben i
            1894 at etablere en Juniorafdeling — uden den store succes. I 1899
            forsøgte AB igen, denne gang under ledelse af skaberen af AB's
            berømte juniorafdeling og dens leder i 20 år: Edmond Andersen.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-white/85 mt-5">
            I løbet af afdelingens første år steg antallet af medlemmer til
            næsten 70. Edmond Andersen holdt en omhyggelig dagbog over de
            enkelte træningssessioner — både store og små.
          </p>
        </div>
      </div>

      <!-- 1919: Træningsdagbog og opsigelsen af Tagensvej -->
      <div
        id="1919"
        class="mt-16 lg:mt-20 border-l-[3px] border-ab-neon pl-6 lg:pl-8">
        <p
          class="text-[0.8rem] font-black text-ab-neon tracking-widest uppercase mb-4">
          1919 · Fra dagbogen
        </p>
        <p class="italic text-[1.05rem] leading-[1.8] text-white/90 mb-1">
          "Træningsdagbog og skarnsalderen (1919)"
        </p>
        <ul
          class="italic text-[1.05rem] leading-[1.8] text-white/80 mt-4 flex flex-col gap-1 list-none">
          <li>
            22-12: 10 mand. Femmands-fodbold. For 50. gang blev det
            konstateret, at X er i skarnsalderen.
          </li>
          <li>27-12: 20 spillere. Fint vejr. God kamp!</li>
          <li>3.-1.-01: Ingen spillere mødt op. Frost. Skøjteføre. Sæsonen sluttede.</li>
          <li>14.-6.: 23 mand til træning. Harald Bohr tog en dukkert.</li>
        </ul>
        <p class="italic text-[1.05rem] leading-[1.8] text-white/90 mt-5">
          "I 1919 begyndte skyerne at trække sig sammen over banerne på
          Tagensvej. Københavns Kommune opsagde lejemålet, men klubben fik det
          udskudt flere gange på grund af lange forhandlinger! Men i maj 1922
          var det slut. AB blev henvist til Fælleden og fik nådigst lov til at
          bruge et stykke af Rigshospitalets grund. I denne periode lå
          omklædningsrummene i et skur uden vand."
        </p>
        <p class="text-[0.95rem] text-white/60 mt-3">
          — Fra Edmond Andersens dagbog
        </p>
      </div>
    </div>
  </section>

  <!-- 1924: Beige bg — floating billede-placeholder i tekstflow -->
  <section id="1924" class="bg-ab-beige py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
        <div
          class="inline-flex items-center mb-7 bg-ab-green rounded-full py-[9px] px-[22px]">
          <span class="font-black text-[1.4rem] text-white tracking-[-0.04em]"
            >1924</span
          >
        </div>
        <h2
          class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
          Flytningen til Nørre Allé
        </h2>
        <PlaceholderImage
          locale="da"
          class="w-full sm:w-[300px] lg:w-[380px] sm:float-right sm:ml-8 lg:ml-10 mb-6"
        />
        <p class="text-[1.1rem] leading-[1.75] text-[#111]">
          Flytningen til Nørre Allé blev kun muliggjort gennem stor økonomisk
          velvilje fra kendte navne i de akademiske kredse, og ikke mindst
          fra fodboldklubben FREM, der gav AB et stort lån til opførelsen af
          nye baner og et klubhus, som stod færdigt den 13. september 1924.
          At det havde kostet klubben dyrt, kan ses af invitationen til
          indvielsesfesten samme aften: "Sandwiches skal medbringes, kun den
          åndelige føde vil udvalget sørge for."
        </p>
        <p class="text-[1.1rem] leading-[1.75] text-[#111] mt-5">
          Året før var P.W. Degner kommet til klubben, og fra starten tog han
          over ledelsen af ungdomsafdelingen. Antallet af medlemmer i
          ungdomsafdelingen voksede støt — fra 130 i 1925 til over 200 i
          midten af 30'erne.
        </p>
        <p class="text-[1.1rem] leading-[1.75] text-[#111] mt-5">
          AB vandt juniorturneringen 7 gange under ledelse af den navnkundige
          Carl Skomager Hansen, som også var den første dansker, der blev
          professionel i udlandet, da han i 1921 skrev kontrakt med Glasgow
          Rangers for en transfersum på £20!
        </p>
        <p class="text-[1.1rem] leading-[1.75] text-[#111] mt-5">
          Klublivet blomstrede i mellemkrigsårene, og årets store fest var
          "Rusgildet". Her blev de nyoprykkede seniorer indviet i klubbens
          regler og skikke gennem taler, sange, en revy og — ikke mindst —
          masser af drinks!
        </p>
        <div class="clear-both" aria-hidden="true" />
    </div>
  </section>

  <!-- 1940: Sort bg — billede-placeholder venstre, tekst højre -->
  <section id="1940" class="bg-rich-black py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
      <div class="grid lg:grid-cols-[minmax(0,360px)_1.65fr] gap-16 lg:gap-20 items-start">
        <div class="order-2 lg:order-1">
          <PlaceholderImage locale="da" />
        </div>
        <div class="order-1 lg:order-2">
          <div
            class="inline-flex items-center mb-7 bg-ab-gold rounded-full py-[9px] px-[22px]">
            <span
              class="font-black text-[1.4rem] text-[#111] tracking-[-0.04em]"
              >1940</span
            >
          </div>
          <h2
            class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-ab-beige">
            AB fylder 50 år
          </h2>
          <p class="text-[1.1rem] leading-[1.75] text-white/85">
            AB's 50-års fødselsdag blev fejret på den mest fashionable
            restaurant på den tid, Nimb, hvor formand O. Thieslen bød gæsterne
            velkommen. Blandt andet afspillede formanden den grammofonplade,
            som professor og nobelprisvinder Niels Bohr havde sendt hjem fra
            sin rejse i USA — en hyldest til fødselaren.
          </p>
          <p class="text-[1.1rem] leading-[1.75] text-white/85 mt-5">
            At spille bold under krigen var anderledes end før 1940. Man
            trænede hårdere, nød kammeratskabet i klubben og følte sig del af
            fællesskabet på en helt anden måde end tidligere. I sæsonen 1942-43
            vandt AB "Double'en", og holdet talte blandt andre Knud Lundberg,
            lægen der samtidig spillede på tre landshold — fodbold, håndbold og
            basketball — Karl Aage Hansen, senere professionel i Juventus, Ivan
            Jensen og Georg Dahlfelt, der spillede sammen med Lundberg på
            landsholdet i håndbold.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 1946: Hvid bg — floating billede-placeholder i tekstflow -->
  <section id="1946" class="bg-white py-[clamp(64px,9vw,112px)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-20">
        <div
          class="inline-flex items-center mb-7 bg-ab-beige rounded-full py-[9px] px-[22px]">
          <span
            class="font-black text-[1.4rem] text-[#111] tracking-[-0.04em]"
            >1946</span
          >
        </div>
        <h2
          class="font-black mb-7 text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.04em] leading-[1.05] text-[#111]">
          Bordtennis kommer til AB
        </h2>
        <PlaceholderImage
          locale="da"
          class="w-full sm:w-[300px] lg:w-[380px] sm:float-right sm:ml-8 lg:ml-10 mb-6"
        />
        <p class="text-[1.1rem] leading-[1.75] text-[#444]">
          I 1946 kom bordtennis til AB. Med forskellige cricket- og
          fodboldspillere på holdet lykkedes det at vinde
          Københavnsmesterskabet i 1946 og '47, og kronen på værket blev
          "Double'en" (DM og pokal) i både 1948 og 1949. Trods de flotte
          resultater blev afdelingen nedlagt i begyndelsen af 50'erne.
        </p>
        <p class="text-[1.1rem] leading-[1.75] text-[#444] mt-5">
          AB's guldalder lå i tiden efter 2. Verdenskrig. Medlemstallet lå på
          over 1.000, og strømmen af danske mesterskaber tog til — med sejre
          i 1945, 1947, 1951 og 1952. Og fodbold var populært: 30.000
          tilskuere til de fleste kampe i Idrætsparken.
        </p>

        <p
          class="text-[0.78rem] font-black text-[#999] tracking-widest uppercase mt-8 mb-3 clear-both">
          1948 London-OL — AB-truppen
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {
            olympiskeLondon1948.map((navn) => (
              <div class="border border-[#E5E7EB] py-3 px-4">
