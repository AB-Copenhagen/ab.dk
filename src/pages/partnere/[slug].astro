---
import Base from '@/layouts/Base.astro';
import { findPartner } from '@/data/partners';

const { slug } = Astro.params;
const partner = findPartner(slug ?? '');

if (!partner) return Astro.redirect('/partnere', 302);

const tierLabel = partner.tier === 'principal' ? 'Hovedpartner' : 'AB Partner';
const backHref = '/partnere';
---

<Base
  locale="da"
  title={`${partner.name} | Partnere | AB 1889`}
  description={partner.description ?? `${partner.name} er partner hos Akademisk Boldklub AB 1889.`}>

  <!-- Thin header -->
  <div class="bg-ab-black border-b border-white/10 py-10 px-8 lg:px-20">
    <div class="max-w-4xl mx-auto">
      <a
        href={backHref}
        class="flex items-center gap-1.5 w-fit text-white/40 hover:text-white text-[0.72rem] font-black uppercase tracking-[0.1em] transition-colors mb-6">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Alle partnere
      </a>
      <span class="inline-block font-black text-[0.65rem] uppercase tracking-[0.14em] text-ab-neon mb-3">{tierLabel}</span>
      <h1 class="font-black text-white text-[clamp(2rem,5vw,3.5rem)] tracking-[-0.04em] leading-tight">{partner.name}</h1>
    </div>
  </div>

  <!-- Content -->
  <section class="bg-white py-[clamp(48px,7vw,80px)]">
    <div class="max-w-4xl mx-auto px-8 lg:px-20 flex flex-col gap-10">

      <!-- Logo box -->
      <div class="border border-gray-100 w-full overflow-hidden">
        <div class="flex items-center justify-center bg-[#F8F8F8] px-12 py-14">
          <img
            src={partner.logo}
            alt={partner.name}
            class="max-h-36 max-w-[360px] w-full object-contain"
            loading="eager"
          />
        </div>
      </div>

      <!-- Description paragraph -->
      <p class:list={['text-[1.0625rem] leading-[1.8]', partner.description ? 'text-[#444]' : 'text-[#BBB] italic']}>
        {partner.description ?? 'Partnerprofil tilføjes snart.'}
      </p>

      {partner.website && (
        <a
          href={partner.website}
          target="_blank"
          rel="noreferrer noopener"
          aria-label={`Besøg ${partner.name}s hjemmeside`}
          class="inline-flex items-center gap-1.5 font-black text-[0.82rem] text-ab-green hover:text-ab-black tracking-[-0.01em] transition-colors w-fit">
          Besøg hjemmeside →
        </a>
      )}

      <!-- Meta strip -->
      <div class="grid grid-cols-3 border border-gray-100">
        <div class="px-5 py-[18px] border-r border-gray-100">
          <p class="font-black text-[0.58rem] uppercase tracking-[0.12em] text-[#BBB] mb-1.5">Varighed</p>
          <p class="font-black text-[0.82rem] text-[#333] leading-snug">{partner.howLong ?? '—'}</p>
        </div>
        <div class="px-5 py-[18px] border-r border-gray-100">
          <p class="font-black text-[0.58rem] uppercase tracking-[0.12em] text-[#BBB] mb-1.5">Nøglekontakter</p>
          <p class="font-black text-[0.82rem] text-[#333] leading-snug">—</p>
        </div>
        <div class="px-5 py-[18px]">
          <p class="font-black text-[0.58rem] uppercase tracking-[0.12em] text-[#BBB] mb-1.5">Højdepunkter</p>
          <p class="font-black text-[0.82rem] text-[#333] leading-snug">{partner.highlights ?? '—'}</p>
        </div>
      </div>

    </div>
  </section>

</Base>
