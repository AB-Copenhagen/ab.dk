---
import Base from '@/layouts/Base.astro';
import SiWidget from '@/components/widgets/SiWidget.astro';
import { fetchEvent, getTeamLogoSrc } from '@/lib/si/client';
import type { SIEvent } from '@/lib/si/client';
import { fetchMatchContent, strapiMediaUrl } from '@/lib/strapi/client';

export const prerender = false;

// Slug format: {eventId}-{teams}  e.g. "1234567-ab-vs-fc-nordsjaelland"
const { slug } = Astro.params;
const eventId = slug ? parseInt(slug.split('-')[0], 10) : NaN;

if (isNaN(eventId)) {
  return Astro.redirect('/kampe');
}

let event: SIEvent | null = null;

try {
  event = await fetchEvent(eventId, 'da');
} catch {
  // SI unavailable
}

if (!event) {
  return Astro.redirect('/kampe');
}

const { homeName, awayName, startDate, statusType, score, tournamentName } = event;

const pageTitle = `${homeName} vs ${awayName} | AB 1889`;
const matchDate = new Date(startDate).toLocaleDateString('da-DK', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});

const isLive = statusType === 'inprogress';
const isFinished = statusType === 'finished';
const cmsMatch = await fetchMatchContent(eventId).catch(() => null);
const accentColor = cmsMatch?.accentColor ?? '#006a52';
const bannerImageUrl = cmsMatch?.bannerImage ? strapiMediaUrl(cmsMatch.bannerImage.url) : null;
// Only show custom ticket CTA when editor explicitly sets a URL per match
const customTicketUrl = cmsMatch?.ticketUrl ?? null;
const articles = cmsMatch?.articles ?? [];
const socialEmbeds = cmsMatch?.socialEmbeds ?? [];

const WIDGET_TEAM_ID = 10202;
const WIDGET_TOURNAMENT_ID = 46;
const WIDGET_SEASON_ID = 16387;
---

<Base locale="da" title={pageTitle}>

  <!-- Hero: stadium aerial view with both team crests overlaid at the bottom -->
  <!-- Place your aerial stadium photo at /images/match-hero-default.jpg to use as default -->
  <div class="relative overflow-hidden" style="min-height:500px;background:#060806">
    <img
      src={bannerImageUrl ?? '/images/matches-header-bg.png'}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#060806] from-20% via-[#060806]/70 to-[#060806]/20" />

    <a
      href="/kampe"
      class="absolute top-6 left-5 md:left-12 z-10 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.15em] text-white/75 hover:text-white transition-colors"
    >
      ← Alle kampe
    </a>

    <div class="relative z-10 flex flex-col items-center text-center px-5 pb-10 pt-44 md:pt-52">
      <p class="text-xs font-bold uppercase mb-8 tracking-[0.2em]" style={`color:${accentColor}`}>
        {tournamentName}
      </p>

      <div class="flex items-center justify-center gap-8 md:gap-16 mb-6 w-full max-w-lg">
        <div class="flex flex-col items-center gap-3 flex-1 min-w-0">
          <img
            src={getTeamLogoSrc(event.homeId)}
            alt={homeName}
            width="96"
            height="96"
            class="w-20 h-20 md:w-24 md:h-24 object-contain drop-shadow-lg"
          />
          <span class="font-black text-white text-sm md:text-base leading-tight">{homeName}</span>
        </div>

        <div class="flex flex-col items-center gap-2 shrink-0">
          {score ? (
            <p
              class="font-black tabular-nums"
              style={`font-size:clamp(2.5rem,6vw,3.5rem);color:${isLive ? '#00FF1F' : 'white'}`}
            >
              {score}
            </p>
          ) : (
            <p class="text-xl font-black text-white/40 tracking-widest">VS</p>
          )}
          {isLive && (
            <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase text-ab-neon tracking-[0.1em]">
              <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
              LIVE
            </span>
          )}
        </div>

        <div class="flex flex-col items-center gap-3 flex-1 min-w-0">
          <img
            src={getTeamLogoSrc(event.awayId)}
            alt={awayName}
            width="96"
            height="96"
            class="w-20 h-20 md:w-24 md:h-24 object-contain drop-shadow-lg"
          />
          <span class="font-black text-white text-sm md:text-base leading-tight">{awayName}</span>
        </div>
      </div>

      <p class="text-sm text-white/50">{matchDate}</p>
    </div>
  </div>

  <div class="bg-white">
    <div class="max-w-7xl mx-auto px-5 md:px-12 py-10 lg:py-14 space-y-16">

      {customTicketUrl && (
        <div class="-mt-4">
          <a
            href={customTicketUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-bold uppercase tracking-[0.12em] text-white rounded-md transition-opacity hover:opacity-80"
            style={`background:${accentColor}`}
          >
            <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="4" width="12" height="6" rx="1" stroke="currentColor" stroke-width="1.2" />
              <path d="M10 4v-.5a2 2 0 0 0-4 0V4" stroke="currentColor" stroke-width="1.2" />
            </svg>
            Køb billetter
          </a>
        </div>
      )}

      {articles.length > 0 && (
        <section>
          <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
            Kampnyheder
          </p>
          <h2
            class="font-black mb-8 text-[#111]"
            style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
          >
            Artikler
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {articles.map((article) => (
              <a href={`/blog/${article.slug}`} class="group block no-underline">
                {article.image && (
                  <div class="aspect-video overflow-hidden rounded-lg mb-4 bg-gray-100">
                    <img
                      src={strapiMediaUrl(article.image.url)}
                      alt={article.image.alternativeText ?? article.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                <h3 class="font-bold text-[#111] group-hover:underline mb-2 leading-snug">
                  {article.title}
                </h3>
                {article.description && (
                  <p class="text-sm text-[#6B7280] line-clamp-2">{article.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      )}

      <section>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKMatchPageHeader"
            params={{ eventId, showTicketBtn: 'true', provider: 'unibet', teamId: WIDGET_TEAM_ID }}
            minHeight={280}
            label="Kampheader"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
          Analyse
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Før kampen
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Formguide
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="MTSFormH2HSnap"
                params={{ eventId, acrossAllTournaments: 'true', teamId: WIDGET_TEAM_ID }}
                minHeight={200}
                label="Formguide"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Indbyrdes opgør
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="H2HTeams"
                params={{ eventId, teamId: WIDGET_TEAM_ID }}
                minHeight={260}
                label="Indbyrdes opgør"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Stilling
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="SPDKTournamentTable"
                params={{ eventId, tournamentId: WIDGET_TOURNAMENT_ID, teamId: WIDGET_TEAM_ID }}
                minHeight={420}
                label="Stilling"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Sjove statistikker
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="EventTeamFunStats"
                params={{ eventId, fault: 2, limit: 10, teamId: WIDGET_TEAM_ID }}
                minHeight={300}
                label="Sjove statistikker"
              />
            </div>
          </div>
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
          Hold
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Opstilling
        </h2>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKLineup"
            params={{ eventId, teamId: WIDGET_TEAM_ID }}
            minHeight={520}
            label="Opstilling"
          />
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
          {isLive ? 'Live nu' : isFinished ? 'Kampreferat' : 'Under kampen'}
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          {isLive ? (
            <span class="inline-flex items-center gap-3">
              Live
              <span class="w-3 h-3 rounded-full" style="background:#00FF1F;box-shadow:0 0 8px #00FF1F;animation:pulse 1.5s ease-in-out infinite"></span>
            </span>
          ) : 'Statistik'}
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Momentum
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="MatchMomentum"
                params={{ eventId, teamId: WIDGET_TEAM_ID }}
                minHeight={220}
                label="Momentum"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Hændelser
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="IncidentListOpta"
                params={{ eventId, header: 'true', card: 'true', initialCollapse: 'false', teamId: WIDGET_TEAM_ID }}
                minHeight={320}
                label="Hændelser"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              Kampstatistik
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="LivePostMatchStatsOpta"
                params={{ eventId, header: 'false', teamId: WIDGET_TEAM_ID }}
                minHeight={360}
                label="Kampstatistik"
              />
            </div>
          </div>

          <div>
            <h3 class="text-[0.6rem] font-bold uppercase mb-3 text-gray-400 tracking-[0.18em]">
              xG — Forventede mål
            </h3>
            <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
              <SiWidget
                widget="TwoTeamsXGoalsPitch"
                params={{
                  eventId,
                  tournamentId: WIDGET_TOURNAMENT_ID,
                  dotSize: 32.5,
                  header: 'true',
                  teamId: WIDGET_TEAM_ID,
                }}
                minHeight={480}
                label="xG bane"
              />
            </div>
          </div>
        </div>
      </section>

      <section>
        <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
          Video
        </p>
        <h2
          class="font-black mb-8 text-[#111]"
          style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
        >
          Højdepunkter
        </h2>
        <div class="overflow-hidden" style="background:#060806;border:1px solid #152214">
          <SiWidget
            widget="SPDKMatchVideo"
            params={{ eventId, teamId: WIDGET_TEAM_ID, seasonId: WIDGET_SEASON_ID }}
            minHeight={400}
            label="Kampvideo"
          />
        </div>
      </section>

      {socialEmbeds.length > 0 && (
        <section>
          <p class="text-[0.6rem] font-bold uppercase mb-2 tracking-[0.2em]" style={`color:${accentColor}`}>
            Social
          </p>
          <h2
            class="font-black mb-8 text-[#111]"
            style="font-size:clamp(1.5rem,3vw,2.25rem);letter-spacing:-0.03em"
          >
            Fra sociale medier
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 items-start">
            {socialEmbeds.map((embed) => (
              <div class="flex flex-col gap-3">
                <div set:html={embed.embedCode} />
                {embed.caption && <p class="text-sm text-[#6B7280]">{embed.caption}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

    </div>
  </div>
</Base>
