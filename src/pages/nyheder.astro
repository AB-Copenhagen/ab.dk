---
import Base from '@/layouts/Base.astro';
import { fetchCollectionType, strapiMediaUrl } from '@/lib/strapi/client';
import { truncate } from '@/lib/utils';
export const prerender = false;

const locale = 'da';

const allArticles = await fetchCollectionType<any[]>('articles', {
  locale,
  sort: ['publishedAt:desc'],
  populate: ['image', 'categories'],
  pagination: { pageSize: 13 },
}).catch(() => [] as any[]);

const [featured, ...rest] = allArticles;

function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString('da-DK', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return ''; }
}
---

<Base locale="da" title="Nyheder | Akademisk Boldklub">
  <!-- Hero: full-width with image + overlay -->
  {featured ? (
    <section class="relative w-full overflow-hidden" style="height:clamp(400px,52vw,660px)">
      {featured.image?.url ? (
        <img
          src={strapiMediaUrl(featured.image.url)}
          alt={featured.title}
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      ) : (
        <div class="absolute inset-0" style="background:#006A52"></div>
      )}
      <!-- gradient: dark on left, fading right -->
      <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(0,0,0,0.78) 0%,rgba(0,0,0,0.42) 55%,transparent 100%)"></div>

      <div class="relative h-full max-w-7xl mx-auto px-5 md:px-12 flex items-end pb-14 md:pb-20">
        <div style="max-width:560px">
          <p class="text-xs font-bold uppercase mb-3" style="color:#00FF1F;letter-spacing:0.2em">
            {featured.categories?.[0]?.name ?? 'Feature'}
          </p>
          <h1 class="font-black text-white mb-4 leading-none" style="font-size:clamp(1.9rem,4.5vw,3.4rem);letter-spacing:-0.03em">
            {featured.title}
          </h1>
          {featured.description && (
            <p class="text-sm leading-relaxed mb-8" style="color:rgba(255,255,255,0.72)">
              {truncate(featured.description, 160)}
            </p>
          )}
          <a
            href={`/blog/${featured.slug}`}
            class="news-hero-cta inline-block px-6 py-3 text-sm font-bold text-white transition-colors"
            style="border:1.5px solid rgba(255,255,255,0.55)"
          >
            Læs mere
          </a>
        </div>
      </div>
    </section>
  ) : null}

  <!-- Card grid -->
  <section style="background:#fff">
    <div class="max-w-7xl mx-auto px-5 md:px-12 py-12 md:py-16">
      {rest.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-12">
          {rest.map((article: any) => (
            <a href={`/blog/${article.slug}`} class="group block">
              <div class="overflow-hidden mb-4" style="aspect-ratio:1/1;background:#F3F4F6">
                {article.image?.url ? (
                  <img
                    src={strapiMediaUrl(article.image.url)}
                    alt={article.title}
                    loading="lazy"
                    class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center font-black text-4xl" style="color:rgba(0,106,82,0.15)">AB</div>
                )}
              </div>
              <p class="text-xs font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.16em">
                {article.categories?.[0]?.name ?? 'Nyheder'}
              </p>
              <h2 class="font-bold text-base leading-snug" style="color:#111;letter-spacing:-0.01em">
                {article.title}
              </h2>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center py-24 text-sm" style="color:#9CA3AF">
          {featured ? 'Ingen øvrige nyheder.' : 'Ingen nyheder endnu.'}
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  .news-hero-cta:hover { background: white; color: black; border-color: white; }
</style>
