---
import Base from '@/layouts/Base.astro';
import ArticleContent from '@/components/islands/ArticleContent';
import FixturesWidget from '@/components/FixturesWidget.astro';
import StandingsWidget from '@/components/StandingsWidget.astro';
import { fetchCollectionType, strapiMediaUrl } from '@/lib/strapi/client';
import { truncate, decodeHtml } from '@/lib/utils';
export const prerender = false;

const { slug } = Astro.params;
const locale = 'da';
const STRAPI_URL = import.meta.env.STRAPI_URL ?? 'http://localhost:1337';

const results = await fetchCollectionType<any[]>('articles', {
  locale,
  filters: { slug: { $eq: slug } },
  populate: ['image', 'categories'],
}).catch(() => [] as any[]);

const article = results[0];
if (!article) return Astro.redirect('/nyheder');

const allArticles = await fetchCollectionType<any[]>('articles', {
  locale,
  sort: ['publishedAt:desc'],
  populate: ['image', 'categories'],
  pagination: { pageSize: 50 },
}).catch(() => [] as any[]);

const idx = allArticles.findIndex((a: any) => a.slug === slug);
const prevArticle = idx < allArticles.length - 1 ? allArticles[idx + 1] : null;
const nextArticle = idx > 0 ? allArticles[idx - 1] : null;
const related = allArticles.filter((a: any) => a.slug !== slug).slice(0, 3);

function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString('da-DK', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return ''; }
}
---

<Base locale="da" title={`${decodeHtml(article.title)} | Akademisk Boldklub`}>
  <article style="color:#111;">

    <!-- ── Header: billede venstre | titel + uddrag + dato højre ── -->
    <div class="grid grid-cols-1 md:grid-cols-2" style="min-height:clamp(340px,45vw,560px);">
      <!-- Venstre: billede -->
      <div class="relative overflow-hidden" style="min-height:clamp(260px,40vw,520px);">
        {article.image?.url ? (
          <img src={strapiMediaUrl(article.image.url)} alt={decodeHtml(article.title)}
               loading="eager" class="absolute inset-0 w-full h-full object-cover object-center" />
        ) : (
          <div class="absolute inset-0" style="background:#006A52;"></div>
        )}
      </div>
      <!-- Højre: centreret indhold på beige -->
      <div class="flex flex-col items-center justify-center text-center px-10 md:px-16 py-14"
           style="background:#F4F4F4;">
        <h1 class="font-black leading-tight mb-6"
            style="font-size:clamp(2rem,3.5vw,3.5rem); letter-spacing:-0.04em; color:#111; text-align:center;">
          {decodeHtml(article.title)}
        </h1>
        {article.description && (
          <p class="leading-relaxed mb-6"
             style="font-size:clamp(0.9rem,1.3vw,1.05rem); color:#111; max-width:440px;">
            {truncate(decodeHtml(article.description), 220)}
          </p>
        )}
        <time class="font-bold text-sm" style="color:#111;">
          {formatDate(article.publishedAt)}
        </time>
      </div>
    </div>

    <!-- ── Brødtekst: nav | indhold | sidebar ────────────────────── -->
    <div style="background:#fff; color:#111;">
      <div class="max-w-[1680px] mx-auto px-5 md:px-10 py-12 md:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-[140px_1fr_320px] gap-10 lg:gap-12 items-start">

          <!-- Venstre: Næste / Forrige (kun labels) -->
          <div class="hidden lg:block pt-1">
            <div class="mb-4">
              {nextArticle ? (
                <a href={`/blog/${nextArticle.slug}`} class="font-black text-sm hover:underline" style="color:#111;">Næste indlæg</a>
              ) : (
                <p class="font-black text-sm" style="color:#9CA3AF;">Næste indlæg</p>
              )}
            </div>
            <div>
              {prevArticle ? (
                <a href={`/blog/${prevArticle.slug}`} class="font-black text-sm hover:underline" style="color:#111;">Forrige indlæg</a>
              ) : (
                <p class="font-black text-sm" style="color:#9CA3AF;">Forrige indlæg</p>
              )}
            </div>
          </div>

          <!-- Centrum: kategori + artikelindhold + del -->
          <div style="color:#111;">
            {article.categories?.[0] && (
              <p class="font-bold mb-6 underline underline-offset-2" style="font-size:0.85rem; color:#006A52;">
                {article.categories[0].name}
              </p>
            )}
            {article.content && (
              <div class="article-prose">
                <ArticleContent content={article.content} strapiUrl={STRAPI_URL} client:load />
              </div>
            )}

            <!-- Del -->
            {(() => {
              const shareUrl = encodeURIComponent(Astro.url.href);
              const shareTitle = encodeURIComponent(decodeHtml(article.title));
              return (
                <div class="mt-10 pt-8 border-t border-gray-200">
                  <p class="text-xs font-black mb-3" style="color:#111;">Del dette:</p>
                  <div class="flex items-center gap-3">
                    <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
                       target="_blank" rel="noopener noreferrer"
                       aria-label="Del på Facebook"
                       class="flex items-center justify-center rounded-full transition-opacity hover:opacity-75"
                       style="width:36px; height:36px; background:#006A52; color:#fff;">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href={`https://x.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`}
                       target="_blank" rel="noopener noreferrer"
                       aria-label="Del på X"
                       class="flex items-center justify-center rounded-full transition-opacity hover:opacity-75"
                       style="width:36px; height:36px; background:#006A52; color:#fff;">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                  </div>
                </div>
              );
            })()}

            <!-- Mobil: næste/forrige -->
            <div class="flex justify-between mt-8 pt-6 border-t border-gray-100 lg:hidden text-sm font-bold">
              {prevArticle ? (
                <a href={`/blog/${prevArticle.slug}`} style="color:#006A52;">← Forrige</a>
              ) : <span />}
              {nextArticle ? (
                <a href={`/blog/${nextArticle.slug}`} style="color:#006A52;">Næste →</a>
              ) : <span />}
            </div>
          </div>

          <!-- Højre: sidebar widgets -->
          <aside class="sticky top-6 space-y-4">
            <div style="background:#fff; border:1px solid #E5E7EB; border-radius:4px; overflow:hidden;">
              <FixturesWidget locale="da" limit={10} theme="light" />
            </div>
            <div style="background:#fff; border:1px solid #E5E7EB; border-radius:4px; overflow:hidden;">
              <StandingsWidget locale="da" />
            </div>
          </aside>

        </div>
      </div>
    </div>

    <!-- ── Relaterede nyheder ─────────────────────────────────── -->
    {related.length > 0 && (
      <div style="background:#fff; border-top:1px solid #E5E7EB;">
        <div class="max-w-[1680px] mx-auto px-5 md:px-10 py-12 md:py-16">
          <h2 class="font-black mb-8" style="font-size:clamp(1.1rem,1.6vw,1.4rem); letter-spacing:-0.02em; color:#111;">
            Relaterede nyheder
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8">
            {related.map((a: any) => (
              <a href={`/blog/${a.slug}`} class="group block">
                <div class="overflow-hidden mb-4" style="aspect-ratio:3/2; background:#F3F4F6;">
                  {a.image?.url ? (
                    <img src={strapiMediaUrl(a.image.url)} alt={decodeHtml(a.title)}
                         loading="lazy"
                         class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center font-black text-4xl" style="color:rgba(0,106,82,0.15);">AB</div>
                  )}
                </div>
                {a.categories?.[0] && (
                  <p class="font-bold mb-2 underline underline-offset-2" style="font-size:0.8rem; color:#006A52;">
                    {a.categories[0].name}
                  </p>
                )}
                <h3 class="font-black leading-snug" style="font-size:clamp(1.1rem,1.8vw,1.5rem); letter-spacing:-0.03em; color:#111;">
                  {decodeHtml(a.title)}
                </h3>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

  </article>
</Base>

<style is:global>
  .article-prose { color: #111; line-height: 1.8; font-size: 0.9375rem; }
  .article-prose h1, .article-prose h2, .article-prose h3, .article-prose h4 {
    color: #111; letter-spacing: -0.02em; margin-top: 1.75em; margin-bottom: 0.5em; font-weight: 900;
  }
  .article-prose p { margin-bottom: 1.25em; color: #111; }
  .article-prose a { color: #006A52; text-decoration: underline; text-underline-offset: 3px; }
  .article-prose strong { color: #111; }
  .article-prose blockquote { border-left: 3px solid #006A52; padding-left: 1em; color: #6B7280; font-style: italic; }
  .article-prose ul > li::marker { color: #006A52; }
  .article-prose ol > li::marker { color: #9CA3AF; }
  .article-prose hr { border-color: #E5E7EB; margin: 2em 0; }
  .article-prose img { max-width: 100%; }
</style>
