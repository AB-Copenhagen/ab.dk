---
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
import { isSearchIndexingBlocked } from '@/lib/config/seo';
import { fetchSingleType } from '@/lib/strapi/client';
import type { Locale } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  ogImage?: string;
}

const {
  title = 'Akademisk Boldklub — AB 1889',
  description = 'Akademisk Boldklub er en dansk fodboldklub grundlagt i 1889.',
  locale = 'da',
  ogImage,
} = Astro.props;

const resolvedOgImage = ogImage ?? `${Astro.url.origin}/images/og-default.png`;

let globalData: any = null;
try {
  globalData = await fetchSingleType('global', { locale });
} catch {
  // CMS unavailable — render with fallbacks
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      isSearchIndexingBlocked() && (
        <>
          <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
          <meta name="googlebot" content="noindex, nofollow" />
        </>
      )
    }
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="da" href={Astro.url.href.replace('/en', '')} />
    <link rel="alternate" hreflang="en" href={Astro.url.href.includes('/en') ? Astro.url.href : `/en${Astro.url.pathname}`} />
    <script is:inline src="https://vivenu.com/web/deliver/js/v1/embed.js"></script>
  </head>
  <body class="min-h-screen bg-white text-[#111]">
    <Navbar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} globalData={globalData} />
  </body>
</html>
