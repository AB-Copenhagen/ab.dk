---
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import CookieConsentBanner from '@/components/CookieConsentBanner.astro';
import '@/styles/global.css';
import { isSearchIndexingBlocked } from '@/lib/config/seo';
import { fetchSingleType } from '@/lib/strapi/client';
import { switchLocalePath } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { CONSENT_COOKIE_NAME, parseConsent, hasConsent } from '@/lib/consent';

interface Props {
  title?: string;
  description?: string;
  /** Falls back to `title` — set only when the social card should read differently from the <title>/SEO meta description. */
  ogTitle?: string;
  ogDescription?: string;
  locale?: Locale;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Akademisk Boldklub — AB 1889',
  description = 'Akademisk Boldklub (AB 1889) er en dansk fodboldklub fra Gladsaxe, grundlagt i 1889. Følg holdet, kampe og nyheder.',
  ogTitle = title,
  ogDescription = description,
  locale = 'da',
  ogImage,
  ogType = 'website',
  structuredData,
} = Astro.props;

// Canonical/hreflang always point at the production domain. og:image, however, must be
// reachable by whatever host actually served this response — on local dev or a Vercel
// preview/staging deployment that's the local/preview URL, not ab.dk (which won't resolve
// to this app pre-launch).
const isVercelProduction = import.meta.env.VERCEL_ENV === 'production';
const assetOrigin = isVercelProduction ? (Astro.site?.origin ?? Astro.url.origin) : Astro.url.origin;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${assetOrigin}${ogImage}`)
  : `${assetOrigin}/images/og-default.png`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const hreflangDaUrl = new URL(switchLocalePath(Astro.url.pathname, 'da'), Astro.site).href;
const hreflangEnUrl = new URL(switchLocalePath(Astro.url.pathname, 'en'), Astro.site).href;
const ogLocale = locale === 'en' ? 'en_US' : 'da_DK';
const ogLocaleAlternate = locale === 'en' ? 'da_DK' : 'en_US';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsTeam',
  name: 'Akademisk Boldklub',
  alternateName: 'AB 1889',
  url: 'https://ab.dk',
  logo: 'https://ab.dk/images/ab-logo.svg',
  sport: 'Soccer',
  foundingDate: '1889',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Gladsaxevej 202',
    postalCode: '2860',
    addressLocality: 'Søborg',
    addressCountry: 'DK',
  },
  sameAs: [
    'https://www.instagram.com/abfodbold/',
    'https://www.facebook.com/akademiskboldklub',
    'https://www.youtube.com/@akademisk-boldklub',
  ],
};

const structuredDataList = [
  organizationSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
];

let globalData: any = null;
try {
  globalData = await fetchSingleType('global', { locale });
} catch {
  // CMS unavailable — render with fallbacks
}

// The Vivenu ticket-embed script sets its own cookies once loaded, so it's gated behind
// functional consent. Server-render it only for returning visitors who already consented —
// first-time visitors (and prerendered pages, which have no per-request cookies to read)
// get it injected client-side instead, via the script below.
const vivenuConsented = Astro.isPrerendered
  ? false
  : hasConsent(parseConsent(Astro.cookies.get(CONSENT_COOKIE_NAME)?.value), 'functional');

// Google Tag Manager (fires the GA4 config tag internally) — gated behind statistics consent,
// same SSR/client-injection split as Vivenu above.
const GTM_ID = 'GTM-TGXD56HD';
const statisticsConsented = Astro.isPrerendered
  ? false
  : hasConsent(parseConsent(Astro.cookies.get(CONSENT_COOKIE_NAME)?.value), 'statistics');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      isSearchIndexingBlocked() && (
        <>
          <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
          <meta name="googlebot" content="noindex, nofollow" />
        </>
      )
    }
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AB 1889" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="da" href={hreflangDaUrl} />
    <link rel="alternate" hreflang="en" href={hreflangEnUrl} />
    <link rel="alternate" hreflang="x-default" href={hreflangDaUrl} />
    {structuredDataList.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {vivenuConsented && (
      <script is:inline id="vivenu-embed-script" src="https://vivenu.com/web/deliver/js/v1/embed.js"></script>
    )}
    {statisticsConsented && (
      <script
        is:inline
        id="gtm-script"
        set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`}
      />
    )}
  </head>
  <body class="min-h-screen bg-white text-[#111]">
    <Navbar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} globalData={globalData} />
    <CookieConsentBanner locale={locale} />
    <script>
      import { onConsentChange } from '@/lib/consent-gate-client';

      onConsentChange('functional', () => {
        if (document.getElementById('vivenu-embed-script')) return;
        const script = document.createElement('script');
        script.id = 'vivenu-embed-script';
        script.src = 'https://vivenu.com/web/deliver/js/v1/embed.js';
        document.head.appendChild(script);
      });

      onConsentChange('statistics', () => {
        if (document.getElementById('gtm-script')) return;
        const w = window as unknown as { dataLayer?: unknown[] };
        w.dataLayer = w.dataLayer || [];
        w.dataLayer.push({ 'gtm.start': Date.now(), event: 'gtm.js' });
        const script = document.createElement('script');
        script.id = 'gtm-script';
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-TGXD56HD';
        document.head.appendChild(script);
      });
    </script>
  </body>
</html>
