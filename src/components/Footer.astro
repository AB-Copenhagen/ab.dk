---
interface Props {
  locale?: string;
  globalData?: any;
}

const { locale = 'da', globalData } = Astro.props;
const d = globalData;
const year = new Date().getFullYear();

const contactLinks = d?.internal_links as { text: string; URL: string }[] | undefined;
const resourceLinks = d?.policy_links as { text: string; URL: string }[] | undefined;
const socialLinks = d?.social_media_links as { text: string; URL: string }[] | undefined;
---

<!-- Sponsor row (white bg) -->
<div style="background:#fff; border-top:1px solid #e5e7eb; padding:48px 0;">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex flex-nowrap items-center justify-between gap-8">
      {[
        { src: '/images/sponsors/carlsberg.png', alt: 'Carlsberg' },
        { src: '/images/sponsors/datum.png', alt: 'Datum' },
        { src: '/images/sponsors/myriad360.png', alt: 'Myriad360' },
        { src: '/images/sponsors/unisport.png', alt: 'Unisport' },
        { src: '/images/sponsors/plane.png', alt: 'Plane' },
      ].map(({ src, alt }) => (
        <img
          src={src}
          alt={alt}
          class="sponsor-logo"
          style="width:180px; height:60px; object-fit:contain; object-position:center; flex-shrink:0;"
        />
      ))}
    </div>
  </div>
</div>

<!-- Footer -->
<footer style="background:#0A0A09;">
  <div class="max-w-[1680px] mx-auto px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr_auto] gap-12 lg:gap-20 items-center">

      <!-- Left: AB 1889 wordmark SVG — large -->
      <div class="shrink-0">
        <img
          src="/images/ab-logo-wordmark.svg"
          alt="AB 1889"
          style="width:clamp(180px,18vw,300px); height:auto;"
        />
      </div>

      <!-- Center: link columns -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-10">
        <!-- Contact -->
        <div>
          <p class="font-black mb-5" style="color:#fff; font-size:0.95rem;">
            {locale === 'da' ? 'Kontakt' : 'Contact'}
          </p>
          {contactLinks?.length ? (
            <ul class="flex flex-col gap-3">
              {contactLinks.map((link) => (
                <li>
                  <a href={link.URL} class="footer-link text-sm hover:opacity-70 transition-opacity" style="color:#fff; text-decoration:none;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-3">
              <li><span class="text-sm" style="color:#fff;">info@ab.dk</span></li>
              <li><span class="text-sm" style="color:#fff;">+45 60399901</span></li>
              <li><span class="text-sm" style="color:#fff;">Gladsaxevej 202, 2860</span></li>
              <li><span class="text-sm" style="color:#fff;">{locale === 'da' ? 'Søborg Danmark' : 'Søborg Denmark'}</span></li>
            </ul>
          )}
        </div>

        <!-- Social Media -->
        <div>
          <p class="font-black mb-5" style="color:#fff; font-size:0.95rem;">
            Social Media
          </p>
          {socialLinks?.length ? (
            <ul class="flex flex-col gap-3">
              {socialLinks.map((link) => (
                <li>
                  <a href={link.URL} target="_blank" rel="noreferrer" class="text-sm hover:opacity-70 transition-opacity" style="color:#fff; text-decoration:none;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-3">
              {['Instagram', 'LinkedIn', 'Facebook', 'YouTube', 'TikTok'].map((s) => (
                <li><span class="text-sm" style="color:#fff;">{s}</span></li>
              ))}
            </ul>
          )}
        </div>

        <!-- Resources -->
        <div>
          <p class="font-black mb-5" style="color:#fff; font-size:0.95rem;">
            Resources
          </p>
          {resourceLinks?.length ? (
            <ul class="flex flex-col gap-3">
              {resourceLinks.map((link) => (
                <li>
                  <a href={link.URL} class="text-sm hover:opacity-70 transition-opacity" style="color:#fff; text-decoration:none;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-3">
              {[
                [locale === 'da' ? 'Køb billetter' : 'Buy tickets', '#'],
                [locale === 'da' ? 'Book event' : 'Book an event', '#'],
                [locale === 'da' ? 'Bliv sponsor' : 'Become a sponsor', '#'],
                [locale === 'da' ? 'Privatlivspolitik' : 'Privacy policy', '#'],
                [locale === 'da' ? 'Refunderings- og returpolitik' : 'Refund and Return Policy', '#'],
              ].map(([label]) => (
                <li><span class="text-sm" style="color:#fff;">{label}</span></li>
              ))}
            </ul>
          )}
        </div>
      </div>

      <!-- Right: AB circular crest -->
      <div class="hidden lg:block shrink-0 self-center">
        <img
          src="/images/ab-crest.svg"
          alt="AB 1889"
          style="width:clamp(120px,12vw,180px); height:auto; opacity:0.85;"
        />
      </div>
    </div>
  </div>

  <!-- Neon green copyright strip -->
  <div style="background:#00FF1F; padding:1rem 2rem; text-align:center;">
    <p class="text-sm font-bold" style="color:#0A0A09;">
      {d?.copyright ?? `© ${year} AB Gladsaxe. All rights reserved.`}
    </p>
  </div>
</footer>

<style>
  .sponsor-logo:hover { opacity: 0.75; }
</style>
