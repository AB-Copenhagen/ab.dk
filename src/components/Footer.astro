---
interface Props {
  locale?: string;
  globalData?: any;
}

const { locale = 'da', globalData } = Astro.props;
const d = globalData;
const year = new Date().getFullYear();

const contactLinks = d?.internal_links as { text: string; URL: string }[] | undefined;
const resourceLinks = d?.policy_links as { text: string; URL: string }[] | undefined;
const socialLinks = d?.social_media_links as { text: string; URL: string }[] | undefined;
---

<!-- Sponsor row (white bg) -->
<div style="background:#fff; border-top:1px solid #e5e7eb; padding:48px 0;">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex flex-nowrap items-center justify-between gap-8">
      {[
        { src: '/images/sponsors/carlsberg.png', alt: 'Carlsberg' },
        { src: '/images/sponsors/datum.png', alt: 'Datum' },
        { src: '/images/sponsors/myriad360.png', alt: 'Myriad360' },
        { src: '/images/sponsors/select-sport.png', alt: 'Select Sport' },
        { src: '/images/sponsors/plane.png', alt: 'Plane' },
      ].map(({ src, alt }) => (
        <img
          src={src}
          alt={alt}
          style="height:36px; width:auto; object-fit:contain; filter:grayscale(100%); opacity:0.55; transition:filter 0.3s, opacity 0.3s;"
          class="sponsor-logo"
        />
      ))}
    </div>
  </div>
</div>

<!-- Footer -->
<footer style="background:#0A0A09;">
  <div class="max-w-7xl mx-auto px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr_auto] gap-12 lg:gap-16 items-start">

      <!-- Left: AB 1889 wordmark SVG -->
      <div class="shrink-0">
        <img
          src="/images/ab-logo-wordmark.svg"
          alt="AB 1889"
          width="220"
          height="221"
          style="width:clamp(140px,14vw,220px); height:auto; opacity:0.92;"
        />
      </div>

      <!-- Center: link columns -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-10">
        <!-- Contact / Club -->
        <div>
          <p class="text-xs font-black uppercase mb-4" style="color:rgba(255,255,255,0.35); letter-spacing:0.18em;">
            {locale === 'da' ? 'Klub' : 'Contact'}
          </p>
          {contactLinks?.length ? (
            <ul class="flex flex-col gap-2.5">
              {contactLinks.map((link) => (
                <li>
                  <a href={link.URL} class="text-xs font-bold hover:text-white transition-colors" style="color:rgba(255,255,255,0.5); text-decoration:none; letter-spacing:-0.01em;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-2.5">
              <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">info@ab.dk</span></li>
              <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">+45 39 62 09 00</span></li>
              <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">Gladsaxevej 202, 2860</span></li>
              <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">Søborg, Danmark</span></li>
            </ul>
          )}
        </div>

        <!-- Social Media -->
        <div>
          <p class="text-xs font-black uppercase mb-4" style="color:rgba(255,255,255,0.35); letter-spacing:0.18em;">
            Social Media
          </p>
          {socialLinks?.length ? (
            <ul class="flex flex-col gap-2.5">
              {socialLinks.map((link) => (
                <li>
                  <a href={link.URL} target="_blank" rel="noreferrer" class="text-xs font-bold hover:text-white transition-colors" style="color:rgba(255,255,255,0.5); text-decoration:none; letter-spacing:-0.01em;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-2.5">
              {['Instagram', 'LinkedIn', 'Facebook', 'YouTube', 'TikTok'].map((s) => (
                <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">{s}</span></li>
              ))}
            </ul>
          )}
        </div>

        <!-- Resources -->
        <div>
          <p class="text-xs font-black uppercase mb-4" style="color:rgba(255,255,255,0.35); letter-spacing:0.18em;">
            Resources
          </p>
          {resourceLinks?.length ? (
            <ul class="flex flex-col gap-2.5">
              {resourceLinks.map((link) => (
                <li>
                  <a href={link.URL} class="text-xs font-bold hover:text-white transition-colors" style="color:rgba(255,255,255,0.5); text-decoration:none; letter-spacing:-0.01em;">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <ul class="flex flex-col gap-2.5">
              {[
                locale === 'da' ? 'Køb billetter' : 'Buy tickets',
                locale === 'da' ? 'Book event' : 'Book an event',
                locale === 'da' ? 'Bliv sponsor' : 'Become a sponsor',
                locale === 'da' ? 'Privatlivspolitik' : 'Privacy policy',
                locale === 'da' ? 'Refunderings- og returpolitik' : 'Refund and Return Policy',
              ].map((label) => (
                <li><span class="text-xs" style="color:rgba(255,255,255,0.25);">{label}</span></li>
              ))}
            </ul>
          )}
        </div>
      </div>

      <!-- Right: AB circular crest (decorative) -->
      <div class="hidden lg:block shrink-0 self-center">
        <img
          src="/images/ab-crest.svg"
          alt="AB 1889"
          width="160"
          height="160"
          style="opacity:0.55;"
        />
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-6 border-t" style="border-color:rgba(255,255,255,0.08);">
      <p class="text-xs" style="color:rgba(255,255,255,0.25); letter-spacing:-0.01em;">
        {d?.copyright ?? `© ${year} AB Akademisk Boldklub. Alle rettigheder forbeholdes.`}
      </p>
    </div>
  </div>
</footer>

<style>
  .sponsor-logo:hover { filter: grayscale(0%) !important; opacity: 1 !important; }
</style>
