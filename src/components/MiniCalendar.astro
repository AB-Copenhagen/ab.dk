---
import { localePath, translate, type Locale } from '@/lib/i18n';
import type { SIEvent } from '@/lib/si/client';

interface Props {
  locale: Locale;
  events: SIEvent[];
}

const { locale, events } = Astro.props;

const now = new Date();
const calYear = now.getFullYear();
const calMonth = now.getMonth();
const calToday = now.getDate();
const calDaysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
const firstDow = new Date(calYear, calMonth, 1).getDay();
const calBlanks = firstDow === 0 ? 6 : firstDow - 1;
const calMonthOnly = new Date(calYear, calMonth, 1).toLocaleDateString(
  locale === 'da' ? 'da-DK' : 'en-US',
  { month: 'long' }
);
const calDayLabels = translate(locale, 'calendarDayLabels').split(',');
const calMatchDays = new Set<number>(
  events
    .filter((e) => {
      const d = new Date(e.startDate);
      return d.getFullYear() === calYear && d.getMonth() === calMonth;
    })
    .map((e) => new Date(e.startDate).getDate())
);
const calTotalCells = Math.ceil((calBlanks + calDaysInMonth) / 7) * 7;
const calCells = Array.from({ length: calTotalCells }, (_, i) => {
  const day = i - calBlanks + 1;
  const valid = day >= 1 && day <= calDaysInMonth;
  return {
    day,
    valid,
    isToday: valid && day === calToday,
    hasMatch: valid && calMatchDays.has(day),
  };
});
---

<style>
  .mini-cal-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.5rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--ab-white);
    cursor: pointer;
  }
</style>

<div id="mini-calendar" class="lg:col-span-4 overflow-hidden">
  <div class="px-6 py-5 flex items-center justify-between bg-ab-green">
    <button
      type="button"
      class="mini-cal-nav"
      aria-label={translate(locale, 'prevMonth')}>
      <svg
        width="18"
        height="24"
        viewBox="0 0 18 24"
        fill="none"
        aria-hidden="true">
        <path d="M14 2L4 12L14 22" stroke="currentColor" stroke-width="2"></path>
      </svg>
    </button>
    <h3
      class="font-black text-white text-center leading-[0.86] tracking-[-0.04em] capitalize"
      style="font-size:clamp(1.5rem,2.8vw,2.1875rem)">
      {calMonthOnly}
      <br />
      {translate(locale, 'monthSchedule')}
    </h3>
    <button
      type="button"
      class="mini-cal-nav"
      aria-label={translate(locale, 'nextMonth')}>
      <svg
        width="18"
        height="24"
        viewBox="0 0 18 24"
        fill="none"
        aria-hidden="true">
        <path d="M4 2L14 12L4 22" stroke="currentColor" stroke-width="2"></path>
      </svg>
    </button>
  </div>

  <div class="grid grid-cols-7 text-center py-2.5 bg-ab-neon">
    {
      calDayLabels.map((lbl) => (
        <span class="text-[1rem] font-black text-ab-green tracking-[-0.04em]">
          {lbl}
        </span>
      ))
    }
  </div>

  <div class="grid grid-cols-7 bg-[#f4f4f4]">
    {
      calCells.map((cell) => (
        <div
          class:list={[
            'flex items-center justify-center min-h-[4.5rem] text-[1rem] tracking-[-0.04em] text-ab-green',
            !cell.valid && 'invisible',
            cell.valid &&
              (cell.isToday
                ? 'bg-white font-black'
                : cell.hasMatch
                  ? 'font-black'
                  : 'font-normal'),
          ]}>
          {cell.valid ? cell.day : ''}
        </div>
      ))
    }
  </div>

  <div class="text-center py-5 bg-[#f4f4f4]">
    <a
      href={localePath(locale, '/kampe')}
      class="text-[1.125rem] font-normal underline text-ab-green tracking-[-0.02em]">
      {translate(locale, 'seeAllEvents')}
    </a>
  </div>
</div>
