---
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

interface Props {
  player: {
    id?: number;
    name?: string;
    position?: string;
    role?: string;
    jerseyNumber?: number;
    number?: number;
    nationality?: string;
    stats?: { appearances?: number; goals?: number; assists?: number };
  };
  locale: 'da' | 'en';
}

const { player, locale } = Astro.props;
const number = player.jerseyNumber ?? player.number;
const position = player.position ?? player.role ?? '';
const photoUrl = getPlayerPhotoUrl(player.name);
---

<div
  class="relative border border-[#1A2018] bg-[#0D1410] transition-colors duration-200 hover:border-ab-green group overflow-hidden"
>
  {number !== undefined && (
    <span class="absolute top-3 right-3 text-xs font-bold tabular-nums z-10 text-ab-gold opacity-50">
      {number}
    </span>
  )}

  <!-- Photo or silhouette -->
  <div class="relative flex items-end justify-center h-[96px]" style="background:linear-gradient(180deg,#081209 0%,#0D1410 100%)">
    {photoUrl ? (
      <img
        src={photoUrl}
        alt={player.name ?? ''}
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover object-top"
        style="object-position:center top;"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
    ) : null}
    <div class={`w-full h-full flex items-end justify-center${photoUrl ? ' hidden' : ''}`} aria-hidden="true">
      <svg width="44" height="56" viewBox="0 0 44 56" fill="none" class="opacity-20">
        <circle cx="22" cy="11" r="7" fill="#7A9185" />
        <path d="M8 26C8 18 36 18 36 26L40 50H4L8 26Z" fill="#7A9185" />
      </svg>
    </div>
  </div>

  <div class="px-3 pt-3 pb-4">
    <p class="text-sm font-bold text-white leading-tight truncate transition-colors group-hover:text-ab-gold" title={player.name}>
      {player.name ?? '—'}
    </p>

    {position && (
      <p class="text-[0.6rem] uppercase mt-1 truncate text-ab-green tracking-[0.12em]">
        {position}
      </p>
    )}

    {player.nationality && (
      <p class="text-[0.6rem] mt-1 truncate text-[#7A9185]">{player.nationality}</p>
    )}

    {player.stats && (
      <div class="flex gap-4 mt-3 pt-2 border-t border-[#1A2018]">
        {player.stats.appearances !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase text-[#7A9185] tracking-[0.12em]">
              {locale === 'da' ? 'Kam.' : 'App.'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.appearances}</p>
          </div>
        )}
        {player.stats.goals !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase text-[#7A9185] tracking-[0.12em]">
              {locale === 'da' ? 'Mål' : 'Gls'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.goals}</p>
          </div>
        )}
        {player.stats.assists !== undefined && (
          <div>
            <p class="text-[0.5rem] uppercase text-[#7A9185] tracking-[0.12em]">
              {locale === 'da' ? 'Ass.' : 'Ast.'}
            </p>
            <p class="text-xs font-bold text-white tabular-nums">{player.stats.assists}</p>
          </div>
        )}
      </div>
    )}
  </div>
</div>
