---
import Img from '@/components/Img.astro';

interface Shot {
  src: string;
  alt: string;
}

interface Props {
  shots: Shot[];
  class?: string;
}

const { shots, class: className } = Astro.props;
---

<div class:list={['relative mx-auto max-w-[800px]', className]} data-carousel>
  <div class="overflow-hidden">
    <div
      class="flex touch-pan-y cursor-grab select-none will-change-transform active:cursor-grabbing"
      data-track
      style="transform:translateX(0)"
    >
      {
        shots.map((shot, i) => (
          <div class="w-full shrink-0 px-1.5 sm:w-1/3">
            <Img
              src={shot.src}
              alt={shot.alt}
              width={270}
              height={480}
              class="pointer-events-none h-auto w-full"
              draggable="false"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))
      }
    </div>
  </div>

  <div class="mt-5 flex items-center justify-center gap-3">
    <button
      type="button"
      data-prev
      aria-label="Previous screenshots"
      class="flex h-7 w-7 items-center justify-center text-[#999] transition-opacity hover:text-[#333] disabled:opacity-30"
    >
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true">
        <path d="M7 1 1 7l6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="flex items-center gap-2" data-dots></div>

    <button
      type="button"
      data-next
      aria-label="Next screenshot"
      class="flex h-7 w-7 items-center justify-center text-[#999] transition-opacity hover:text-[#333] disabled:opacity-30"
    >
      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true">
        <path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<script>
  const EASE = 'transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
  const SWIPE_THRESHOLD = 40;

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-track]')!;
    const dotsContainer = root.querySelector<HTMLElement>('[data-dots]')!;
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]')!;
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]')!;
    const slides = Array.from(track.children) as HTMLElement[];

    let current = 0;
    let perPage = 1;
    let total = slides.length;
    let dots: HTMLElement[] = [];

    const width = () => root.offsetWidth;

    function measure() {
      const slideWidth = slides[0]?.offsetWidth || width();
      perPage = Math.max(1, Math.round(width() / slideWidth));
      total = Math.ceil(slides.length / perPage);
      current = Math.min(current, total - 1);
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      dots = Array.from({ length: total }, (_, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'carousel-dot';
        dot.style.cssText = 'height:6px;border-radius:3px;border:none;padding:0;cursor:pointer;transition:width 0.25s ease,background 0.25s ease';
        dot.setAttribute('aria-label', `Go to screenshots page ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
        return dot;
      });
    }

    function snap(animated: boolean) {
      track.style.transition = animated ? EASE : 'none';
      track.style.transform = `translateX(${-current * width()}px)`;
    }

    function render() {
      dots.forEach((dot, i) => {
        dot.style.width = i === current ? '20px' : '6px';
        dot.style.background = i === current ? 'var(--ab-green)' : '#D9D9D9';
      });
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === total - 1;
    }

    function goTo(n: number) {
      current = Math.max(0, Math.min(total - 1, n));
      snap(true);
      render();
    }

    measure();
    buildDots();
    snap(false);
    render();

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    let lastTotal = total;
    window.addEventListener(
      'resize',
      () => {
        measure();
        if (total !== lastTotal) {
          lastTotal = total;
          buildDots();
        }
        snap(false);
        render();
      },
      { passive: true }
    );

    // ── Drag / swipe ──────────────────────────────────────────
    let dragStartX = 0;
    let dragDelta = 0;
    let dragging = false;

    root.addEventListener(
      'pointerdown',
      (e) => {
        if ((e.target as Element).closest('button')) return;
        dragStartX = e.clientX;
        dragDelta = 0;
        dragging = true;
        track.style.transition = 'none';
        root.setPointerCapture(e.pointerId);
      },
      { passive: true }
    );

    root.addEventListener(
      'pointermove',
      (e) => {
        if (!dragging) return;
        dragDelta = e.clientX - dragStartX;
        track.style.transform = `translateX(${-current * width() + dragDelta}px)`;
      },
      { passive: true }
    );

    root.addEventListener('pointerup', () => {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(dragDelta) > SWIPE_THRESHOLD) {
        goTo(dragDelta < 0 ? current + 1 : current - 1);
      } else {
        snap(true);
      }
      dragDelta = 0;
    });

    root.addEventListener('pointercancel', () => {
      if (!dragging) return;
      dragging = false;
      dragDelta = 0;
      snap(true);
    });
  });
</script>
