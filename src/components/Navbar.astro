---
import MobileMenu from './islands/MobileMenu';
import LangSwitch from '@/components/layout/LangSwitch.astro';
import Logo from '@/components/brand/Logo.astro';
import { getNavConfig } from '@/lib/nav-config';

interface Props {
  locale?: string;
  globalData?: any;
}

const { locale = 'da', globalData } = Astro.props;
const nav = getNavConfig(locale);
const enPrefix = locale === 'en' ? '/en' : '';
---

<header class="sticky top-0 z-50 border-b" style="background:#080A08; border-color:rgba(0,106,82,0.2);">
  <!-- Pre-header -->
  <div class="border-b hidden md:block" style="border-color:rgba(255,255,255,0.06); background:#060806;">
    <div class="max-w-7xl mx-auto px-6 h-8 flex items-center justify-between">
      <div class="flex items-center gap-5">
        {nav.preHeader.left.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noreferrer' : undefined}
            class={[
              'text-[0.65rem] font-bold uppercase tracking-widest transition-colors',
              item.highlight
                ? 'hover:text-yellow-300'
                : 'text-white/40 hover:text-white/80',
            ].join(' ')}
            style={item.highlight ? 'color:#D6A02A' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
      <LangSwitch locale={locale as 'da' | 'en'} />
    </div>
  </div>

  <!-- Primary nav -->
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between gap-6">
    <!-- Logo — always render master SVG, never from font -->
    <a href={enPrefix + '/'} class="flex items-center gap-2 shrink-0" aria-label="AB 1889 — hjem">
      {globalData?.favicon?.url
        ? <img src={globalData.favicon.url} alt="AB 1889" class="h-8 w-auto object-contain" />
        : <Logo variant="white" size={32} />
      }
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden lg:flex items-center gap-1">
      {nav.primary.map((item) => (
        <div class="relative group">
          <a
            href={enPrefix + item.href}
            class="px-3 py-1.5 text-sm font-semibold text-white/70 hover:text-white transition-colors uppercase tracking-wide"
            style="letter-spacing:0.06em; font-size:0.72rem;"
          >
            {item.label}
          </a>
          {item.children && (
            <div
              class="absolute top-full left-0 hidden group-hover:block z-50 min-w-[180px] border py-1"
              style="background:#0D1A10; border-color:#152214;"
            >
              {item.children.map((child) => (
                <a
                  href={enPrefix + child.href}
                  class="block px-4 py-2 text-xs text-white/60 hover:text-white hover:bg-white/5 transition-colors"
                  style="letter-spacing:0.04em;"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Right: tickets + mobile menu -->
    <div class="flex items-center gap-3">
      <a
        href="https://billetter.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 text-xs font-bold uppercase px-4 py-2 text-white transition-colors hover:opacity-80"
        style="background:#006A52; letter-spacing:0.12em;"
      >
        {locale === 'da' ? 'Billetter' : 'Tickets'}
      </a>

      <!-- Mobile menu island -->
      <MobileMenu client:load nav={nav} locale={locale} enPrefix={enPrefix} />
    </div>
  </div>
</header>
