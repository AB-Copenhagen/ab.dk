---
import MobileMenu from './islands/MobileMenu';
import SearchModal from './islands/SearchModal';
import { getNavConfig, isNavItemActive } from '@/lib/nav-config';
import { translate, type Locale } from '@/lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'da' } = Astro.props;
const nav = getNavConfig(locale);
const enPrefix = locale === 'en' ? '/en' : '';
const currentPath = Astro.url.pathname;
const daPath = currentPath.replace(/^\/en/, '') || '/';
const enPath = '/en' + (currentPath.replace(/^\/en/, '') || '/');
---

<header class="sticky top-0 z-50">
  <!-- Utility bar: 45px, black -->
  <div
    class="nav-utility hidden md:flex items-center"
    style="background:#0A0A09;">
    <!-- Neon ABTV block -->
    <a
      href="https://abtv.ab.dk"
      target="_blank"
      rel="noreferrer"
      class="flex items-center justify-center shrink-0 h-full font-black"
      style="background:#00FF1F; width:171px; color:#006A52; text-decoration:none; font-size:15px; letter-spacing:-0.04em;">
      ABTV
    </a>
    <!-- Utility links -->
    <div class="flex items-center gap-8 px-8 flex-1">
      <a
        href="https://billet.ab.dk/"
        target="_blank"
        rel="noreferrer"
        class="text-white text-[15px] font-medium tracking-normal no-underline hover:opacity-70 transition-opacity">
        {locale === 'da' ? 'Køb billetter' : 'Buy Tickets'}
      </a>
      <a
        href="https://shop.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="text-white text-[15px] font-medium tracking-normal no-underline hover:opacity-70 transition-opacity"
        >{translate(locale, 'shop')}</a
      >
    </div>
    <!-- Social icons + Login + lang -->
    <div class="flex items-center gap-5 px-6">
      <!-- Social icons -->
      <div class="flex items-center gap-3">
        <a href="https://www.instagram.com/ab1889.dk" target="_blank" rel="noreferrer" aria-label="Instagram" class="text-white hover:opacity-70 transition-opacity">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/AB1889" target="_blank" rel="noreferrer" aria-label="Facebook" class="text-white hover:opacity-70 transition-opacity">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@ab1889" target="_blank" rel="noreferrer" aria-label="YouTube" class="text-white hover:opacity-70 transition-opacity">
          <svg width="18" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
      <div class="w-px h-4 bg-white/20 shrink-0"></div>
      <!-- Login -->
      <a
        href={enPrefix + '/konto'}
        class="flex items-center gap-2 text-white text-[15px] font-medium tracking-normal no-underline hover:opacity-70 transition-opacity">
        Login
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 20 19"
          fill="none">
          <path
            d="M8.57541 10.9615C11.1318 10.9615 13.2165 8.82761 13.2165 6.21156C13.2165 3.59551 11.1315 1.46166 8.57541 1.46166C6.01927 1.46166 3.93429 3.59551 3.93429 6.21156C3.93429 8.82761 6.01927 10.9615 8.57541 10.9615ZM14.2164 10.618C13.4381 10.618 12.7027 10.9322 12.1457 11.4949C11.1889 12.4741 9.92504 13.0076 8.57552 13.0076C7.22601 13.0076 5.95495 12.4669 4.99826 11.4949C4.44846 10.9249 3.71299 10.618 2.92755 10.618C2.14926 10.618 1.41379 10.9249 0.856844 11.4949C0.307047 12.0576 0 12.8103 0 13.6142C0 14.418 0.307047 15.1634 0.856844 15.7334C2.91327 17.8453 5.65517 19 8.56844 19C11.4817 19 14.2236 17.8381 16.28 15.7334C16.8298 15.1707 17.1369 14.418 17.1369 13.6142C17.1369 12.8103 16.8298 12.0649 16.28 11.4949C15.7302 10.9322 14.9948 10.618 14.2093 10.618H14.2164Z"
            fill="white"
          ></path>
        </svg>
      </a>
      <div class="w-px h-4 bg-white/20 shrink-0"></div>
      <!-- Language selector -->
      <div class="flex items-center gap-4">
        <a
          href={daPath}
          class:list={[
            'no-underline hover:opacity-100 transition-opacity',
            locale === 'da' ? 'opacity-100' : 'opacity-45',
          ]}
          aria-label="Dansk">
          <img
            src="/flags/da.jpg"
            alt=""
            width="18"
            height="14"
            class="block h-3.5 w-auto"
          />
        </a>
        <a
          href={enPath}
          class:list={[
            'no-underline hover:opacity-100 transition-opacity',
            locale === 'en' ? 'opacity-100' : 'opacity-45',
          ]}
          aria-label="English">
          <img
            src="/flags/en.jpg"
            alt=""
            width="21"
            height="14"
            class="block h-3.5 w-auto"
          />
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav: ~92px, dark green -->
  <div
    class="nav-main relative flex items-center px-8 lg:px-12">
    <!-- Logo -->
    <div class="flex flex-1 items-center justify-start min-w-0">
      <a
        href={enPrefix + '/'}
        aria-label={translate(locale, 'logoHome')}
        class="shrink-0">
        <img
          src="/images/ab-logo.svg"
          alt="AB 1889"
          width="100"
          height="64"
          class="nav-logo"
        />
      </a>
    </div>

    <!-- Desktop nav links (viewport-centered via balanced side columns) -->
    <nav
      class="hidden lg:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 items-center gap-8 xl:gap-12">
      {
        nav.primary.map((item) => {
          const isActive = isNavItemActive(currentPath, item, enPrefix);
          return (
            <div class="relative group">
              <a
                href={enPrefix + item.href}
                class:list={['text-[17px] font-bold tracking-[-0.02em] no-underline transition-colors', isActive ? 'text-[#D3BC8D]' : 'text-white']}>
                {item.label}
              </a>
              {isActive && (
                <div class="absolute bottom-0 left-0 w-full h-[3px] bg-ab-beige" />
              )}
              {item.children && (
                <div class="absolute top-full left-0 hidden group-hover:block z-50 pt-3">
                  <div
                    class="min-w-[200px] shadow-2xl"
                    style="background:#004A3A; border-top:3px solid #D3BC8D;">
                    {item.children.map((child) => (
                      <a
                        href={enPrefix + child.href}
                        class="block px-5 py-3 font-black text-sm hover:bg-white/10 transition-colors"
                        style="color:rgba(255,255,255,0.8); text-decoration:none; letter-spacing:-0.02em;">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })
      }
    </nav>

    <!-- Right: Search + Mobile -->
    <div class="flex flex-1 items-center justify-end gap-3 min-w-0 shrink-0">
      <button
        id="search-open-btn"
        class="hidden lg:flex items-center gap-2 font-black text-sm"
        style="background:rgba(15,148,118,0.5); color:#fff; border:none; border-radius:22px; padding:10px 20px; cursor:pointer; letter-spacing:-0.03em;"
        aria-label={translate(locale, 'search')}>
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true">
          <circle
            cx="6"
            cy="6"
            r="4.5"
            stroke="currentColor"
            stroke-width="1.4"
          ></circle>
          <path
            d="M10 10l2.5 2.5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
          ></path>
        </svg>
        {translate(locale, 'search')}
      </button>
      <button
        type="button"
        id="mobile-menu-open-btn"
        class="burger flex flex-col justify-center items-center gap-[7px] lg:hidden text-white/80 hover:text-white transition-colors shrink-0"
        aria-label={nav.openMenu}
        aria-expanded="false"
        aria-controls="mobile-menu-panel">
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
      </button>
      <MobileMenu
        client:load
        nav={nav}
        locale={locale}
        enPrefix={enPrefix}
        toggleId="mobile-menu-open-btn"
      />
      <SearchModal
        client:load
        locale={locale}
      />
    </div>
  </div>
</header>

<script>
  const hdr = document.querySelector('header.sticky');
  if (hdr) {
    const SHRINK_AT  = 80;
    const RESTORE_AT = 20;
    const COOLDOWN   = 450; // ms — longer than the 0.34s transition

    let lastChange = -COOLDOWN;

    const update = () => {
      const now = performance.now();
      if (now - lastChange < COOLDOWN) return;

      const y = window.scrollY;
      const compact = hdr.classList.contains('nav-scrolled');
      if (!compact && y > SHRINK_AT)  { hdr.classList.add('nav-scrolled');    lastChange = now; }
      if ( compact && y < RESTORE_AT) { hdr.classList.remove('nav-scrolled'); lastChange = now; }
    };

    window.addEventListener('load', () => {
      hdr.classList.add('nav-no-transition');
      hdr.classList.toggle('nav-scrolled', window.scrollY > SHRINK_AT);
      requestAnimationFrame(() => requestAnimationFrame(() => hdr.classList.remove('nav-no-transition')));
    });

    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style>
  /* ── Scroll-shrink ─────────────────────────────────────── */

  /* Suppress all nav transitions during the initial paint */
  header.nav-no-transition .nav-utility,
  header.nav-no-transition .nav-main,
  header.nav-no-transition .nav-logo {
    transition: none !important;
  }

  /* Utility bar slides up */
  .nav-utility {
    height: 45px;
    overflow: hidden;
    transition: height 0.34s cubic-bezier(0.4, 0, 0.2, 1);
  }
  header.nav-scrolled .nav-utility {
    height: 0;
  }

  /* Main nav morphs via padding — content breathes, not just the box */
  .nav-main {
    background: #006a52;
    padding-top: 14px;
    padding-bottom: 14px;
    transition: padding 0.34s cubic-bezier(0.4, 0, 0.2, 1),
                background-color 0.34s ease,
                box-shadow 0.34s ease;
  }
  header.nav-scrolled .nav-main {
    padding-top: 10px;
    padding-bottom: 10px;
    background: rgba(0, 90, 68, 0.75);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.22),
                inset 0 1px 0 rgba(255, 255, 255, 0.09);
  }

  /* Logo shrinks in sync */
  .nav-logo {
    display: block;
    height: 64px;
    width: auto;
    transition: height 0.34s cubic-bezier(0.4, 0, 0.2, 1);
  }
  header.nav-scrolled .nav-logo {
    height: 44px;
  }

  /* ── Burger ────────────────────────────────────────────── */
  .burger {
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .burger-bar {
    display: block;
    width: 26px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transform-origin: center;
    transition: transform 0.28s ease, opacity 0.2s ease;
  }

  .burger[aria-expanded="true"] .burger-bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .burger[aria-expanded="true"] .burger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .burger[aria-expanded="true"] .burger-bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }
</style>
