---
import MobileMenu from './islands/MobileMenu';
import SearchModal from './islands/SearchModal';
import LangSwitch from '@/components/layout/LangSwitch.astro';
import { getNavConfig } from '@/lib/nav-config';

interface Props {
  locale?: string;
  globalData?: any;
}

const { locale = 'da', globalData } = Astro.props;
const nav = getNavConfig(locale);
const enPrefix = locale === 'en' ? '/en' : '';
const currentPath = Astro.url.pathname;
const daPath = currentPath.replace(/^\/en/, '') || '/';
const enPath = '/en' + (currentPath.replace(/^\/en/, '') || '/');
---

<header class="sticky top-0 z-50">
  <!-- Utility bar: 45px, black -->
  <div
    class="hidden md:flex items-center"
    style="background:#0A0A09; height:45px;">
    <!-- Neon "Join MyAB" block -->
    <a
      href={enPrefix + '/bliv-involveret/myab'}
      class="flex items-center justify-center shrink-0 h-full font-black"
      style="background:#00FF1F; width:171px; color:#006A52; text-decoration:none; font-size:15px; letter-spacing:-0.04em;">
      Join MyAB
    </a>
    <!-- Utility links -->
    <div class="flex items-center gap-8 px-8 flex-1">
      <a
        href="https://billetter.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="font-black hover:opacity-70 transition-opacity"
        style="color:#fff; text-decoration:none; font-size:15px; letter-spacing:-0.03em;">
        {locale === 'da' ? 'Billetter' : 'Tickets'}
      </a>
      <a
        href="https://shop.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="font-black hover:opacity-70 transition-opacity"
        style="color:#fff; text-decoration:none; font-size:15px; letter-spacing:-0.03em;"
        >Shop</a
      >
      <a
        href="https://abtv.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="font-black hover:opacity-70 transition-opacity"
        style="color:#fff; text-decoration:none; font-size:15px; letter-spacing:-0.03em;"
        >ABTV</a
      >
    </div>
    <!-- Login + lang -->
    <div class="flex items-center gap-5 px-6">
      <a
        href={enPrefix + '/konto'}
        class="flex items-center gap-1.5 font-black hover:opacity-70 transition-opacity"
        style="color:#fff; text-decoration:none; font-size:15px; letter-spacing:-0.03em;">
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true">
          <circle
            cx="7"
            cy="4.5"
            r="2.5"
            stroke="currentColor"
            stroke-width="1.4"
          ></circle>
          <path
            d="M2 13c0-2.761 2.239-5 5-5s5 2.239 5 5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
          ></path>
        </svg>
        {locale === 'da' ? 'Log ind' : 'Login'}
      </a>
      <div class="flex items-center gap-2">
        <!-- Danish flag -->
        <a href={daPath} class="transition-opacity" style={`display:inline-flex; text-decoration:none; opacity:${locale === 'da' ? '1' : '0.4'}; border-radius:3px; overflow:hidden;`} aria-label="Dansk">
          <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="22" height="16" fill="#C60C30"/>
            <rect x="10" width="4" height="20" fill="#fff"/>
            <rect y="8" width="28" height="4" fill="#fff"/>
          </svg>
        </a>
        <!-- UK flag -->
        <a href={enPath} class="transition-opacity" style={`display:inline-flex; text-decoration:none; opacity:${locale === 'en' ? '1' : '0.4'}; border-radius:3px; overflow:hidden;`} aria-label="English">
          <svg width="22" height="16" viewBox="0 0 60 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="60" height="40" fill="#012169"/>
            <path d="M0,0 L60,40 M60,0 L0,40" stroke="#fff" stroke-width="8"/>
            <path d="M0,0 L60,40 M60,0 L0,40" stroke="#C8102E" stroke-width="4"/>
            <path d="M30,0 V40 M0,20 H60" stroke="#fff" stroke-width="12"/>
            <path d="M30,0 V40 M0,20 H60" stroke="#C8102E" stroke-width="8"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav: ~92px, dark green -->
  <div
    class="flex items-center px-8 lg:px-12"
    style="background:#006A52; height:92px;">
    <!-- Logo -->
    <a
      href={enPrefix + '/'}
      aria-label="AB 1889 — hjem"
      class="shrink-0 mr-8 lg:mr-16">
      <img
        src="/images/ab-logo.svg"
        alt="AB 1889"
        width="100"
        height="64"
        style="display:block; height:64px; width:auto;"
      />
    </a>

    <!-- Desktop nav links (centered) -->
    <nav class="hidden lg:flex items-center gap-8 xl:gap-12 flex-1 justify-center">
      {nav.primary.map((item) => {
        const isActive = currentPath === (enPrefix + item.href) || (item.href !== '/' && currentPath.startsWith(enPrefix + item.href));
        return (
          <div class="relative group">
            <a
              href={enPrefix + item.href}
              class="font-black transition-colors"
              style={`text-decoration:none; font-size:16px; letter-spacing:-0.04em; color:${isActive ? '#D3BC8D' : '#fff'};`}
            >
              {item.label}
            </a>
            {isActive && (
              <div style="position:absolute; bottom:-10px; left:50%; transform:translateX(-50%); width:40px; height:3px; background:#D3BC8D;" />
            )}
            {item.children && (
              <div class="absolute top-full left-0 hidden group-hover:block z-50 min-w-[200px]" style="padding-top:12px;">
                <div style="background:#004A3A; border-top:3px solid #D3BC8D;" class="shadow-2xl">
                  {item.children.map((child) => (
                    <a
                      href={enPrefix + child.href}
                      class="block px-5 py-3 font-medium text-sm hover:bg-white/10 transition-colors"
                      style="color:rgba(255,255,255,0.8); text-decoration:none;"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <!-- Right: Search + Mobile -->
    <div class="flex items-center gap-3 ml-auto">
      <button
        id="search-open-btn"
        class="hidden lg:flex items-center gap-2 font-black text-sm"
        style="background:rgba(15,148,118,0.5); color:#fff; border:none; border-radius:22px; padding:10px 20px; cursor:pointer; letter-spacing:-0.03em;"
        aria-label={locale === 'da' ? 'Søg' : 'Search'}>
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true">
          <circle
            cx="6"
            cy="6"
            r="4.5"
            stroke="currentColor"
            stroke-width="1.4"
          ></circle>
          <path
            d="M10 10l2.5 2.5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
          ></path>
        </svg>
        {locale === 'da' ? 'Søg' : 'Search'}
      </button>
      <MobileMenu client:load nav={nav} locale={locale} enPrefix={enPrefix} />
      <SearchModal client:load locale={locale} />
    </div>
  </div>
</header>
