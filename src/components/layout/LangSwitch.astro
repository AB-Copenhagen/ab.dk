---
import { switchLocalePath } from '@/lib/i18n';

interface Props {
  locale: 'da' | 'en';
  class?: string;
}

const { locale, class: cls = '' } = Astro.props;

const currentPath = Astro.url.pathname;
const targetLocale = locale === 'da' ? 'en' : 'da';
const switchedPath = switchLocalePath(currentPath, targetLocale);
---

<a
  href={switchedPath}
  class={`text-[0.65rem] font-bold uppercase transition-colors hover:text-white ${cls}`}
  style="color:rgba(255,255,255,0.35);letter-spacing:0.2em"
  aria-label={locale === 'da' ? 'Switch to English' : 'Skift til dansk'}
>
  {locale === 'da' ? 'EN' : 'DA'}
</a>
