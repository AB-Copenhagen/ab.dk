---
import { getPlayerPhotoUrl, getPlayerPhotoPosition } from '@/lib/si/player-photos';
import { getPersonCardSizing } from '@/lib/person-card-sizing';
import { resolveName, getPlayerSlug, slugify } from '@/data/player-cms-data';

interface Props {
  player: {
    id?: number;
    name: string;
    position?: string;
    shirtNumber?: number | null;
    jerseyNumber?: number | null;
    country?: { name: string } | null;
  };
  locale: 'da' | 'en';
  /** Omit to auto-derive from player.name */
  href?: string;
}

const { player, locale, href } = Astro.props;

const number = player.shirtNumber ?? player.jerseyNumber;
// Photo lookup stays keyed on the raw SI name (may be ASCII-mangled or
// truncated, e.g. "Soeren Ilsoee" or "Milan Rasmussen") — Wasabi filenames
// were uploaded against that raw name, not the corrected display name.
const photoUrl = getPlayerPhotoUrl(player.name);
const photoPosition = getPlayerPhotoPosition(player.name);
const displayName =
  (player.id != null ? resolveName(player.id, player.name) : null) ??
  player.name;

const positionLabels: Record<string, { da: string; en: string }> = {
  keeper: { da: 'Målmand', en: 'Goalkeeper' },
  defender: { da: 'Forsvarer', en: 'Defender' },
  midfielder: { da: 'Midtbane', en: 'Midfielder' },
  forward: { da: 'Angriber', en: 'Forward' },
};
const pos = (player.position ?? '').toLowerCase();
const posLabel = positionLabels[pos]?.[locale] ?? player.position ?? '';

const isKeeper = pos === 'keeper';
const cardBg = isKeeper ? 'var(--ab-beige)' : 'var(--ab-green)';
const textColor = isKeeper ? '#111' : '#fff';
// 0.5/0.6 alpha both fail WCAG AA contrast (~3.4:1) against these brand backgrounds at this font size.
const textMuted = isKeeper ? 'rgba(0,0,0,0.7)' : 'rgba(255,255,255,0.8)';

// Surname gets its own line, alone — every other part shares the line above it.
// A long surname (e.g. "Benediktsson") is far more likely to fit whole when it
// isn't sharing its line with a first/middle name.
const nameParts = displayName.trim().split(' ');
const firstLine = nameParts.slice(0, -1).join(' ');
const surname = nameParts[nameParts.length - 1];

// A long name (a single unbreakable word, or 3+ parts that wrap to 3 lines) can grow tall
// enough to push the jersey number past the bottom of the card. Shrink name + number
// together as that risk grows, rather than letting either overflow.
const { nameFontClamp, numberFontClamp, labelFontClamp } = getPersonCardSizing(
  displayName,
  posLabel
);

const playerSlug =
  player.id != null ? getPlayerSlug(player.id, player.name) : slugify(player.name);
const playerHref =
  href ??
  (locale === 'da' ? `/spiller/${playerSlug}` : `/en/player/${playerSlug}`);
---

<!--
  Card frame: aspect-ratio 593:503 (full frame incl. overflow zone at top)
  Green background rectangle: occupies bottom 84.1% of frame (423/503)
  Photo: right ~52%, full frame height — so it naturally "overflows" above the background
-->
<a
  href={playerHref}
  class="squad-card block relative group aspect-[593/503]"
  data-position={player.position}>
  <!-- Position-coloured background rectangle (bottom 84% of card frame) -->
  <div
    class="absolute inset-x-0 bottom-0 transition-all duration-300 group-hover:brightness-110"
    style={`height:84.1%; background:${cardBg};`}>
  </div>

  <!-- Player photo: right 52%, full height of card frame -->
  <div
    class="absolute top-0 bottom-0 right-0 overflow-hidden rounded-r-xl w-[52%]">
    {
      photoUrl ? (
        <img
          src={photoUrl}
          alt={displayName}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover"
          style={`object-position: ${photoPosition};`}
          onerror="this.style.opacity='0'"
        />
      ) : null
    }
  </div>

  <!-- Text layer: left 52%, pinned to bottom 84% of frame. No overflow clipping on the name —
       an exceptionally long surname is allowed to bleed rightward over the photo rather than
       being clipped invisibly or force-broken mid-word; the sizing above keeps this rare. -->
  <div
    class="absolute inset-x-0 bottom-0 flex flex-col justify-between p-4 md:p-5 z-10 h-[84.1%] w-[52%]">
    <!-- Name + position -->
    <div>
      <p
        class="font-black leading-tight"
        style={`font-size:${nameFontClamp}; letter-spacing:-0.025em; color:${textColor};`}>
        {firstLine ? (<>{firstLine}<br /><span class="whitespace-nowrap">{surname}</span></>) : <span class="whitespace-nowrap">{surname}</span>}
      </p>
      <p
        class="mt-1 font-medium"
        style={`font-size:${labelFontClamp}; color:${textMuted};`}>
        {posLabel}
      </p>
    </div>

    <!-- Jersey number -->
    {
      number != null ? (
        <p
          class="font-black leading-none select-none"
          style={`font-size:${numberFontClamp}; letter-spacing:-0.04em; color:${textColor};`}>
          {number}
        </p>
      ) : null
    }
  </div>
</a>
