---
import { getPlayerPhotoUrl } from '@/lib/si/player-photos';

interface Props {
  player: {
    id?: number;
    name: string;
    position?: string;
    shirtNumber?: number | null;
    jerseyNumber?: number | null;
    country?: { name: string } | null;
  };
  locale: 'da' | 'en';
  /** Omit to auto-derive from player.name */
  href?: string;
}

const { player, locale, href } = Astro.props;

const number = player.shirtNumber ?? player.jerseyNumber;
const photoUrl = getPlayerPhotoUrl(player.name);

const positionLabels: Record<string, { da: string; en: string }> = {
  keeper: { da: 'Målmand', en: 'Goalkeeper' },
  defender: { da: 'Forsvarer', en: 'Defender' },
  midfielder: { da: 'Midtbane', en: 'Midfielder' },
  forward: { da: 'Angriber', en: 'Forward' },
};
const pos = (player.position ?? '').toLowerCase();
const posLabel = positionLabels[pos]?.[locale] ?? player.position ?? '';

const isKeeper = pos === 'keeper';
const cardBg = isKeeper ? 'var(--ab-beige)' : 'var(--ab-green)';
const textColor = isKeeper ? '#111' : '#fff';
const textMuted = isKeeper ? 'rgba(0,0,0,0.5)' : 'rgba(255,255,255,0.6)';

const nameParts = player.name.trim().split(' ');
const firstName = nameParts[0];
const lastName = nameParts.slice(1).join(' ');

// A single long unbreakable word (e.g. "Koudelka", "Benediktsson") can overflow the name
// column at the default size, since text-wrap:balance only breaks on spaces. Scale the font
// down in steps as the longest word grows, rather than letting it break mid-word.
const longestWord = Math.max(...nameParts.map((part) => part.length));
const nameFontClamp =
  longestWord > 10
    ? 'clamp(0.62rem,1.3vw,0.95rem)'
    : longestWord > 8
      ? 'clamp(0.7rem,1.5vw,1.15rem)'
      : longestWord > 6
        ? 'clamp(0.8rem,1.7vw,1.4rem)'
        : 'clamp(0.95rem,2.1vw,1.75rem)';

function toSlug(name: string) {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/'/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

const playerSlug = player.id
  ? `${player.id}-${toSlug(player.name)}`
  : toSlug(player.name);
const playerHref =
  href ??
  (locale === 'da' ? `/spiller/${playerSlug}` : `/en/player/${playerSlug}`);
---

<!--
  Card frame: aspect-ratio 593:503 (full frame incl. overflow zone at top)
  Green background rectangle: occupies bottom 84.1% of frame (423/503)
  Photo: right ~46%, full frame height — so it naturally "overflows" above the background
-->
<a
  href={playerHref}
  class="squad-card block relative group aspect-[593/503]"
  data-position={player.position}>
  <!-- Position-coloured background rectangle (bottom 84% of card frame) -->
  <div
    class="absolute inset-x-0 bottom-0 transition-all duration-300 group-hover:brightness-110"
    style={`height:84.1%; background:${cardBg};`}>
  </div>

  <!-- Player photo: right 46%, full height of card frame -->
  <div
    class="absolute top-0 bottom-0 right-0 overflow-hidden rounded-r-xl w-[46%]">
    {
      photoUrl ? (
        <img
          src={photoUrl}
          alt={player.name}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover object-top"
          onerror="this.style.opacity='0'"
        />
      ) : null
    }
  </div>

  <!-- Text layer: left 58%, pinned to bottom 84% of frame -->
  <div
    class="absolute inset-x-0 bottom-0 flex flex-col justify-between p-4 md:p-5 z-10 h-[84.1%] w-[58%]">
    <!-- Name + position -->
    <div>
      <p
        class="font-black leading-tight"
        style={`font-size:${nameFontClamp}; letter-spacing:-0.025em; text-wrap:balance; overflow-wrap:anywhere; color:${textColor};`}>
        {firstName}<br />{lastName}
      </p>
      <p
        class="text-xs mt-1 font-medium"
        style={`color:${textMuted};`}>
        {posLabel}
      </p>
    </div>

    <!-- Jersey number -->
    {
      number != null ? (
        <p
          class="font-black leading-none select-none"
          style={`font-size:clamp(2.5rem,6.5vw,6.5rem); letter-spacing:-0.04em; color:${textColor};`}>
          {number}
        </p>
      ) : null
    }
  </div>
</a>
