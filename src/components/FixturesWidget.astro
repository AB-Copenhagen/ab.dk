---
import { fetchABEvents } from '@/lib/si/client';

interface Props {
  locale: 'da' | 'en';
  limit?: number;
  theme?: 'dark' | 'light';
}

const { locale, limit = 20, theme = 'dark' } = Astro.props;
const dark = theme === 'dark';

const dateColor = dark ? '#7A9185' : '#888';
const nameColor = dark ? '#fff'    : '#111';
const divider   = dark ? '#1A2018' : '#E5E7EB';
const hoverBg   = dark ? '#0D1410' : '#F5FAF8';

let events: any[] = [];
let error = '';

try {
  events = await fetchABEvents({ locale, limit });
} catch {
  error = locale === 'da' ? 'Kampprogram ikke tilgængeligt' : 'Fixtures unavailable';
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString(
    locale === 'da' ? 'da-DK' : 'en-GB',
    { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }
  );
}
---

{error ? (
  <div class="text-xs py-4 text-center" style={`color:${dateColor}`}>{error}</div>
) : !events.length ? (
  <div class="text-xs py-4 text-center" style={`color:${dateColor}`}>
    {locale === 'da' ? 'Ingen kampe fundet' : 'No fixtures found'}
  </div>
) : (
  <div>
    {events.slice(0, limit).map((event: any) => {
      const isABHome = event.homeId === 9805;
      const opponent = isABHome ? event.awayName : event.homeName;
      const isFinished = event.statusType === 'finished';
      const isLive = event.statusType === 'inprogress';
      const home = isABHome ? 'AB' : (opponent ?? '—');
      const away = isABHome ? (opponent ?? '—') : 'AB';
      return (
        <div class="py-3 px-4 transition-colors"
             style={`border-bottom:1px solid ${divider};`}
             onmouseenter={`this.style.background='${hoverBg}'`}
             onmouseleave={`this.style.background='transparent'`}>

          <!-- Date row -->
          <p class="text-xs mb-1" style={`color:${dateColor}`}>{formatDate(event.startDate)}</p>

          <!-- Teams row -->
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium flex-1 text-right" style={`color:${nameColor};`}>
              {home}
            </span>

            {(isFinished || isLive) && event.score ? (
              <span class="font-bold tabular-nums px-2 py-0.5 shrink-0"
                    style={`font-size:0.9rem; ${isLive
                      ? 'color:#00FF1F;background:rgba(0,255,31,0.08)'
                      : 'color:#D6A02A;background:rgba(214,160,42,0.08)'}`}>
                {event.score}
              </span>
            ) : (
              <span class="text-sm shrink-0 font-medium" style={`color:${dateColor}`}>vs</span>
            )}

            <span class="text-sm font-medium flex-1" style={`color:${nameColor};`}>
              {away}
            </span>

            {isLive && (
              <span class="inline-flex items-center gap-1 text-xs font-medium uppercase shrink-0 text-ab-neon tracking-[0.1em]">
                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                LIVE
              </span>
            )}
            {isFinished && (
              <span class="text-xs uppercase shrink-0 tracking-[0.1em]" style={`color:${dateColor}`}>FT</span>
            )}
          </div>
        </div>
      );
    })}
  </div>
)}
