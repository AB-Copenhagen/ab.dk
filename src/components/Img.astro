---
/**
 * Universal drop-in for <img> that auto-serves WebP.
 *
 * - Local public paths (/images/foo.png or .jpg): outputs <picture> with .webp source + original fallback
 * - Imported ImageMetadata: delegates to astro:assets <Picture> (Vercel optimizer). Pass
 *   `widths` + `sizes` to get a real responsive srcset for images whose display size varies
 *   by viewport — otherwise renders a single webp source at the image's natural size.
 * - Remote URLs and /api/media/* proxy paths: plain <img> (CDN or the proxy's own
 *   Accept-header negotiation handles format instead — see api/media/[...key].ts)
 *
 * Usage:
 *   <Img src="/images/hero.png" alt="Hero" width={1200} height={600} />
 *   <Img src={importedAsset} alt="Logo" />
 *   <Img src={importedAsset} alt="Hero" widths={[640, 1024, 1920]} sizes="100vw" />
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  style?: string;
  /** Responsive widths (px) to generate — ImageMetadata sources only, ignored otherwise. */
  widths?: number[];
  /** `sizes` attribute paired with `widths` — required by astro:assets whenever `widths` has more than one entry. */
  sizes?: string;
  /** ImageMetadata sources only — the Vercel image service defaults to 100 (near-lossless) when omitted. */
  quality?: number | 'low' | 'mid' | 'high' | 'max';
  [key: string]: unknown;
}

const {
  src,
  alt,
  width: widthProp,
  height: heightProp,
  class: className,
  loading = 'lazy',
  decoding = 'async',
  style,
  widths,
  sizes,
  quality = 80,
  ...rest
} = Astro.props;

// <Image> from astro:assets requires numeric width/height; HTML attrs arrive as strings
const width = widthProp !== undefined ? Number(widthProp) : undefined;
const height = heightProp !== undefined ? Number(heightProp) : undefined;

const CONVERTIBLE_LOCAL_IMAGE = /^\/images\/.*\.(png|jpe?g)$/i;

const isImageMetadata = src !== null && typeof src === 'object' && 'src' in src;
const isLocalConvertibleImage =
  typeof src === 'string' && CONVERTIBLE_LOCAL_IMAGE.test(src);

const webpSrc = isLocalConvertibleImage
  ? (src as string).replace(/\.(png|jpe?g)$/i, '.webp')
  : null;
---

{
  isImageMetadata ? (
    <Picture
      src={src as ImageMetadata}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
      style={style}
      widths={widths}
      sizes={sizes}
      quality={quality}
      formats={['webp']}
      {...rest}
    />
  ) : isLocalConvertibleImage && webpSrc ? (
    <picture>
      <source srcset={webpSrc} type="image/webp" />
      <img
        src={src as string}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading={loading}
        decoding={decoding}
        style={style}
        {...rest}
      />
    </picture>
  ) : (
    <img
      src={src as string}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
      style={style}
      {...rest}
    />
  )
}
