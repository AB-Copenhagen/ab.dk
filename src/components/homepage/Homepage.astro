---
import { fetchCollectionType } from '@/lib/strapi/client';
import { fetchABEvents, getTeamLogoSrc } from '@/lib/si/client';
import { getSquadPlayers } from '@/lib/si/squad';
import { abConfig, CURRENT_SEASON_START } from '@/lib/config/ab';
import { strapiMediaUrl } from '@/lib/strapi/client';
import SquadCard from '@/components/SquadCard.astro';
import StaffCard from '@/components/StaffCard.astro';
import { COACHING_STAFF } from '@/data/coaching-staff';
import MatchScheduleList from '@/components/MatchScheduleList.astro';
import MiniCalendar from '@/components/MiniCalendar.astro';
import { translate } from '@/lib/i18n';
import { decodeHtml } from '@/lib/utils';
import { fetchCollectionProducts } from '@/lib/shopify';
import StandingsWidget from '@/components/StandingsWidget.astro';
import Img from '@/components/Img.astro';
import matchesHeaderBg from '@/assets/images/matches-header-bg.png';
import joinTeamAbBg from '@/assets/images/join-team-ab-bg.png';
import bannerDownloadApp from '@/assets/images/banner-download-app.png';
import bannerWatchLive from '@/assets/images/banner-watch-live.png';
import product1Img from '@/assets/images/product-1.png';
import product2Img from '@/assets/images/product-2.png';
import product3Img from '@/assets/images/product-3.png';
import heroAbReturnsImg from '@/assets/images/hero-ab-returns.jpg';
import playerFeaturedImg from '@/assets/images/player-featured.png';
import {
  fmtDate,
  dtAttrs,
  DATE_WEEKDAY_MONTH_DAY_OPTS,
  TIME_24H_OPTS,
  DATE_SHORT_OPTS,
} from '@/lib/dateFormat';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

function formatArticleDate(str: string) {
  try {
    return new Date(str).toLocaleDateString(locale === 'en' ? 'en-US' : 'da-DK', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    });
  } catch {
    return '';
  }
}

const now = new Date();
// Fetch from the start of the current season through ~3 months ahead, so the
// homepage doesn't get stuck on whatever the SI API returns by default when
// no date range is given, and doesn't mix in leftover results from the
// previous season.
const seasonFrom = new Date(CURRENT_SEASON_START);
const seasonTo = new Date(now);
seasonTo.setMonth(seasonTo.getMonth() + 3);

const [articles, events, players, shopifyProducts] = await Promise.all([
  fetchCollectionType<any[]>('articles', {
    locale,
    sort: ['originalPublishedAt:desc'],
    populate: ['image'],
    pagination: { pageSize: 4 },
  }).catch(() => [] as any[]),
  fetchABEvents({
    locale,
    limit: 200,
    fromDate: seasonFrom.toISOString().slice(0, 10),
    toDate: seasonTo.toISOString().slice(0, 10),
  }).catch(() => [] as any[]),
  getSquadPlayers(locale),
  fetchCollectionProducts('311129374820', 3).catch(
    () => [] as Awaited<ReturnType<typeof fetchCollectionProducts>>
  ),
]);

const positionOrder: Record<string, number> = {
  keeper: 0,
  defender: 1,
  midfielder: 2,
  forward: 3,
};
const sortedPlayers = [...players].sort(
  (a, b) => (positionOrder[a.position] ?? 4) - (positionOrder[b.position] ?? 4)
);

const upcomingEvents = events
  .filter((e: any) => new Date(e.startDate) >= now)
  .sort((a: any, b: any) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());
const pastEvents = events
  .filter((e: any) => new Date(e.startDate) < now)
  .sort((a: any, b: any) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime());

const nextMatch = upcomingEvents.find(
  (e: any) => e.statusType === 'notstarted' || e.statusType === 'inprogress'
);
const recentResults = pastEvents
  .filter((e: any) => e.statusType === 'finished')
  .slice(0, 5);

const abHome = nextMatch ? nextMatch.homeId === abConfig.teamId : false;
const opponent = nextMatch
  ? abHome
    ? nextMatch.awayName
    : nextMatch.homeName
  : null;
const opponentId = nextMatch
  ? abHome
    ? nextMatch.awayId
    : nextMatch.homeId
  : null;
const oppLogo = opponentId ? getTeamLogoSrc(opponentId) : null;
const matchDateLocale = locale === 'da' ? 'da-DK' : 'en-US';
const matchTimeLocale = locale === 'da' ? 'da-DK' : 'en-GB';
const matchDateStr = nextMatch
  ? fmtDate(nextMatch.startDate, matchDateLocale, DATE_WEEKDAY_MONTH_DAY_OPTS)
  : null;
const matchTimeStr = nextMatch
  ? fmtDate(nextMatch.startDate, matchTimeLocale, TIME_24H_OPTS)
  : null;

function articlePath(slug: string) {
  return locale === 'en' ? `/en/news/${slug}` : `/nyheder/${slug}`;
}
const enSlugs: Record<string, string> = {
  '/kampe': '/matches',
  '/hold': '/squad',
  '/nyheder': '/news',
};
function localPath(daPath: string) {
  if (locale !== 'en') return daPath;
  return `/en${enSlugs[daPath] ?? daPath}`;
}

const staticProducts = [
  {
    name: translate(locale, 'productGreenTShirt'),
    price: 'DKK 89',
    originalPrice: 'DKK 169',
    img: product1Img,
    href: 'https://shop.ab.dk/products/green-academic-football-club-t-shirt?variant=47392935051364',
  },
  {
    name: translate(locale, 'productGreenSweatshirt'),
    price: 'DKK 129',
    originalPrice: 'DKK 249',
    img: product2Img,
    href: 'https://shop.ab.dk/products/green-academic-football-club-sweatshirt?variant=47392934035556',
  },
  {
    name: translate(locale, 'productGreySweater'),
    price: 'DKK 219',
    originalPrice: 'DKK 429',
    img: product3Img,
    href: 'https://shop.ab.dk/products/knowledgecotton-apparel-grey-monochromatic-ab-logo?variant=47392933249124',
  },
];

const products = shopifyProducts.length > 0
  ? shopifyProducts.map(p => ({
      name: p.title,
      price: p.price,
      originalPrice: p.compareAtPrice,
      img: p.imageUrl,
      href: p.url,
    }))
  : staticProducts;

const heroSlides = [
  {
    type: 'image' as const,
    img: heroAbReturnsImg,
    alt: translate(locale, 'heroDivisionAlt'),
    headline: translate(locale, 'heroDivisionHeadline'),
    ctaLabel: translate(locale, 'heroDivisionCta'),
    ctaVariant: 'btn-beige',
    ctaUrl:
      locale === 'en'
        ? '/en/news/ab-returns-to-1-division'
        : '/nyheder/ab-vender-tilbage-til-betinia-liga',
  },
  {
    type: 'video' as const,
    video: locale === 'da' ? '/videos/hero-merch-da.mp4' : '/videos/hero-merch-en.mp4',
    ctaLabel: translate(locale, 'heroShopNow'),
    ctaUrl: 'https://shop.ab.dk',
    ctaVariant: 'btn-beige',
  },
  {
    type: 'image' as const,
    img: matchesHeaderBg,
    alt: translate(locale, 'heroMatchesAlt'),
    headline: translate(locale, 'heroMatchesHeadline'),
    subtitle: translate(locale, 'heroMatchesSubtitle'),
    ctaLabel: translate(locale, 'heroMatchesCta'),
    ctaUrl: localPath('/kampe'),
    ctaVariant: 'btn-beige',
  },
  {
    type: 'image' as const,
    img: joinTeamAbBg,
    alt: translate(locale, 'heroJoinAlt'),
    headline: translate(locale, 'heroJoinHeadline'),
    subtitle: translate(locale, 'heroJoinSubtitle'),
    ctaLabel: translate(locale, 'heroJoinCta'),
    ctaUrl: localPath('/om/bliv-medlem'),
    ctaVariant: 'btn-beige',
  },
];
---

<style>
  @keyframes dot-fill {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>

<!-- ── Hero Slider ───────────────────────────────────────── -->
<section
  id="hero-slider"
  class="relative w-full overflow-hidden h-[60svh] min-h-[560px] max-h-[960px] cursor-grab active:cursor-grabbing select-none touch-pan-y">

  <!-- Horizontal track: all slides side-by-side -->
  <div id="hero-track" class="flex h-full will-change-transform" style="transform:translateX(0)">
    {
      heroSlides.map((slide, i) => (
        <div class={`relative flex-shrink-0 w-full h-full ${slide.type === 'video' ? 'bg-ab-black' : ''}`}>
          {slide.type === 'video' ? (
            <video
              src={slide.video}
              muted
              playsinline
              preload={i === 0 ? 'auto' : 'none'}
              draggable="false"
              class="hero-video w-full h-full max-w-[1680px] mx-auto object-cover object-center pointer-events-none"
            />
          ) : (
            <Img
              src={slide.img}
              alt={slide.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              draggable="false"
              widths={[640, 828, 1200, 1920]}
              sizes="100vw"
              class="w-full h-full object-cover object-center pointer-events-none"
            />
          )}
          {slide.type === 'video' ? (
            <div class="absolute inset-0 z-10 flex flex-col items-center justify-end pb-28 px-6 text-center">
              <a href={slide.ctaUrl} target="_blank" rel="noopener noreferrer" class={`btn btn-lg ${slide.ctaVariant} pointer-events-auto`}>
                {slide.ctaLabel}
              </a>
            </div>
          ) : (
            <>
              <div class="absolute inset-0 bg-black/20" />
              <div class="absolute inset-0 z-10 flex flex-col items-center justify-center px-6 text-center">
                <h1 class="font-black text-white leading-none text-[clamp(4rem,11vw,10rem)] tracking-[-0.04em] text-balance text-center">
                  {slide.headline}
                </h1>
                {slide.subtitle && (
                  <p class="font-medium text-white mt-8 mb-5 text-[clamp(1.7rem,2.8vw,2rem)]">
                    {slide.subtitle}
                  </p>
                )}
                <a href={slide.ctaUrl} class={`btn btn-lg ${slide.ctaVariant} pointer-events-auto`}>
                  {slide.ctaLabel}
                </a>
              </div>
            </>
          )}
        </div>
      ))
    }
  </div>

  <!-- Scrim so the indicator/controls stay legible regardless of slide brightness -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 h-28 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />

  <!-- Dot indicators (centered) -->
  <div class="absolute bottom-8 left-0 right-0 z-30 flex justify-center items-center">
    <div id="hero-dots" class="flex items-center gap-2 h-7 cursor-default">
      {
        heroSlides.map((_, i) => (
          <button
            class="hero-dot relative overflow-hidden"
            style={`height:4px; border-radius:2px; border:none; padding:0; cursor:pointer; transition:width 0.3s ease; background:rgba(255,255,255,0.35); ${i === 0 ? 'width:48px;' : 'width:16px;'}`}
            data-dot={i}
            aria-label={`Slide ${i + 1}`}>
            <div
              class="hero-dot-fill"
              style={`position:absolute; inset:0; background:#fff; transform-origin:left; transform:scaleX(0); ${i === 0 ? `animation:dot-fill ${5000}ms linear forwards;` : ''}`}
            />
          </button>
        ))
      }
    </div>
  </div>

  <!-- Prev/pause/next controls, grouped at the right -->
  <div id="hero-controls" class="absolute bottom-8 right-6 z-30 flex items-center gap-2 cursor-default">
    <button
      type="button"
      id="hero-prev-btn"
      class="flex items-center justify-center size-7 rounded-full bg-black/35 hover:bg-black/50 backdrop-blur-sm transition-colors text-white shrink-0 cursor-pointer"
      aria-label={translate(locale, 'previousSlide')}>
      <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
        <path d="M6 1L1 6L6 11" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button
      type="button"
      id="hero-pause-btn"
      class="flex items-center justify-center size-7 rounded-full bg-black/35 hover:bg-black/50 backdrop-blur-sm transition-colors text-white shrink-0 cursor-pointer"
      aria-pressed="false"
      aria-label={translate(locale, 'pauseSlideshow')}
      data-label-pause={translate(locale, 'pauseSlideshow')}
      data-label-play={translate(locale, 'playSlideshow')}>
      <svg id="hero-pause-icon" width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
        <rect x="0" y="0" width="3" height="10" />
        <rect x="7" y="0" width="3" height="10" />
      </svg>
      <svg id="hero-play-icon" width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true" style="display:none;">
        <path d="M0 0 L9 5 L0 10 Z" />
      </svg>
    </button>
    <button
      type="button"
      id="hero-next-btn"
      class="flex items-center justify-center size-7 rounded-full bg-black/35 hover:bg-black/50 backdrop-blur-sm transition-colors text-white shrink-0 cursor-pointer"
      aria-label={translate(locale, 'nextSlide')}>
      <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
        <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>
</section>

<script>
  const IMAGE_DURATION  = 5000;
  const SNAP_EASE       = 'transform 0.48s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
  const SWIPE_THRESHOLD = 50;

  const slider    = document.getElementById('hero-slider')!;
  const track     = document.getElementById('hero-track')!;
  const dots      = Array.from(document.querySelectorAll<HTMLElement>('.hero-dot'));
  const fills     = dots.map(d => d.querySelector<HTMLElement>('.hero-dot-fill')!);
  const pauseBtn  = document.getElementById('hero-pause-btn')!;
  const pauseIcon = document.getElementById('hero-pause-icon')!;
  const playIcon  = document.getElementById('hero-play-icon')!;
  const prevBtn   = document.getElementById('hero-prev-btn')!;
  const nextBtn   = document.getElementById('hero-next-btn')!;
  const total     = dots.length;

  // Keep the swipe/drag handling below from hijacking taps on the
  // indicator dots and prev/pause/next controls.
  const dotsWrap     = document.getElementById('hero-dots')!;
  const controlsWrap = document.getElementById('hero-controls')!;
  [dotsWrap, controlsWrap].forEach((el) => {
    el.style.touchAction = 'auto';
    el.addEventListener('pointerdown', (e) => e.stopPropagation());
  });

  // ── Clone first/last for infinite wrapping ─────────────────
  // Track layout: [lastClone] [s0] [s1] … [sN] [firstClone]
  // trackIndex 0 = lastClone, 1..total = real slides, total+1 = firstClone
  const realSlides = Array.from(track.children) as HTMLElement[];
  track.prepend(realSlides[total - 1].cloneNode(true));
  track.append(realSlides[0].cloneNode(true));

  let current       = 0;      // logical slide index (0..total-1)
  let trackIndex     = 1;      // position in expanded track
  let paused         = false;
  let activeVideo: HTMLVideoElement | null = null;
  let advanceTimer: ReturnType<typeof setTimeout> | null = null;
  let advanceDeadline = 0;     // epoch ms the pending image-slide advance fires at
  let pausedRemainingMs = 0;   // time left on that advance when paused (image slides only)

  const w = () => slider.offsetWidth;

  function snap(ti: number, animated: boolean) {
    track.style.transition = animated ? SNAP_EASE : 'none';
    track.style.transform  = `translateX(${-ti * w()}px)`;
  }

  function clearAdvanceTimer() {
    if (advanceTimer !== null) {
      clearTimeout(advanceTimer);
      advanceTimer = null;
    }
  }

  function armImageTimer(ms: number) {
    clearAdvanceTimer();
    advanceDeadline = Date.now() + ms;
    advanceTimer = setTimeout(() => goTo(current + 1), ms);
  }

  // Video slides advance on their own 'ended' event so the clip always
  // plays out in full; image slides advance on a fixed timer.
  function scheduleAdvance(ti: number) {
    clearAdvanceTimer();
    if (paused) return;
    const video = (track.children[ti] as HTMLElement).querySelector('video');
    if (video) return; // handled by the 'ended' listener below
    armImageTimer(IMAGE_DURATION);
  }

  // Starts the dot-fill animation sized to the slide's actual duration —
  // fixed for image slides, the clip length (once known) for video slides.
  function armFill(dotIndex: number, video: HTMLVideoElement | null) {
    const fill = fills[dotIndex];
    const apply = (ms: number) => {
      fill.style.animation = 'none';
      void fill.offsetWidth;
      fill.style.animation = `dot-fill ${ms}ms linear forwards`;
      fill.style.animationPlayState = paused ? 'paused' : 'running';
    };
    if (!video) { apply(IMAGE_DURATION); return; }
    if (video.readyState >= 1 && !Number.isNaN(video.duration)) apply(video.duration * 1000);
    else video.addEventListener('loadedmetadata', () => apply(video.duration * 1000), { once: true });
  }

  // Only the active slide's video plays; every other one pauses and resets.
  function activateVideo(ti: number) {
    activeVideo = null;
    Array.from(track.children).forEach((slideEl, idx) => {
      const video = slideEl.querySelector('video');
      if (!video) return;
      if (idx === ti) {
        activeVideo = video;
        video.currentTime = 0;
        if (!paused) video.play().catch(() => {});
      } else {
        video.pause();
      }
    });
  }

  // Every video (real slides + clones) advances the slider on 'ended', but
  // only while it's the one actually driving the currently shown slide.
  Array.from(track.children).forEach((slideEl) => {
    const video = slideEl.querySelector('video');
    video?.addEventListener('ended', () => {
      if (!paused && video === activeVideo) goTo(current + 1);
    });
  });

  // After animated transition to a clone, silently jump to real slide
  track.addEventListener('transitionend', () => {
    if (trackIndex === 0) {
      trackIndex = total;
      snap(trackIndex, false);
      activateVideo(trackIndex);
    } else if (trackIndex === total + 1) {
      trackIndex = 1;
      snap(trackIndex, false);
      activateVideo(trackIndex);
    }
  });

  function activateDot(i: number, video: HTMLVideoElement | null) {
    dots.forEach((dot, j) => {
      if (j === i) {
        dot.style.width = '48px';
        armFill(j, video);
      } else {
        dot.style.width = '16px';
        fills[j].style.animation = 'none';
        fills[j].style.transform = 'scaleX(0)';
      }
    });
  }

  function goTo(n: number) {
    pausedRemainingMs = 0; // a manual/auto jump always starts a fresh slide
    current = (n + total) % total;
    // Route wraps through clones so motion stays directional
    if (n >= total)  trackIndex = total + 1;   // forward wrap → firstClone
    else if (n < 0)  trackIndex = 0;           // backward wrap → lastClone
    else             trackIndex = current + 1;
    snap(trackIndex, true);
    activateVideo(trackIndex);
    activateDot(current, activeVideo);
    scheduleAdvance(trackIndex);
  }

  function setPaused(next: boolean) {
    paused = next;
    pauseBtn.setAttribute('aria-pressed', String(paused));
    pauseBtn.setAttribute(
      'aria-label',
      paused ? pauseBtn.dataset.labelPlay! : pauseBtn.dataset.labelPause!
    );
    pauseIcon.style.display = paused ? 'none' : '';
    playIcon.style.display  = paused ? '' : 'none';
    fills.forEach((f) => { f.style.animationPlayState = paused ? 'paused' : 'running'; });

    if (paused) {
      if (advanceTimer !== null) pausedRemainingMs = Math.max(0, advanceDeadline - Date.now());
      clearAdvanceTimer();
      activeVideo?.pause();
    } else {
      activeVideo?.play().catch(() => {});
      if (pausedRemainingMs > 0) {
        armImageTimer(pausedRemainingMs);
        pausedRemainingMs = 0;
      } else {
        scheduleAdvance(trackIndex);
      }
    }
  }

  pauseBtn.addEventListener('click', () => setPaused(!paused));

  // Start at real slide 0
  snap(1, false);
  activateVideo(1);
  activateDot(0, activeVideo);
  scheduleAdvance(1);

  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  window.addEventListener('resize', () => snap(trackIndex, false), { passive: true });

  // ── Drag ──────────────────────────────────────────────────
  let dragStartX = 0;
  let dragDelta  = 0;
  let dragging   = false;
  let didDrag    = false;

  slider.addEventListener('pointerdown', (e) => {
    if ((e.target as Element).closest('a, button, #hero-dots, #hero-controls')) return;
    dragStartX = e.clientX;
    dragDelta  = 0;
    dragging   = true;
    didDrag    = false;
    track.style.transition = 'none';
    slider.setPointerCapture(e.pointerId);
  }, { passive: true });

  slider.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    dragDelta = e.clientX - dragStartX;
    if (Math.abs(dragDelta) > 8) didDrag = true;
    track.style.transform = `translateX(${-trackIndex * w() + dragDelta}px)`;
  }, { passive: true });

  slider.addEventListener('pointerup', () => {
    if (!dragging) return;
    dragging = false;
    if (Math.abs(dragDelta) > SWIPE_THRESHOLD) {
      goTo(dragDelta < 0 ? current + 1 : current - 1);
    } else {
      snap(trackIndex, true);  // spring back
    }
    dragDelta = 0;
  });

  slider.addEventListener('pointercancel', () => {
    if (!dragging) return;
    dragging = false; dragDelta = 0;
    snap(trackIndex, true);
  });

  slider.addEventListener('click', (e) => {
    if (didDrag) { e.preventDefault(); didDrag = false; }
  }, { capture: true });
</script>

<!-- ── Player + Standings ────────────────────────────────── -->
<section
  id="player-standings"
  class="content-container py-8 md:py-10 bg-white">
  <div
    class="grid lg:grid-cols-[clamp(280px,28vw,460px)_1fr] gap-8 xl:gap-10 items-start">
    <!-- Left: Player photo + next match + buy tickets -->
    <div
      id="player-featured"
      class="flex flex-col">
      <div class="relative overflow-hidden bg-rich-black">
        <Img
          src={playerFeaturedImg}
          alt="AB 1889 Player"
          loading="lazy"
          widths={[400, 480, 640, 828]}
          sizes="(min-width: 1024px) 30vw, 100vw"
          class="w-full h-full object-cover object-top aspect-3/4"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-black/55 to-transparent">
        </div>
        <div class="absolute left-4 top-4 flex items-start justify-between">
          <a
            class="vivenu-btn btn btn-md btn-green"
            href="https://billet.ab.dk/?useEmbed=true">
            {translate(locale, 'buyTickets')}
          </a>
        </div>
      </div>

      <!-- Next match card -->
      {
        nextMatch && opponent && (
          <div
            id="next-match"
            class="bg-ab-green overflow-hidden min-h-[212px] px-6 py-5 flex flex-col">
            <h2
              class="font-black text-white leading-[0.86] tracking-[-0.04em] mb-6"
              style="font-size:clamp(1.75rem,3vw,2.1875rem)">
              {translate(locale, 'nextMatch')}
            </h2>
            <div class="flex items-center justify-between gap-4 flex-1">
              <div class="flex flex-col items-center gap-2 shrink-0 w-[76px]">
                <Img
                  src="/images/ab-logo-alt.png"
                  alt="AB"
                  width="81"
                  height="81"
                  class="size-[81px] object-contain"
                />
                <span class="text-sm font-normal text-white text-center tracking-[-0.02em]">
                  AB
                </span>
              </div>
              <div class="flex flex-col items-center text-center text-white flex-1 min-w-0">
                {matchDateStr && nextMatch && (
                  <p class="text-lg font-normal tracking-[-0.02em]" {...dtAttrs(nextMatch.startDate, matchDateLocale, DATE_WEEKDAY_MONTH_DAY_OPTS)}>
                    {matchDateStr}
                  </p>
                )}
                {matchTimeStr && nextMatch && (
