</section>

<!-- ── Matchday Gear / Shop ──────────────────────────────── -->
<section
  id="matchday-gear"
  class="bg-white border-t border-gray-100">
  <div class="content-container py-8 md:py-10">
    <!-- Heading block: centered, large -->
    <div class="text-center mb-10">
      <h2
        class="font-black leading-none mb-4 text-[clamp(3.5rem,9vw,8rem)] tracking-[-0.04em] text-[#111] normal-case text-center">
        {translate(locale, 'matchdayGear')}
      </h2>
      <p class="font-bold text-[clamp(0.95rem,1.5vw,1.1rem)] text-[#111]">
        {translate(locale, 'matchdayGearSubtitle')}
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {
        products.map((p) => (
          <a
            href="https://shop.ab.dk"
            target="_blank"
            rel="noreferrer"
            class="product-card group block">
            <div class="overflow-hidden mb-3 aspect-3/4 bg-gray-100">
              <img
                src={p.img}
                alt={p.name}
                loading="lazy"
                class="product-img w-full h-full object-cover object-top transition-transform duration-[450ms] group-hover:scale-[1.03]"
              />
