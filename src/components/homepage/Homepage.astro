              {p.name}
            </p>
          </a>
        ))
      }
    </div>
    <div class="text-center mt-10">
      <a
        href="https://shop.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="text-sm font-bold underline underline-offset-4 text-ab-green">
        {translate(locale, 'shopAbStore')}
      </a>
    </div>
  </div>
</section>

<!-- ── The Squad ──────────────────────────────────────────────── -->
<section
  id="squad"
  class="bg-white">
  <!-- Hero banner -->
  <div class="w-full">
    <img
      src="/images/squad-banner.png"
      alt="AB 1889 Squad"
      loading="lazy"
      class="w-full h-auto block"
    />
  </div>

  <!-- Players -->
  <div class="content-container py-8 md:py-10">
    <!-- Position filter pills -->
    <div
      class="flex gap-2 md:gap-3 overflow-x-auto pb-3 mb-8 scrollbar-none [-webkit-overflow-scrolling:touch]">
      <button
        data-filter="keeper"
        class="squad-filter squad-filter-active shrink-0 px-5 py-2 rounded-full font-black text-sm tracking-[-0.02em]">
        {translate(locale, 'positionGoalkeeper')}
      </button>
      <button
        data-filter="defender"
        class="squad-filter shrink-0 px-5 py-2 rounded-full font-black text-sm tracking-[-0.02em]">
        {translate(locale, 'positionDefense')}
      </button>
      <button
        data-filter="midfielder"
        class="squad-filter shrink-0 px-5 py-2 rounded-full font-black text-sm tracking-[-0.02em]">
        {translate(locale, 'positionMidfield')}
      </button>
      <button
        data-filter="forward"
        class="squad-filter shrink-0 px-5 py-2 rounded-full font-black text-sm tracking-[-0.02em]">
        {translate(locale, 'positionAttack')}
      </button>
      <button
        data-filter="coach"
        class="squad-filter shrink-0 px-5 py-2 rounded-full font-black text-sm tracking-[-0.02em]">
        {translate(locale, 'positionCoaching')}
      </button>
    </div>

    <!-- Player grid -->
    {
      sortedPlayers.length > 0 ? (
        <div
          class="grid grid-cols-2 lg:grid-cols-3 gap-x-3.5 md:gap-x-7.5"
          id="squad-grid">
          {sortedPlayers.map((player) => (
            <SquadCard
              player={player}
              locale={locale}
            />
          ))}
        </div>
      ) : null
    }

    <!-- See Full Squad link -->
    <div class="text-center mt-10">
      <a
        href={localPath('/hold')}
        class="text-sm font-bold underline underline-offset-4 text-ab-green">
        {translate(locale, 'seeFullSquad')}
      </a>
    </div>
  </div>
</section>

<script>
  (function () {
    const filters = document.querySelectorAll(
      '.squad-filter'
    ) as NodeListOf<HTMLElement>;
    const cards = document.querySelectorAll(
      '.squad-card'
    ) as NodeListOf<HTMLElement>;

    function setActive(btn: HTMLElement) {
      filters.forEach((b) => b.classList.remove('squad-filter-active'));
      btn.classList.add('squad-filter-active');
    }

    function filterCards(pos: string) {
      cards.forEach((card) => {
        card.style.display = card.dataset.position === pos ? '' : 'none';
      });
    }

    // Apply default: keeper
    const defaultFilter = 'keeper';
    filterCards(defaultFilter);

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const pos = btn.dataset.filter!;
        setActive(btn);
        filterCards(pos);
      });
    });
  })();
</script>

<!-- ── News — Inside the club ─────────────────────────────── -->
<section
  id="news"
  class="bg-white">
  <div class="content-container py-14 md:py-20">
    <div class="text-center mb-10 md:mb-14">
      <h2
        class="font-black leading-none mb-4 text-[clamp(3.5rem,9vw,8rem)] tracking-tighter text-[#111] normal-case text-center">
        {translate(locale, 'insideTheClub')}
      </h2>
      <p class="font-bold text-[#111] text-[clamp(0.95rem,1.5vw,1.1rem)]">
        {translate(locale, 'newsSectionSubtitle')}
      </p>
    </div>

    {
      articles.length > 0 ? (
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 md:gap-7">
          {articles.slice(0, 4).map((article: any) => (
            <a
              href={articlePath(article.slug)}
              class="article-card group block">
              <div class="overflow-hidden mb-4 aspect-3/2 bg-gray-300">
                {article.image?.url ? (
                  <img
                    src={strapiMediaUrl(article.image.url)}
                    alt={decodeHtml(article.title)}
                    loading="lazy"
                    class="article-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center font-black text-5xl text-ab-green/15">
                    AB
                  </div>
                )}
              </div>
              {article.categories?.[0] && (
                <p class="font-bold mb-2 underline underline-offset-2 text-[0.8rem] text-ab-green">
                  {article.categories[0].name}
                </p>
              )}
              <h3 class="font-black leading-snug text-[clamp(1.05rem,1.8vw,1.4rem)] tracking-[-0.03em] text-[#111]">
                {decodeHtml(article.title)}
              </h3>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-center py-12 text-sm text-gray-400">
          {translate(locale, 'noNewsYet')}
        </p>
      )
    }

    <div class="mt-12 text-center">
      <a
        href={localPath('/nyheder')}
        class="text-sm font-bold underline underline-offset-4 text-ab-green">
        {translate(locale, 'seeMoreNews')}
      </a>
    </div>
  </div>
</section>
