---
import { fetchCollectionType } from '@/lib/strapi/client';
import { fetchABEvents, fetchABPlayers, type SIPlayer } from '@/lib/si/client';
import { strapiMediaUrl } from '@/lib/strapi/client';
import SquadCard from '@/components/SquadCard.astro';
import { truncate, decodeHtml } from '@/lib/utils';
import StandingsWidget from '@/components/StandingsWidget.astro';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

const [articles, events, players] = await Promise.all([
  fetchCollectionType<any[]>('articles', {
    locale,
    sort: ['publishedAt:desc'],
    populate: ['image', 'categories'],
    pagination: { pageSize: 8 },
  }).catch(() => [] as any[]),
  fetchABEvents({ locale, limit: 20 }).catch(() => [] as any[]),
  fetchABPlayers(locale).catch((): SIPlayer[] => []),
]);

const positionOrder: Record<string, number> = {
  keeper: 0,
  defender: 1,
  midfielder: 2,
  forward: 3,
};
const sortedPlayers = [...players].sort(
  (a, b) => (positionOrder[a.position] ?? 4) - (positionOrder[b.position] ?? 4)
);

const [featured, ...rest] = articles;

const nextMatch = events.find(
  (e: any) => e.statusType === 'notstarted' || e.statusType === 'inprogress'
);
const recentResults = events
  .filter((e: any) => e.statusType === 'finished')
  .slice(0, 5);

const abHome = nextMatch ? nextMatch.homeId === 9805 : false;
const opponent = nextMatch
  ? abHome
    ? nextMatch.awayName
    : nextMatch.homeName
  : null;
const oppLogo = nextMatch
  ? abHome
    ? nextMatch.awayLogo
    : nextMatch.homeLogo
  : null;
const matchDateStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleDateString(
      locale === 'da' ? 'da-DK' : 'en-GB',
      {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
      }
    )
  : null;
const matchTimeStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleTimeString(
      locale === 'da' ? 'da-DK' : 'en-GB',
      {
        hour: '2-digit',
        minute: '2-digit',
      }
    )
  : null;
const venue = nextMatch?.properties?.venue ?? null;

// Calendar widget
const _now = new Date();
const calYear = _now.getFullYear();
const calMonth = _now.getMonth();
const calToday = _now.getDate();
const calDaysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
const _firstDow = new Date(calYear, calMonth, 1).getDay();
const calBlanks = _firstDow === 0 ? 6 : _firstDow - 1;
const calMonthName = new Date(calYear, calMonth, 1).toLocaleDateString(
  locale === 'da' ? 'da-DK' : 'en-GB',
  { month: 'long', year: 'numeric' }
);
const calDayLabels =
  locale === 'da'
    ? ['M', 'T', 'O', 'T', 'F', 'L', 'S']
    : ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
const calMatchDays = new Set<number>(
  events
    .filter((e: any) => {
      const d = new Date(e.startDate);
      return d.getFullYear() === calYear && d.getMonth() === calMonth;
    })
    .map((e: any) => new Date(e.startDate).getDate() as number)
);
const calTotalCells = Math.ceil((calBlanks + calDaysInMonth) / 7) * 7;
const calCells = Array.from({ length: calTotalCells }, (_, i) => {
  const day = i - calBlanks + 1;
  const valid = day >= 1 && day <= calDaysInMonth;
  return {
    day,
    valid,
    isToday: valid && day === calToday,
    hasMatch: valid && calMatchDays.has(day),
  };
});
const calRows = [...events]
  .sort(
    (a: any, b: any) =>
      new Date(b.startDate).getTime() - new Date(a.startDate).getTime()
  )
  .slice(0, 7);

function articlePath(slug: string) {
  return locale === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;
}
function localPath(path: string) {
  return locale === 'en' ? `/en${path}` : path;
}
function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString(
      locale === 'da' ? 'da-DK' : 'en-GB',
      {
        day: 'numeric',
        month: 'short',
      }
    );
  } catch {
    return '';
  }
}

const products = [
  {
    name: locale === 'da' ? 'Grøn AB T-Shirt' : 'Green AB T-Shirt',
    price: 'DKK 89',
    originalPrice: 'DKK 169',
    img: '/images/product-1.png',
  },
  {
    name:
      locale === 'da'
        ? 'Grøn Akademisk Fodboldklub Sweatshirt'
        : 'Green Academic Football Club Sweatshirt',
    price: 'DKK 129',
    originalPrice: 'DKK 249',
    img: '/images/product-2.png',
  },
  {
    name:
      locale === 'da' ? 'Grå Sweater med AB Logo' : 'Grey Sweater with AB Logo',
    price: 'DKK 219',
    originalPrice: 'DKK 429',
    img: '/images/product-3.png',
  },
];

const sponsors = [
  { name: 'Plane', img: '/images/sponsors/plane.png' },
  { name: 'Myriad360', img: '/images/sponsors/myriad360.png' },
  { name: 'Datum', img: '/images/sponsors/datum.png' },
  { name: 'Select Sport', img: '/images/sponsors/select-sport.png' },
  { name: 'Carlsberg', img: '/images/sponsors/carlsberg.png' },
];

const heroSlides = [
  {
    img: '/images/hero.jpg',
    alt: 'AB 1889',
    headline: locale === 'da' ? 'Vær en del af det.' : 'Be part of it.',
    subtitle: locale === 'da' ? 'Få den nyeste trøje' : 'Get the latest kit',
    ctaLabel: locale === 'da' ? 'Shop nu' : 'Shop Now',
    ctaUrl: 'https://shop.ab.dk',
  },
  {
    img: '/images/matches-header-bg.png',
    alt: locale === 'da' ? 'AB Kampe' : 'AB Matches',
    headline: locale === 'da' ? 'Næste kamp venter.' : 'Next match awaits.',
    subtitle:
      locale === 'da'
        ? 'Se kampprogram og køb billetter'
        : 'View fixtures and buy tickets',
    ctaLabel: locale === 'da' ? 'Kampe' : 'Matches',
    ctaUrl: localPath('/kampe'),
  },
  {
    img: '/images/join-team-ab-bg.png',
    alt: locale === 'da' ? 'Bliv en del af AB' : 'Join AB',
    headline: locale === 'da' ? 'Bliv en del af AB.' : 'Join the family.',
    subtitle:
      locale === 'da'
        ? 'Meld dig ind og støt holdet'
        : 'Become a member and support the club',
    ctaLabel: locale === 'da' ? 'Meld dig ind' : 'Join now',
    ctaUrl: localPath('/om/bliv-medlem'),
  },
];
---

<style>
  @keyframes dot-fill {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>

<!-- ── Hero Slider ───────────────────────────────────────── -->
<section
  id="hero-slider"
  class="relative w-full overflow-hidden h-[60svh] min-h-[560px] max-h-[960px]">
  <!-- Slide images -->
  {
    heroSlides.map((slide, i) => (
      <div
        class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-slide={i}>
        <img
          src={slide.img}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          class="w-full h-full object-cover object-center"
        />
      </div>
    ))
  }

  <!-- Overlay -->
  <div class="absolute inset-0 z-10 bg-black/20"></div>

  <!-- Centered content -->
  <div
    class="absolute inset-0 z-20 flex flex-col items-center justify-center text-center px-6">
    {
      heroSlides.map((slide, i) => (
        <div
          class={`hero-content absolute inset-0 flex flex-col items-center justify-center px-6 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-content={i}>
          <h1 class="font-black text-white leading-none text-[clamp(4rem,11vw,10rem)] tracking-[-0.04em] text-balance">
            {slide.headline}
          </h1>
          <p class="font-bold text-white mt-8 mb-5 text-[clamp(0.85rem,1.4vw,1rem)]">
            {slide.subtitle}
          </p>
          <a
            href={slide.ctaUrl}
            class="inline-flex items-center px-8 py-3 font-black text-sm rounded-full bg-ab-beige text-[#111] tracking-[-0.02em] hover:opacity-90 transition-opacity">
            {slide.ctaLabel}
          </a>
        </div>
      ))
    }
  </div>

  <!-- Timer dot indicators -->
  <div
    class="absolute bottom-8 left-0 right-0 z-30 flex justify-center items-center gap-2">
    {
      heroSlides.map((_, i) => (
        <button
          class="hero-dot relative overflow-hidden"
          style={`height:4px; border-radius:2px; border:none; padding:0; cursor:pointer; transition:width 0.3s ease; background:rgba(255,255,255,0.35); ${i === 0 ? 'width:48px;' : 'width:16px;'}`}
          data-dot={i}
          aria-label={`Slide ${i + 1}`}>
          <div
            class="hero-dot-fill"
            style={`position:absolute; inset:0; background:#fff; transform-origin:left; transform:scaleX(0); ${i === 0 ? 'animation:dot-fill 5s linear forwards;' : ''}`}
          />
        </button>
      ))
    }
  </div>
</section>

<script>
  const DURATION = 5000;
  const slides = Array.from(
    document.querySelectorAll<HTMLElement>('.hero-slide')
  );
  const contents = Array.from(
    document.querySelectorAll<HTMLElement>('.hero-content')
  );
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.hero-dot'));
  const fills = dots.map((d) =>
    d.querySelector<HTMLElement>('.hero-dot-fill')!
  );
  const total = slides.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function activateDot(i: number) {
    dots.forEach((dot, j) => {
      const fill = fills[j];
      if (j === i) {
        dot.classList.remove('w-4');
        dot.classList.add('w-12');
        fill.style.animation = 'none';
        void fill.offsetWidth; // force reflow to restart
        fill.style.animation = `dot-fill ${DURATION}ms linear forwards`;
      } else {
        dot.classList.remove('w-12');
        dot.classList.add('w-4');
        fill.style.animation = 'none';
        fill.style.transform = 'scaleX(0)';
      }
    });
  }

  function goTo(n: number) {
    slides[current].classList.replace('opacity-100', 'opacity-0');
    contents[current].classList.replace('opacity-100', 'opacity-0');
    current = (n + total) % total;
    slides[current].classList.replace('opacity-0', 'opacity-100');
    contents[current].classList.replace('opacity-0', 'opacity-100');
    activateDot(current);
  }

  timer = setInterval(() => goTo(current + 1), DURATION);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(() => goTo(current + 1), DURATION);
    });
  });
</script>

<!-- ── Player + Standings ────────────────────────────────── -->
<div class="max-w-[1680px] mx-auto px-5 md:px-10 py-10 md:py-14 bg-white">
