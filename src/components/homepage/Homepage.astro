        class="absolute pointer-events-none select-none left-6 top-6 w-[clamp(180px,28vw,340px)] h-auto z-1"
      />
      <!-- Content bottom-left -->
      <div class="absolute bottom-0 left-0 p-8 md:p-10 z">
        <p class="mb-5 text-banner-subtitle">
          {translate(locale, 'downloadApp')}
        </p>
        <a
          href="#"
          class="btn btn-md btn-dark">
          {translate(locale, 'download')}
