---
import { fetchCollectionType } from '@/lib/strapi/client';
import {
  fetchABEvents,
  fetchABPlayers,
  getTeamLogoSrc,
  type SIPlayer,
} from '@/lib/si/client';
import { abConfig } from '@/lib/config/ab';
import { strapiMediaUrl } from '@/lib/strapi/client';
import SquadCard from '@/components/SquadCard.astro';
import MatchScheduleList from '@/components/MatchScheduleList.astro';
import MiniCalendar from '@/components/MiniCalendar.astro';
import { translate } from '@/lib/i18n';
import { decodeHtml } from '@/lib/utils';
import StandingsWidget from '@/components/StandingsWidget.astro';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

const [articles, events, players] = await Promise.all([
  fetchCollectionType<any[]>('articles', {
    locale,
    sort: ['publishedAt:desc'],
    populate: ['image', 'categories'],
    pagination: { pageSize: 8 },
  }).catch(() => [] as any[]),
  fetchABEvents({ locale, limit: 20 }).catch(() => [] as any[]),
  fetchABPlayers(locale).catch((): SIPlayer[] => []),
]);

const positionOrder: Record<string, number> = {
  keeper: 0,
  defender: 1,
  midfielder: 2,
  forward: 3,
};
const sortedPlayers = [...players].sort(
  (a, b) => (positionOrder[a.position] ?? 4) - (positionOrder[b.position] ?? 4)
);

const nextMatch = events.find(
  (e: any) => e.statusType === 'notstarted' || e.statusType === 'inprogress'
);
const recentResults = events
  .filter((e: any) => e.statusType === 'finished')
  .slice(0, 5);

const abHome = nextMatch ? nextMatch.homeId === abConfig.teamId : false;
const opponent = nextMatch
  ? abHome
    ? nextMatch.awayName
    : nextMatch.homeName
  : null;
const opponentId = nextMatch
  ? abHome
    ? nextMatch.awayId
    : nextMatch.homeId
  : null;
const oppLogo = opponentId ? getTeamLogoSrc(opponentId) : null;
const matchDateStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleDateString(
      locale === 'da' ? 'da-DK' : 'en-US',
      {
        weekday: 'long',
        month: 'long',
        day: 'numeric',
      }
    )
  : null;
const matchTimeStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleTimeString(
      locale === 'da' ? 'da-DK' : 'en-GB',
      {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      }
    )
  : null;

function articlePath(slug: string) {
  return locale === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;
}
function localPath(path: string) {
  return locale === 'en' ? `/en${path}` : path;
}

const products = [
  {
    name: translate(locale, 'productGreenTShirt'),
    price: 'DKK 89',
    originalPrice: 'DKK 169',
    img: '/images/product-1.png',
  },
  {
    name: translate(locale, 'productGreenSweatshirt'),
    price: 'DKK 129',
    originalPrice: 'DKK 249',
    img: '/images/product-2.png',
  },
  {
    name: translate(locale, 'productGreySweater'),
    price: 'DKK 219',
    originalPrice: 'DKK 429',
    img: '/images/product-3.png',
  },
];

const heroSlides = [
  {
    img: '/images/hero.jpg',
    alt: 'AB 1889',
    headline: translate(locale, 'heroShopHeadline'),
    subtitle: translate(locale, 'heroShopSubtitle'),
    ctaLabel: translate(locale, 'heroShopNow'),
    ctaUrl: 'https://shop.ab.dk',
  },
  {
    img: '/images/matches-header-bg.png',
    alt: translate(locale, 'heroMatchesAlt'),
    headline: translate(locale, 'heroMatchesHeadline'),
    subtitle: translate(locale, 'heroMatchesSubtitle'),
    ctaLabel: translate(locale, 'heroMatchesCta'),
    ctaUrl: localPath('/kampe'),
  },
  {
    img: '/images/join-team-ab-bg.png',
    alt: translate(locale, 'heroJoinAlt'),
    headline: translate(locale, 'heroJoinHeadline'),
    subtitle: translate(locale, 'heroJoinSubtitle'),
    ctaLabel: translate(locale, 'heroJoinCta'),
    ctaUrl: localPath('/om/bliv-medlem'),
  },
];
---

<style>
  @keyframes dot-fill {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>

<!-- ── Hero Slider ───────────────────────────────────────── -->
<section
  id="hero-slider"
  class="relative w-full overflow-hidden h-[60svh] min-h-[560px] max-h-[960px]">
  <!-- Slide images -->
  {
    heroSlides.map((slide, i) => (
      <div
        class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-slide={i}>
        <img
          src={slide.img}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          class="w-full h-full object-cover object-center"
        />
      </div>
    ))
  }

  <!-- Overlay -->
  <div class="absolute inset-0 z-10 bg-black/20"></div>

  <!-- Centered content -->
  <div
    class="absolute inset-0 z-20 flex flex-col items-center justify-center text-center px-6">
    {
      heroSlides.map((slide, i) => (
        <div
          class={`hero-content absolute inset-0 flex flex-col items-center justify-center px-6 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-content={i}>
          <h1 class="font-black text-white leading-none text-[clamp(4rem,11vw,10rem)] tracking-[-0.04em] text-balance">
            {slide.headline}
          </h1>
          <p class="font-medium text-white mt-8 mb-5 text-[clamp(1.7rem,2.8vw,2rem)]">
            {slide.subtitle}
          </p>
          <a
            href={slide.ctaUrl}
            class="btn btn-lg btn-beige">
            {slide.ctaLabel}
          </a>
        </div>
      ))
    }
  </div>

  <!-- Timer dot indicators -->
  <div
    class="absolute bottom-8 left-0 right-0 z-30 flex justify-center items-center gap-2">
    {
      heroSlides.map((_, i) => (
        <button
          class="hero-dot relative overflow-hidden"
          style={`height:4px; border-radius:2px; border:none; padding:0; cursor:pointer; transition:width 0.3s ease; background:rgba(255,255,255,0.35); ${i === 0 ? 'width:48px;' : 'width:16px;'}`}
          data-dot={i}
          aria-label={`Slide ${i + 1}`}>
          <div
            class="hero-dot-fill"
            style={`position:absolute; inset:0; background:#fff; transform-origin:left; transform:scaleX(0); ${i === 0 ? 'animation:dot-fill 5s linear forwards;' : ''}`}
          />
        </button>
      ))
    }
  </div>
</section>

<script>
  const DURATION = 5000;
  const slides = Array.from(
    document.querySelectorAll<HTMLElement>('.hero-slide')
  );
  const contents = Array.from(
    document.querySelectorAll<HTMLElement>('.hero-content')
  );
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.hero-dot'));
  const fills = dots.map((d) =>
    d.querySelector<HTMLElement>('.hero-dot-fill')!
  );
  const total = slides.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function activateDot(i: number) {
    dots.forEach((dot, j) => {
      const fill = fills[j];
      if (j === i) {
        dot.classList.remove('w-4');
        dot.classList.add('w-12');
        fill.style.animation = 'none';
        void fill.offsetWidth; // force reflow to restart
        fill.style.animation = `dot-fill ${DURATION}ms linear forwards`;
      } else {
        dot.classList.remove('w-12');
        dot.classList.add('w-4');
        fill.style.animation = 'none';
        fill.style.transform = 'scaleX(0)';
      }
    });
  }

  function goTo(n: number) {
    slides[current].classList.replace('opacity-100', 'opacity-0');
    contents[current].classList.replace('opacity-100', 'opacity-0');
    current = (n + total) % total;
    slides[current].classList.replace('opacity-0', 'opacity-100');
    contents[current].classList.replace('opacity-0', 'opacity-100');
    activateDot(current);
  }

  timer = setInterval(() => goTo(current + 1), DURATION);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(() => goTo(current + 1), DURATION);
    });
  });
</script>

<!-- ── Player + Standings ────────────────────────────────── -->
<section
  id="player-standings"
  class="content-container py-8 md:py-10 bg-white">
  <div
    class="grid lg:grid-cols-[clamp(280px,28vw,460px)_1fr] gap-8 xl:gap-10 items-start">
    <!-- Left: Player photo + next match + buy tickets -->
    <div
      id="player-featured"
      class="flex flex-col">
      <div class="relative overflow-hidden bg-rich-black">
        <img
          src="/images/player-featured.png"
          alt="AB 1889 Player"
          loading="lazy"
          class="w-full h-full object-cover object-top aspect-3/4"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-black/55 to-transparent">
        </div>
        <div class="absolute left-4 top-4 flex items-start justify-between">
          <a
            href="https://billet.ab.dk/"
            target="_blank"
            rel="noreferrer"
            class="btn btn-md btn-green">
            {translate(locale, 'buyTickets')}
          </a>
        </div>
      </div>

      <!-- Next match card -->
      {
        nextMatch && opponent && (
          <div
            id="next-match"
            class="bg-ab-green overflow-hidden min-h-[212px] px-6 py-5 flex flex-col">
            <h3
              class="font-black text-white leading-[0.86] tracking-[-0.04em] mb-6"
              style="font-size:clamp(1.75rem,3vw,2.1875rem)">
              {translate(locale, 'nextMatch')}
            </h3>
            <div class="flex items-center justify-between gap-4 flex-1">
              <div class="flex flex-col items-center gap-2 shrink-0 w-[76px]">
                <img
                  src="/images/ab-logo-alt.png"
                  alt="AB"
                  width="81"
                  height="81"
                  class="size-[81px] object-contain"
                />
                <span class="text-sm font-normal text-white text-center tracking-[-0.02em]">
                  AB
                </span>
              </div>
              <div class="flex flex-col items-center text-center text-white flex-1 min-w-0">
                {matchDateStr && (
                  <p class="text-lg font-normal tracking-[-0.02em]">
                    {matchDateStr}
                  </p>
                )}
                {matchTimeStr && (
                  <p class="text-lg font-black tracking-[-0.02em]">
                    {matchTimeStr}
                  </p>
                )}
              </div>
              <div class="flex flex-col items-center gap-2 shrink-0 w-[76px]">
                {oppLogo ? (
                  <img
                    src={oppLogo}
                    alt={opponent}
                    width="81"
                    height="81"
                    class="size-[81px] object-contain"
                  />
                ) : (
                  <div class="size-[81px] rounded-full flex items-center justify-center text-sm font-black bg-white/10 text-white">
                    {opponent.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <span class="text-sm font-normal text-center text-white tracking-[-0.02em] leading-tight">
                  {opponent}
                </span>
              </div>
            </div>
          </div>
        )
      }
    </div>

    <!-- Right: Standings -->
    <div
      id="standings"
      class="overflow-hidden bg-white shadow-sm">
      <StandingsWidget locale={locale} />
    </div>
  </div>
</section>

<!-- ── Recent Results ──────────────────────────────────── -->
{
  recentResults.length > 0 && (
    <section
      id="recent-results"
      class="bg-white border-t border-gray-100">
      <div class="content-container py-8 nd:py-10">
        <div class="flex items-center gap-3 mb-5">
          <p class="text-xs font-black uppercase text-gray-400 tracking-[0.22em]">
            {translate(locale, 'recentResults')}
          </p>
          <div class="flex-1 h-px bg-gray-200" />
          <a
            href={localPath('/kampe')}
            class="text-xs font-bold text-ab-green">
            {translate(locale, 'seeAllArrow')}
          </a>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-gray-100">
                <th class="text-left pb-2 text-xs font-black uppercase text-gray-400 tracking-[0.14em] w-[220px]">
                  {translate(locale, 'date')}
                </th>
                <th class="text-left pb-2 text-xs font-black uppercase text-gray-400 tracking-[0.14em]">
                  {translate(locale, 'homeTeam')}
                </th>
                <th class="text-center pb-2 text-xs font-black uppercase text-gray-400 tracking-[0.14em] w-20">
                  {translate(locale, 'score')}
                </th>
                <th class="text-right pb-2 text-xs font-black uppercase text-gray-400 tracking-[0.14em]">
                  {translate(locale, 'awayTeam')}
                </th>
              </tr>
            </thead>
            <tbody>
              {recentResults.map((event: any) => {
                const isHome = event.homeId === 9805;
                return (
                  <tr class="result-row odd:bg-gray-50 border-b border-gray-100">
                    <td class="py-3 text-xs text-gray-400 tabular-nums">
                      {new Date(event.startDate).toLocaleDateString(
                        locale === 'da' ? 'da-DK' : 'en-GB',
                        {
                          weekday: 'short',
                          day: 'numeric',
                          month: 'short',
                        }
                      )}
                    </td>
                    <td
                      class={`py-3 text-sm font-bold ${isHome ? 'text-ab-green' : 'text-[#111]'}`}>
                      {event.homeName}
                    </td>
                    <td class="py-3 text-sm font-black text-center text-ab-gold tabular-nums tracking-[0.04em]">
                      {event.score ?? '–'}
                    </td>
                    <td
                      class={`py-3 text-sm font-bold text-right ${!isHome ? 'text-ab-green' : 'text-[#111]'}`}>
                      {event.awayName}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )
}

<!-- ── Join Team AB ──────────────────────────────────────── -->
<a
  id="join-team-ab"
  href={localPath('/bliv-involveret/myab')}
  class="flex items-center relative overflow-hidden min-h-[clamp(120px,16vw,200px)] w-full no-underline">
  <div
    class="absolute inset-0 bg-[url('/images/join-team-ab-bg.png')] bg-cover bg-center">
  </div>

  <div class="content-container relative w-full">
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-6 w-full">
      <h2
        class="font-black text-white leading-none text-[clamp(2.8rem,7vw,6.5rem)] tracking-tighter text-balance normal-case">
        {translate(locale, 'joinTeamAbHeadline')}
