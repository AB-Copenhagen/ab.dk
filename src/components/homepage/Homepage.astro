      </div>
    </div>

    <!-- ABTV: Watch Live -->
    <div
      id="abtv"
      class="relative overflow-hidden flex flex-col justify-between min-h-[clamp(400px,50vw,620px)]">
      <div class="absolute inset-0">
        <img
          src="/images/banner-watch-live.png"
          alt="ABTV"
          loading="lazy"
          class="w-full h-full object-cover object-center"
        />
        <div
          class="absolute inset-0 bg-[linear-gradient(to_top,rgba(0,0,0,0.75)_0%,rgba(0,0,0,0.15)_60%,transparent_100%)]">
        </div>
      </div>
