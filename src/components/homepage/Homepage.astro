          <a href={localPath('/kampe')} class="text-xs font-medium px-3 py-1.5 rounded-full border border-white/30 text-white/70 hover:text-white hover:border-white/70 transition-colors">
            {locale === 'da' ? 'Se alle →' : 'All →'}
