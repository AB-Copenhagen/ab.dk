<!-- ── Calendar + Mini-Calendar ───────────────────────────── -->
<div class="bg-white">
  <div class="max-w-[1680px] mx-auto px-5 md:px-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-8">
      <!-- Left: Calendar list -->
      <div class="overflow-hidden rounded border border-gray-200">
        <div class="px-6 py-3 text-center bg-ab-green">
          <span class="font-black text-white text-sm tracking-[-0.02em]">
            {locale === 'da' ? 'Kalender' : 'Calendar'}
          </span>
        </div>
        <div class="grid font-medium text-xs py-2 px-3 gap-2" style="background:#00FF1F; color:#006A52; grid-template-columns:110px 1fr 100px 1fr 80px 1fr 64px; letter-spacing:0.02em;">
          <span>{locale === 'da' ? 'Dato' : 'Date'}</span>
          <span>{locale === 'da' ? 'Hjemme' : 'Home'}</span>
          <span class="text-center"
            >{locale === 'da' ? 'Tid/Res.' : 'Time/Results'}</span
          >
          <span>{locale === 'da' ? 'Ude' : 'Away'}</span>
          <span>{locale === 'da' ? 'Sæson' : 'Season'}</span>
          <span>{locale === 'da' ? 'Bane' : 'Ground'}</span>
          <span class="text-right"
            >{locale === 'da' ? 'Artikel' : 'Article'}</span
          >
        </div>
        {calRows.map((event: any, i: number) => {
          const isHome = event.homeId === 9805;
          const d = new Date(event.startDate);
          const dateStr = d.toLocaleDateString(locale === 'da' ? 'da-DK' : 'en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          const timeStr = d.toLocaleTimeString(locale === 'da' ? 'da-DK' : 'en-GB', { hour: '2-digit', minute: '2-digit' });
          const scoreOrTime = event.statusType === 'finished' && event.score ? event.score : timeStr;
          const evtVenue = event.properties?.venue ?? (isHome ? 'Gladsaxe Stadion' : '');
          const season = event.tournamentYear ?? '—';
          return (
            <div class="grid items-center px-3 py-2.5 text-xs gap-2" style={`grid-template-columns:110px 1fr 100px 1fr 80px 1fr 64px; background:${i % 2 === 0 ? '#fff' : '#F9F9F6'}; border-top:1px solid #EBEBEB;`}>
              <span style="color:#333;">{dateStr}</span>
              <div class="flex items-center gap-1.5">
                {isHome
                  ? <img src="/images/ab-crest.svg" alt="AB" width="18" height="18" />
                  : <span class="inline-flex w-5 h-5 rounded-full items-center justify-center text-[0.45rem] font-medium" style="background:#E5E7EB; color:#555;">{event.homeName?.slice(0,2)}</span>
                }
                <span class="font-medium truncate" style="color:#111;">{event.homeName}</span>
              </div>
              <span class="font-bold text-center" style="color:#006A52;">{scoreOrTime}</span>
              <div class="flex items-center gap-1.5">
                {!isHome
                  ? <img src="/images/ab-crest.svg" alt="AB" width="18" height="18" />
                  : <span class="inline-flex w-5 h-5 rounded-full items-center justify-center text-[0.45rem] font-medium" style="background:#E5E7EB; color:#555;">{event.awayName?.slice(0,2)}</span>
                }
                <span class="font-medium truncate" style="color:#111;">{event.awayName}</span>
              </div>
              <span style="color:#888;">{season}</span>
              <span class="truncate" style="color:#888;">{evtVenue}</span>
              {event.statusType === 'finished'
                ? <a href={localPath('/kampe')} class="text-right font-medium" style="color:#006A52; text-decoration:none;">{locale === 'da' ? 'Referat' : 'Recap'}</a>
                : <span class="text-right" style="color:#bbb;">—</span>
              }
            </div>
          );
        })}
      </div>

      <!-- Right: Mini-calendar -->
      <div class="overflow-hidden" style="border-radius:4px; border:1px solid #E5E7EB;">
        <div class="px-4 py-3 flex items-center justify-between" style="background:#006A52;">
          <span class="text-white/50 text-sm font-medium px-1">‹</span>
          <span class="font-bold text-white text-sm capitalize" style="letter-spacing:-0.02em;">{calMonthName}</span>
          <span class="text-white/50 text-sm font-medium px-1">›</span>
        </div>
        <div class="grid grid-cols-7 text-center py-2" style="background:#00FF1F;">
          {calDayLabels.map((lbl: string) => (
            <span class="text-xs font-medium" style="color:#006A52;">{lbl}</span>
          ))}
        </div>
        <div class="grid grid-cols-7 bg-white">
          {
            calCells.map((cell: any) => (
              <div
                class={`flex items-center justify-center text-xs relative aspect-square ${!cell.valid ? 'text-transparent' : cell.isToday ? 'text-[#111] font-black bg-[#F0F7F4]' : cell.hasMatch ? 'text-ab-green font-black' : 'text-[#444]'}`}>
                {cell.valid ? cell.day : ''}
                {cell.hasMatch && !cell.isToday && (
                  <span class="absolute bottom-[3px] left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-ab-neon block" />
                )}
              </div>
            ))
          }
        </div>
        <div class="text-center py-3 border-t border-gray-200">
          <a
            href={localPath('/kampe')}
            class="text-xs font-bold underline text-ab-green">
            {locale === 'da' ? 'Se alle kampe' : 'View all matches'}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

