</section>

<!-- ── Calendar + Mini-Calendar ───────────────────────────── -->
<section
  id="calendar"
  class="bg-white">
  <div class="content-container py-8 md:py-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <MatchScheduleList
        locale={locale}
        events={events}
      />
      <MiniCalendar
        locale={locale}
        events={events}
