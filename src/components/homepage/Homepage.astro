---
import { fetchCollectionType } from '@/lib/strapi/client';
import { fetchABEvents } from '@/lib/si/client';
import { strapiMediaUrl } from '@/lib/strapi/client';
import { truncate } from '@/lib/utils';
import StandingsWidget from '@/components/StandingsWidget.astro';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

const T = {
  ground:  '#060806',
  green:   '#006A52',
  gold:    '#D6A02A',
};

const [articles, events] = await Promise.all([
  fetchCollectionType<any[]>('articles', {
    locale,
    sort: ['publishedAt:desc'],
    pagination: { pageSize: 7 },
  }).catch(() => [] as any[]),
  fetchABEvents({ locale, limit: 15 }).catch(() => [] as any[]),
]);

const [featured, ...rest] = articles;
const gridArticles = rest.slice(0, 6);

const nextMatch = events.find(
  (e: any) => e.statusType === 'notstarted' || e.statusType === 'inprogress'
);
const recentResults = events.filter((e: any) => e.statusType === 'finished').slice(0, 3);

const abHome = nextMatch ? nextMatch.homeId === 9805 : false;
const opponent = nextMatch ? (abHome ? nextMatch.awayName : nextMatch.homeName) : null;
const matchDateStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleDateString(locale === 'da' ? 'da-DK' : 'en-GB', {
      weekday: 'short', day: 'numeric', month: 'short',
    }).toUpperCase()
  : null;
const matchTimeStr = nextMatch
  ? new Date(nextMatch.startDate).toLocaleTimeString(locale === 'da' ? 'da-DK' : 'en-GB', {
      hour: '2-digit', minute: '2-digit',
    })
  : null;
const venue = nextMatch?.properties?.venue ?? null;

function articlePath(slug: string) {
  return locale === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;
}
function localPath(path: string) {
  return locale === 'en' ? `/en${path}` : path;
}

function formatDate(str: string) {
  try {
    return new Date(str).toLocaleDateString(locale === 'da' ? 'da-DK' : 'en-GB', {
      day: 'numeric', month: 'short', year: 'numeric',
    });
  } catch { return ''; }
}
---

<style>
  .ab-hero {
    background:
      radial-gradient(ellipse 90% 55% at 50% -10%, rgba(0,106,82,0.18) 0%, transparent 65%),
      radial-gradient(ellipse 50% 35% at 15% 110%, rgba(0,106,82,0.10) 0%, transparent 55%),
      #060806;
  }
  .ab-hero-lines::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg,   rgba(0,106,82,0.025) 0, rgba(0,106,82,0.025) 1px, transparent 1px, transparent 72px),
      repeating-linear-gradient(90deg,  rgba(0,106,82,0.015) 0, rgba(0,106,82,0.015) 1px, transparent 1px, transparent 120px);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ab-fade-up { animation: ab-rise 0.8s cubic-bezier(0.16,1,0.3,1) both; }
    .ab-fade-up-d { animation: ab-rise 0.8s 0.15s cubic-bezier(0.16,1,0.3,1) both; }
    @keyframes ab-rise {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
  .article-img { transition: transform 0.5s ease; }
  .article-card:hover .article-img { transform: scale(1.05); }
</style>

<!-- ── Hero ──────────────────────────────────────────────── -->
<section class="ab-hero ab-hero-lines relative min-h-[calc(100svh-104px)] flex flex-col justify-end overflow-hidden px-5 md:px-12 pb-14 md:pb-20">
  <span
    aria-hidden="true"
    class="pointer-events-none select-none absolute bottom-[-8vw] right-[-3vw] font-black leading-none"
    style="font-size:58vw;color:rgba(0,106,82,0.055);letter-spacing:-0.06em"
  >AB</span>

  <div class="absolute inset-x-0 bottom-0 h-40 pointer-events-none" style="background:linear-gradient(to top,#060806,transparent)"></div>

  <div class="ab-fade-up relative z-10 max-w-5xl">
    <div class="flex items-center gap-3 mb-7">
      <div class="h-px w-8" style={`background:${T.gold}`}></div>
      <span class="text-xs font-bold uppercase" style={`color:${T.gold};letter-spacing:0.22em`}>
        Akademisk Boldklub &middot; Siden 1889
      </span>
    </div>

    <h1
      class="font-black text-white uppercase"
      style="font-size:clamp(5rem,15vw,13rem);letter-spacing:-0.04em;line-height:0.88;text-wrap:balance"
    >
      {locale === 'da' ? <Fragment>Vær<br />med.</Fragment> : <Fragment>Be<br />part.</Fragment>}
    </h1>

    <div class="mt-6 mb-6 h-0.5 w-12" style={`background:${T.green}`}></div>

    <p class="text-sm mb-8 max-w-[36ch] leading-relaxed" style="color:rgba(255,255,255,0.45);letter-spacing:0.01em">
      {locale === 'da'
        ? 'Bliv en del af historien. Følg holdet, køb billetter og støt din klub hjemme og ude.'
        : 'Be part of the story. Follow the squad, buy tickets and support your club home and away.'}
    </p>

    <div class="flex flex-wrap gap-3">
      <a
        href="https://billetter.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 font-bold text-white uppercase text-xs px-6 py-3"
        style={`background:${T.green};letter-spacing:0.15em`}
      >
        {locale === 'da' ? 'Køb billetter' : 'Buy tickets'} →
      </a>
      <a
        href={localPath('/nyheder')}
        class="inline-flex items-center gap-2 font-bold uppercase text-xs px-6 py-3 border transition-colors duration-200 hover:border-white/50 hover:text-white"
        style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.65);letter-spacing:0.15em"
      >
        {locale === 'da' ? 'Se nyheder' : 'Read news'}
      </a>
    </div>
  </div>
</section>

<!-- ── Next match bar ────────────────────────────────────── -->
{nextMatch && opponent && (
  <div class="ab-fade-up-d border-y" style={`background:${T.green};border-color:rgba(0,0,0,0.25)`}>
    <div class="max-w-7xl mx-auto px-5 md:px-12 h-14 flex items-center justify-between gap-4">
      <span class="text-xs font-bold uppercase hidden sm:block shrink-0" style="color:rgba(255,255,255,0.5);letter-spacing:0.2em">
        {locale === 'da' ? 'Næste kamp' : 'Next fixture'}
      </span>

      <div class="flex items-center gap-3 font-black text-white uppercase text-sm" style="letter-spacing:-0.01em">
        <span>AB</span>
        <span class="text-xs font-bold opacity-40" style="letter-spacing:0.1em">vs</span>
        <span>{opponent}</span>
      </div>

      <div class="hidden md:flex items-center gap-2 text-xs shrink-0" style="color:rgba(255,255,255,0.6);letter-spacing:0.06em">
        {matchDateStr && <span>{matchDateStr}</span>}
        <span style="opacity:0.35">·</span>
        {matchTimeStr && <span class="font-bold" style="font-variant-numeric:tabular-nums">{matchTimeStr}</span>}
        {venue && <><span style="opacity:0.35">·</span><span>{venue}</span></>}
      </div>

      <a
        href="https://billetter.ab.dk"
        target="_blank"
        rel="noreferrer"
        class="shrink-0 text-xs font-bold uppercase px-3 py-1.5 border transition-colors hover:bg-white/10"
        style="border-color:rgba(255,255,255,0.35);color:rgba(255,255,255,0.9);letter-spacing:0.12em"
      >
        {locale === 'da' ? 'Billetter →' : 'Tickets →'}
      </a>
    </div>
  </div>
)}

<!-- ── News + Sidebar ─────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-5 md:px-12 py-12 lg:py-16 grid lg:grid-cols-[1fr_296px] gap-8 items-start" style="background:#fff">

  <!-- News column -->
  <div>
    <div class="flex items-center gap-3 mb-5 text-xs font-bold uppercase" style="color:#9CA3AF;letter-spacing:0.22em">
      <span>{locale === 'da' ? 'Seneste fra klubben' : 'Latest from the club'}</span>
      <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <!-- Featured article -->
    {featured && (
      <a
        href={articlePath(featured.slug)}
        class="article-card group grid md:grid-cols-2 border border-gray-200 mb-px"
      >
        <div class="relative overflow-hidden" style="min-height:260px">
          {featured.image?.url ? (
            <img
              src={strapiMediaUrl(featured.image.url)}
              alt={featured.title}
              loading="lazy"
              class="article-img h-full w-full object-cover object-top"
              style="min-height:260px"
            />
          ) : (
            <div
              class="h-full w-full flex items-center justify-center font-black"
              style="min-height:260px;background:#F3F4F6;font-size:3rem;color:rgba(0,106,82,0.18);letter-spacing:-0.04em"
            >AB</div>
          )}
        </div>
        <div class="p-6 md:p-8 flex flex-col bg-white">
          {featured.categories?.[0] && (
            <p class="text-xs font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.18em">
              {featured.categories[0].name}
            </p>
          )}
          <h2 class="font-bold leading-tight mb-3" style="font-size:clamp(1.1rem,2.4vw,1.55rem);letter-spacing:-0.02em;color:#111">
            {featured.title}
          </h2>
          {featured.description && (
            <p class="text-sm leading-relaxed mb-4" style="color:#6B7280">
              {truncate(featured.description, 160)}
            </p>
          )}
          <p class="text-xs mt-auto pt-3" style="color:#9CA3AF;font-variant-numeric:tabular-nums">
            {formatDate(featured.publishedAt)}
          </p>
        </div>
      </a>
    )}

    <!-- Article grid -->
    {gridArticles.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-gray-200">
        {gridArticles.map((article: any) => (
          <a href={articlePath(article.slug)} class="article-card group flex flex-col bg-white">
            <div class="relative overflow-hidden" style="aspect-ratio:16/9">
              {article.image?.url ? (
                <img
                  src={strapiMediaUrl(article.image.url)}
                  alt={article.title}
                  loading="lazy"
                  class="article-img h-full w-full object-cover"
                />
              ) : (
                <div
                  class="h-full w-full flex items-center justify-center font-black"
                  style="background:#F3F4F6;font-size:3rem;color:rgba(0,106,82,0.18);letter-spacing:-0.04em"
                >AB</div>
              )}
            </div>
            <div class="p-4 flex flex-col flex-1">
              {article.categories?.[0] && (
                <p class="text-xs font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.18em">
                  {article.categories[0].name}
                </p>
              )}
              <h3 class="text-sm font-bold leading-snug" style="color:#111;letter-spacing:-0.01em">
                {article.title}
              </h3>
              <p class="text-xs mt-auto pt-3" style="color:#9CA3AF;font-variant-numeric:tabular-nums">
                {formatDate(article.publishedAt)}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}

    {!featured && !gridArticles.length && (
      <p class="py-16 text-sm text-center" style="color:#9CA3AF">
        {locale === 'da' ? 'Ingen artikler endnu.' : 'No articles yet.'}
      </p>
    )}

    <a
      href={localPath('/nyheder')}
      class="inline-flex items-center gap-1 mt-5 text-xs font-bold uppercase transition-opacity hover:opacity-70"
      style="color:#006A52;letter-spacing:0.12em"
    >
      {locale === 'da' ? 'Se alle nyheder' : 'All news'} →
    </a>
  </div>

  <!-- Sidebar -->
  <aside class="flex flex-col gap-5">
    <!-- Standings -->
    <div class="border border-gray-200">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-200 text-xs font-bold uppercase" style="color:#9CA3AF;letter-spacing:0.18em">
        <span>{locale === 'da' ? '1. Division' : '1st Division'}</span>
        <a href={localPath('/kampe')} class="text-xs transition-opacity hover:opacity-70" style="color:#006A52;letter-spacing:0.08em">
          {locale === 'da' ? 'Se tabel →' : 'Full table →'}
        </a>
      </div>
      <div style="background:#060806">
        <StandingsWidget locale={locale} />
      </div>
    </div>

    <!-- Recent results -->
    {recentResults.length > 0 && (
      <div class="border border-gray-200">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-200 text-xs font-bold uppercase" style="color:#9CA3AF;letter-spacing:0.18em">
          <span>{locale === 'da' ? 'Seneste resultater' : 'Recent results'}</span>
          <a href={localPath('/kampe')} class="text-xs" style="color:#006A52;letter-spacing:0.08em">
            {locale === 'da' ? 'Se alle →' : 'All →'}
          </a>
        </div>
        <ul>
          {recentResults.map((event: any) => {
            const isHome = event.homeId === 9805;
            const opp = isHome ? event.awayName : event.homeName;
            return (
              <li class="flex items-center justify-between px-4 py-3 border-b border-gray-100 last:border-b-0 gap-3">
                <span class="text-xs font-semibold truncate" style="color:#111">
                  {isHome ? `AB — ${opp}` : `${opp} — AB`}
                </span>
                <div class="flex items-center gap-2 shrink-0">
                  {event.score && (
                    <span class="text-sm font-black" style="color:#D6A02A;font-variant-numeric:tabular-nums">
                      {event.score}
                    </span>
                  )}
                  <span class="text-[0.6rem] font-bold uppercase" style="color:#9CA3AF;letter-spacing:0.1em">FT</span>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    <!-- Squad link -->
    <a
      href={localPath('/hold')}
      class="group border border-gray-200 flex items-center justify-between px-4 py-4 transition-colors duration-200 hover:border-gray-400 bg-white"
    >
      <div>
        <p class="text-xs font-bold uppercase mb-1" style="color:#9CA3AF;letter-spacing:0.18em">
          {locale === 'da' ? 'Holdet' : 'The Squad'}
        </p>
        <p class="text-sm font-bold" style="color:#111;letter-spacing:-0.01em">
          {locale === 'da' ? 'Se spillertruppen' : 'View the squad'}
        </p>
      </div>
      <span class="text-lg font-bold transition-transform group-hover:translate-x-1" style="color:#006A52">→</span>
    </a>
  </aside>
</div>

<!-- ── Join MyAB strip ────────────────────────────────────── -->
<div class="border-t border-gray-200" style="background:#F9FAFB">
  <div class="max-w-7xl mx-auto px-5 md:px-12 py-14 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
    <div class="max-w-xl">
      <p class="text-xs font-bold uppercase mb-2" style="color:#006A52;letter-spacing:0.2em">MyAB Membership</p>
      <h2 class="font-black mb-3" style="font-size:clamp(1.5rem,4vw,2.4rem);letter-spacing:-0.03em;line-height:1.05;color:#111">
        {locale === 'da'
          ? <Fragment>Bliv en del<br />af klubben.</Fragment>
          : <Fragment>Be part of<br />the club.</Fragment>}
      </h2>
      <p class="text-sm leading-relaxed" style="color:#6B7280">
        {locale === 'da'
          ? 'Eksklusiv adgang til sæsonkort, merchandise-rabatter, fan-events og alt der sker bag kulisserne.'
          : 'Exclusive access to season tickets, merchandise discounts, fan events and everything happening behind the scenes.'}
      </p>
    </div>
    <a
      href={localPath('/bliv-involveret')}
      class="shrink-0 inline-flex items-center gap-2 font-bold text-white uppercase text-xs px-7 py-4 transition-opacity hover:opacity-80"
      style="background:#006A52;letter-spacing:0.15em"
    >
      {locale === 'da' ? 'Tilmeld MyAB' : 'Join MyAB'} →
    </a>
  </div>
</div>
