<!-- ── Calendar + Mini-Calendar ───────────────────────────── -->
<div style="background:#fff;">
  <div class="max-w-[1680px] mx-auto px-5 md:px-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-8">
      <!-- Left: Calendar list -->
      <div
        class="overflow-hidden"
        style="border-radius:4px; border:1px solid #E5E7EB;">
        <div
          class="px-6 py-3 text-center"
          style="background:#006A52;">
          <span
            class="font-black text-white text-sm"
            style="letter-spacing:-0.02em;">
            {locale === 'da' ? 'Kalender' : 'Calendar'}
          </span>
        </div>
        <div
          class="grid font-black text-xs py-2 px-3 gap-2"
          style="background:#00FF1F; color:#006A52; grid-template-columns:110px 1fr 100px 1fr 80px 1fr 64px; letter-spacing:0.02em;">
          <span>{locale === 'da' ? 'Dato' : 'Date'}</span>
          <span>{locale === 'da' ? 'Hjemme' : 'Home'}</span>
          <span class="text-center"
            >{locale === 'da' ? 'Tid/Res.' : 'Time/Results'}</span
          >
          <span>{locale === 'da' ? 'Ude' : 'Away'}</span>
          <span>{locale === 'da' ? 'Sæson' : 'Season'}</span>
          <span>{locale === 'da' ? 'Bane' : 'Ground'}</span>
          <span class="text-right"
            >{locale === 'da' ? 'Artikel' : 'Article'}</span
          >
        </div>
        {
          calRows.map((event: any, i: number) => {
            const isHome = event.homeId === 9805;
            const d = new Date(event.startDate);
            const dateStr = d.toLocaleDateString(
              locale === 'da' ? 'da-DK' : 'en-US',
              { month: 'long', day: 'numeric', year: 'numeric' }
            );
            const timeStr = d.toLocaleTimeString(
              locale === 'da' ? 'da-DK' : 'en-GB',
              { hour: '2-digit', minute: '2-digit' }
            );
            const scoreOrTime =
              event.statusType === 'finished' && event.score
                ? event.score
                : timeStr;
            const evtVenue =
              event.properties?.venue ?? (isHome ? 'Gladsaxe Stadion' : '');
            const season = event.tournamentYear ?? '—';
            return (
              <div
                class="grid items-center px-3 py-2.5 text-xs gap-2"
                style={`grid-template-columns:110px 1fr 100px 1fr 80px 1fr 64px; background:${i % 2 === 0 ? '#fff' : '#F9F9F6'}; border-top:1px solid #EBEBEB;`}>
                <span style="color:#333;">{dateStr}</span>
                <div class="flex items-center gap-1.5">
                  {isHome ? (
                    <img
                      src="/images/ab-crest.svg"
                      alt="AB"
                      width="18"
                      height="18"
                    />
                  ) : (
                    <span
                      class="inline-flex w-5 h-5 rounded-full items-center justify-center text-[0.45rem] font-black"
                      style="background:#E5E7EB; color:#555;">
                      {event.homeName?.slice(0, 2)}
                    </span>
                  )}
                  <span
                    class="font-bold truncate"
                    style="color:#111;">
                    {event.homeName}
                  </span>
                </div>
                <span
                  class="font-black text-center"
                  style="color:#006A52;">
                  {scoreOrTime}
                </span>
                <div class="flex items-center gap-1.5">
                  {!isHome ? (
                    <img
                      src="/images/ab-crest.svg"
                      alt="AB"
                      width="18"
                      height="18"
                    />
                  ) : (
                    <span
                      class="inline-flex w-5 h-5 rounded-full items-center justify-center text-[0.45rem] font-black"
                      style="background:#E5E7EB; color:#555;">
                      {event.awayName?.slice(0, 2)}
                    </span>
                  )}
                  <span
                    class="font-bold truncate"
                    style="color:#111;">
                    {event.awayName}
                  </span>
                </div>
                <span style="color:#888;">{season}</span>
                <span
                  class="truncate"
                  style="color:#888;">
                  {evtVenue}
                </span>
                {event.statusType === 'finished' ? (
                  <a
                    href={localPath('/kampe')}
                    class="text-right font-bold"
                    style="color:#006A52; text-decoration:none;">
                    {locale === 'da' ? 'Referat' : 'Recap'}
                  </a>
                ) : (
                  <span
                    class="text-right"
                    style="color:#bbb;">
                    —
                  </span>
                )}
              </div>
            );
          })
        }
      </div>

      <!-- Right: Mini-calendar -->
      <div
        class="overflow-hidden"
        style="border-radius:4px; border:1px solid #E5E7EB;">
        <div
          class="px-4 py-3 flex items-center justify-between"
          style="background:#006A52;">
          <span class="text-white/50 text-sm font-bold px-1">‹</span>
          <span
            class="font-black text-white text-sm capitalize"
            style="letter-spacing:-0.02em;"
            >{calMonthName}</span
          >
          <span class="text-white/50 text-sm font-bold px-1">›</span>
        </div>
        <div
          class="grid grid-cols-7 text-center py-2"
          style="background:#00FF1F;">
          {
            calDayLabels.map((lbl: string) => (
              <span
                class="text-xs font-black"
                style="color:#006A52;">
                {lbl}
              </span>
            ))
          }
        </div>
        <div class="grid grid-cols-7 bg-white">
          {
            calCells.map((cell: any) => (
              <div
                class="flex items-center justify-center text-xs relative"
                style={`aspect-ratio:1; color:${!cell.valid ? 'transparent' : cell.isToday ? '#111' : cell.hasMatch ? '#006A52' : '#444'}; font-weight:${cell.isToday || cell.hasMatch ? '900' : '400'}; background:${cell.isToday ? '#F0F7F4' : 'transparent'};`}>
                {cell.valid ? cell.day : ''}
                {cell.hasMatch && !cell.isToday && (
                  <span
                    class="absolute"
                    style="bottom:3px; left:50%; transform:translateX(-50%); width:4px; height:4px; border-radius:50%; background:#00FF1F; display:block;"
                  />
                )}
              </div>
            ))
          }
        </div>
        <div
          class="text-center py-3"
          style="border-top:1px solid #E5E7EB;">
          <a
            href={localPath('/kampe')}
            class="text-xs font-bold underline"
            style="color:#006A52;">
            {locale === 'da' ? 'Se alle kampe' : 'View all matches'}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

