---
import { localePath, translate, type Locale } from '@/lib/i18n';
import { getTeamLogoSrc, type SIEvent } from '@/lib/si/client';

interface Props {
  locale: Locale;
  events: SIEvent[];
  limit?: number;
}

const { locale, events, limit = 7 } = Astro.props;

const rows = [...events]
  .sort(
    (a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime()
  )
  .slice(0, limit);

function formatEventScore(score: unknown): string {
  if (score == null) return '–';
  if (typeof score === 'string') {
    return score.replace('-', ' - ').replace(':', ' - ');
  }
  if (
    typeof score === 'object' &&
    'home' in (score as object) &&
    'away' in (score as object)
  ) {
    const { home, away } = score as { home: number; away: number };
    return `${home} - ${away}`;
  }
  return '–';
}

function eventVenue(event: SIEvent): string {
  const props = event.properties as
    | { venueName?: string; venue?: string }
    | undefined;
  return (
    props?.venueName ??
    props?.venue ??
    (event.homeId === 9805 ? 'Gladsaxe Stadion' : '')
  );
}
---

<div id="calendar-list" class="lg:col-span-8 overflow-x-auto">
  <div class="min-w-[560px]">
    <div class="widget-header">
      <h2 class="widget-heading">{translate(locale, 'latestResults')}</h2>
      <a
        href={localePath(locale, '/kampe')}
        class="font-normal text-white underline text-base tracking-[-0.02em] shrink-0 ml-6">
        {translate(locale, 'viewAllMatches')}
      </a>
    </div>

    <div class="grid py-2.5 px-6 bg-ab-neon grid-cols-[2fr_1.75fr_90px_1.75fr_1.5fr]">
      <span class="widget-th">{translate(locale, 'date')}</span>
      <span class="widget-th text-right">{translate(locale, 'homeTeam')}</span>
      <span class="widget-th text-center">{translate(locale, 'score')}</span>
      <span class="widget-th">{translate(locale, 'awayTeam')}</span>
      <span class="widget-th">{translate(locale, 'ground')}</span>
    </div>

    {
      rows.map((event, i) => {
        const d = new Date(event.startDate);
        const weekday = d.toLocaleDateString(
          locale === 'da' ? 'da-DK' : 'en-US',
          { weekday: 'long' }
        );
        const monthDay = d.toLocaleDateString(
          locale === 'da' ? 'da-DK' : 'en-US',
          { month: 'long', day: 'numeric' }
        );
        const timeStr = d.toLocaleTimeString('en-US', {
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
        });
        const dateTimeStr = `${weekday}, ${monthDay} – ${timeStr}`;
        const scoreStr =
          event.statusType === 'finished'
            ? formatEventScore(event.score)
            : '–';

        return (
          <div
            class:list={[
              'grid items-center px-6 py-3 gap-2 grid-cols-[2fr_1.75fr_90px_1.75fr_1.5fr] border-t border-[#EBEBEB]',
              i % 2 === 0 ? 'widget-row-even' : 'widget-row-odd',
            ]}>
            <span class="widget-td font-black">{dateTimeStr}</span>
            <span class="widget-td font-normal flex items-center gap-2 justify-end">
              {event.homeName}
              <img
                src={getTeamLogoSrc(event.homeId)}
                alt=""
                width="24"
                height="24"
                class="shrink-0 object-contain h-[24px] w-auto"
                onerror="this.style.display='none'"
              />
            </span>
            <span class="widget-td text-center font-black tabular-nums">{scoreStr}</span>
            <span class="widget-td font-normal flex items-center gap-2">
              <img
                src={getTeamLogoSrc(event.awayId)}
                alt=""
                width="24"
                height="24"
                class="shrink-0 object-contain h-[24px] w-auto"
                onerror="this.style.display='none'"
              />
              {event.awayName}
            </span>
            <span class="widget-td font-normal truncate">{eventVenue(event)}</span>
          </div>
        );
      })
    }
  </div>
</div>
