---
import { fetchStandings } from '@/lib/si/client';

interface Props {
  locale: 'da' | 'en';
}

const { locale } = Astro.props;

let rows: any[] = [];
let error = '';

try {
  rows = await fetchStandings(locale);
} catch (err) {
  error = locale === 'da' ? 'Stilling ikke tilgængelig' : 'Standings unavailable';
}

const headers = locale === 'da'
  ? ['#', 'Hold', 'K', 'V', 'U', 'T', 'Mål', 'Pt']
  : ['#', 'Club', 'P', 'W', 'D', 'L', 'GD', 'Pts'];
---

{error ? (
  <div class="text-xs py-4 text-center" style="color:#888">{error}</div>
) : !rows.length ? (
  <div class="text-xs py-6 text-center" style="color:#888">
    {locale === 'da' ? 'Sæsonen er endnu ikke startet' : 'Season has not started yet'}
  </div>
) : (
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[#E5E7EB]">
          {headers.map((h) => (
            <th class="py-2 px-2 text-left font-bold uppercase first:pl-4 last:pr-4" style="color:#7A9185;font-size:0.6rem;letter-spacing:0.12em">
              {h}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-[#E5E7EB]">
        {rows.map((row: any) => {
          const isAB = row.teamId === 9805;
          const gd = (row.goalsScored ?? 0) - (row.goalsConceded ?? 0);
          const gdStr = gd > 0 ? `+${gd}` : String(gd);
          return (
            <tr
              class="transition-colors hover:bg-[#F5FAF8]"
              style={isAB ? 'background:rgba(0,106,82,0.07)' : ''}
            >
              <td class="py-2.5 pl-4 pr-2 tabular-nums font-bold" style={isAB ? 'color:#D6A02A' : 'color:#888'}>
                {row.rank}
              </td>
              <td class="py-2.5 px-2 font-bold" style={isAB ? 'color:#006A52' : 'color:#111'}>
                {row.teamName ?? '—'}
                {isAB && <span class="ml-1.5 text-[0.55rem] uppercase font-black" style="color:#D6A02A">▲</span>}
              </td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#888">{row.matchesPlayed}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#888">{row.matchesWon}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#888">{row.matchesDraw}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#888">{row.matchesLost}</td>
              <td class="py-2.5 px-2 tabular-nums" style="color:#888">{gdStr}</td>
              <td class="py-2.5 pr-4 pl-2 font-black tabular-nums" style={isAB ? 'color:#006A52' : 'color:#111'}>
                {row.points}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
)}
