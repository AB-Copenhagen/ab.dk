WEBSITE_URL=http://localhost:3000 # Add the correct ENV var for this onto your hosting platform, point it to your production website.
ENVIRONMENT=development
PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:1337
PREVIEW_SECRET=preview_secret

# ── Descope Auth ─────────────────────────────────────
# Project ID and base URL — same value used for both server and client.
# NEXT_PUBLIC_ prefix is required for the client-side AuthProvider.
# Custom domain (auth.ab.dk) confirmed — requires Descope Pro tier.
NEXT_PUBLIC_DESCOPE_PROJECT_ID=P3EPl5uP1I4EeAMt7zk7daQcMxD6
DESCOPE_PROJECT_ID=P3EPl5uP1I4EeAMt7zk7daQcMxD6
DESCOPE_BASE_URL=https://auth.ab.dk
# Server-only — Management API key for user sync. Never prefix NEXT_PUBLIC_.
DESCOPE_MANAGEMENT_KEY=

# ── Shopify Storefront ────────────────────────────────
# Public access token — safe for browser. Obtain from Shopify Admin → Develop apps.
SHOPIFY_STORE_DOMAIN=shop.ab.dk
SHOPIFY_APP_CLIENT_ID=
# shpss_... prefix — Storefront API access token. Public (browser-safe) per Shopify's model.
SHOPIFY_STOREFRONT_TOKEN=
# Server-only — API secret key from Shopify Admin → Apps → your app → API credentials.
# Used to verify Shopify webhook HMAC signatures before triggering ISR revalidation.
SHOPIFY_WEBHOOK_SECRET=

# ── SportsInnovation API ──────────────────────────────
# SI_ACCESS_TOKEN is server-only. Do NOT prefix with NEXT_PUBLIC_.
# Obtain from: https://dash.si-ab.com/account/settings
SI_ACCESS_TOKEN=

# AB 1889 team ID — confirmed value, do not change
AB_TEAM_ID=9805

# 1.division tournament ID — find via GET /tournaments or dash.si-ab.com
AB_TOURNAMENT_ID=

# Current season ID — find via GET /tournaments/{AB_TOURNAMENT_ID}/season
AB_SEASON_ID=

# SportsInnovation API base URL (do not change unless instructed by SI)
SI_API_BASE_URL=https://api.superliga.dk