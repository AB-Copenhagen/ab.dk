# Strapi CMS
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
STRAPI_WEBHOOK_SECRET=
# Must match Strapi Cloud's PREVIEW_SECRET env var — validates requests to /api/preview
PREVIEW_SECRET=

# Sports Innovation API
SI_API_BASE_URL=https://ss2.tjekscores.dk
SI_ACCESS_TOKEN=
SI_TEAM_LOGO_BASE_URL=https://dxugi372p6nmc.cloudfront.net/spdk/current/64x64
AB_TEAM_ID=9805
AB_TOURNAMENT_ID=85
AB_SEASON_ID=36245

# Descope auth
DESCOPE_PROJECT_ID=
DESCOPE_MANAGEMENT_KEY=

# Mailgun (EU region)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
MAILGUN_LIST_ADDRESS=

# Contact
CONTACT_EMAIL=kontakt@ab.dk

# Shopify (optional — homepage featured products)
# SHOPIFY_STOREFRONT_ACCESS_TOKEN is the public Storefront API access token
# (Shopify admin → Settings → Apps → your app → API credentials). Not a secret —
# the Storefront API is designed to be called from public clients.
SHOPIFY_DOMAIN=shop.ab.dk
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Wasabi media storage
WASABI_BUCKET=
WASABI_REGION=eu-central-1
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=

# App
PORT=1889
HOST=0.0.0.0

# Search indexing — schema in astro.config.mjs, default false (blocked).
# Set to true before production launch (see README).
ALLOW_SEARCH_INDEXING=
